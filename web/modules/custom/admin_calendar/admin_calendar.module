<?php

/**
 * @file
 * Admin Calendar — BOS scheduling dispatch calendar.
 *
 * Provides a FullCalendar-based weekly/monthly view of scheduling entities.
 * Color-codes Work Orders by department via the service taxonomy term chain:
 *   scheduling → work_order.field_service → services term → field_department → field_color
 *
 * The old fullcalendar_view preprocess hook has been removed.
 * This module no longer depends on the fullcalendar_view contrib module.
 */

/**
 * Implements hook_theme().
 */
function admin_calendar_theme(): array {
  return [
    'admin_calendar_page' => [
      'variables' => [
        'departments' => [],
        'teammates'   => [],
        'statuses'    => [],
      ],
      'template' => 'admin-calendar-page',
    ],
  ];
}
