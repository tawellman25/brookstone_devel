<?php

/**
 * @file
 * Backflow Device lifecycle hooks.
 *
 * Gate 2 (module logic only — no new fields):
 *  - On insert, assign a stable Device ID title (BF-NNNNNN) and generate a
 *    permanent QR code encoding the device's ABSOLUTE CANONICAL URL.
 *  - On the public "full" view mode, render a pull-through street address
 *    (current value, reaching into the referenced property by code) without
 *    granting any access on the properties entity.
 *
 * The QR is permanent: it is generated once on insert (when field_qr_code is
 * empty) and never regenerated by a later ->save(). The QR encodes the
 * canonical route (immutable) — Redirect 301s it to the property-path alias.
 */

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\ContentEntityInterface;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\File\FileExists;
use Drupal\Core\File\FileSystemInterface;
use Endroid\QrCode\Builder\Builder;
use Endroid\QrCode\Encoding\Encoding;
use Endroid\QrCode\ErrorCorrectionLevel;
use Endroid\QrCode\Writer\PngWriter;

/**
 * Implements hook_entity_insert().
 *
 * Only fires on insert (id now known). A normal later ->save() is an update
 * and never re-enters this hook, so the title and QR are written exactly once.
 */
function backflow_device_entity_insert(EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'property_backflow_device') {
    return;
  }
  _backflow_device_finalize($entity);
}

/**
 * Assigns the Device ID title and the permanent QR code, then saves once.
 *
 * Guarded so it is a no-op once the title is set and field_qr_code is
 * populated — a defensive belt-and-suspenders in addition to only hooking
 * insert.
 */
function _backflow_device_finalize(ContentEntityInterface $device) {
  $expected_title = 'BF-' . str_pad((string) $device->id(), 6, '0', STR_PAD_LEFT);
  $needs_title = $device->label() !== $expected_title;
  $needs_qr = $device->get('field_qr_code')->isEmpty();
  if (!$needs_title && !$needs_qr) {
    return;
  }

  // Re-entrancy guard (the follow-up save below triggers update hooks).
  static $running = [];
  $id = $device->id();
  if (!empty($running[$id])) {
    return;
  }
  $running[$id] = TRUE;

  try {
    if ($needs_title) {
      $device->set('title', $expected_title);
    }

    if ($needs_qr) {
      try {
        $file = _backflow_device_generate_qr($device, $expected_title);
        if ($file) {
          $device->set('field_qr_code', [
            'target_id' => $file->id(),
            'alt' => 'QR code for ' . $expected_title,
          ]);
        }
      }
      catch (\Throwable $e) {
        // Never block device creation on QR failure; log and continue.
        \Drupal::logger('backflow_device')->error('QR generation failed for device @id: @msg', [
          '@id' => $id,
          '@msg' => $e->getMessage(),
        ]);
      }
    }

    // Single follow-up save (the cabb8a6e safe double-save: title set directly,
    // no AEL sentinel token).
    $device->save();

    // Title is now set, so (re)generate the pathauto alias from it.
    if (\Drupal::moduleHandler()->moduleExists('pathauto')) {
      \Drupal::service('pathauto.generator')->updateEntityAlias($device, 'update', ['force' => TRUE]);
    }
  }
  finally {
    unset($running[$id]);
  }
}

/**
 * Builds a PNG QR of the device's absolute canonical URL and saves it.
 *
 * @return \Drupal\file\FileInterface|null
 *   The managed file, or NULL on failure.
 */
function _backflow_device_generate_qr(ContentEntityInterface $device, string $title) {
  // Canonical route (immutable) — NOT the pathauto alias. The 'alias' => TRUE
  // option suppresses alias substitution so we encode the raw
  // /property_backflow_device/{id} path (Redirect 301s it to the property-path
  // alias). setAbsolute() yields a full https URL scannable off-site;
  // toString(TRUE) avoids leaked-metadata exceptions in this non-render context.
  $url = $device->toUrl('canonical', ['alias' => TRUE])
    ->setAbsolute()
    ->toString(TRUE)
    ->getGeneratedUrl();

  $result = (new Builder(
    writer: new PngWriter(),
    data: $url,
    encoding: new Encoding('UTF-8'),
    errorCorrectionLevel: ErrorCorrectionLevel::High,
    size: 300,
    margin: 10,
  ))->build();
  $png = $result->getString();

  $directory = 'public://property_backflow_device/device/qr';
  \Drupal::service('file_system')->prepareDirectory(
    $directory,
    FileSystemInterface::CREATE_DIRECTORY | FileSystemInterface::MODIFY_PERMISSIONS
  );
  $uri = $directory . '/qr-' . $title . '.png';

  return \Drupal::service('file.repository')->writeData($png, $uri, FileExists::Replace);
}

/**
 * Implements hook_entity_view().
 *
 * On the public "full" view mode, replace the field_property entity-reference
 * label (which is access-filtered for anonymous) with a pull-through street
 * address read directly from the referenced property by code. This exposes
 * ONLY street + city/zip + a maintained-by line — no owner, contact, gate
 * code, notes, or link — and does not change properties entity access.
 */
function backflow_device_entity_view(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display, $view_mode) {
  if ($entity->getEntityTypeId() !== 'property_backflow_device' || $view_mode !== 'full') {
    return;
  }

  // Remove the property reference label render (kept on admin/default displays).
  unset($build['field_property']);

  $lines = [];
  $property = $entity->get('field_property')->entity;
  if ($property instanceof ContentEntityInterface) {
    $street = $property->hasField('field_street_address')
      ? trim((string) $property->get('field_street_address')->value) : '';
    if ($street !== '') {
      $lines[] = $street;
    }

    $city = '';
    $zip = '';
    if ($property->hasField('field_zipcode_reference') && !$property->get('field_zipcode_reference')->isEmpty()) {
      $zipcode = $property->get('field_zipcode_reference')->entity;
      if ($zipcode instanceof ContentEntityInterface) {
        if ($zipcode->hasField('field_zipcode')) {
          $zip = trim((string) $zipcode->get('field_zipcode')->value);
        }
        if ($zipcode->hasField('field_city') && !$zipcode->get('field_city')->isEmpty()) {
          $city_entity = $zipcode->get('field_city')->entity;
          if ($city_entity) {
            $city = (string) $city_entity->label();
          }
        }
      }
    }
    $city_zip = trim($city . (($city !== '' && $zip !== '') ? ', ' : ' ') . $zip);
    if ($city_zip !== '') {
      $lines[] = $city_zip;
    }
  }

  $address = [];
  foreach ($lines as $delta => $line) {
    $address['line_' . $delta] = [
      '#type' => 'html_tag',
      '#tag' => 'div',
      '#attributes' => ['class' => ['backflow-device-location__line']],
      '#value' => $line,
    ];
  }

  $build['backflow_public_address'] = [
    '#type' => 'container',
    '#attributes' => ['class' => ['backflow-device-location']],
    '#weight' => 8,
    'heading' => [
      '#type' => 'html_tag',
      '#tag' => 'h3',
      '#value' => t('Device Location'),
    ],
    'address' => $address,
    'maintained_by' => [
      '#type' => 'html_tag',
      '#tag' => 'p',
      '#attributes' => ['class' => ['backflow-device-location__maintained-by']],
      '#value' => t('Maintained by Brookstone Outdoors'),
    ],
  ];

  // Pull-through: invalidate when the referenced property changes so a later
  // address correction shows the current value.
  if ($property instanceof ContentEntityInterface) {
    $build['backflow_public_address']['#cache']['tags'] = $property->getCacheTags();
  }
}
