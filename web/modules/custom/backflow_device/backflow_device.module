<?php

/**
 * @file
 * Backflow Device lifecycle hooks.
 *
 * Gate 2 (module logic only — no new fields):
 *  - On insert, assign a stable Device ID title (BF-NNNNNN) and generate a
 *    permanent QR code encoding the device's ABSOLUTE CANONICAL URL.
 *  - On the public "full" view mode, render a pull-through street address
 *    (current value, reaching into the referenced property by code) without
 *    granting any access on the properties entity.
 *
 * The QR is permanent: it is generated once on insert (when field_qr_code is
 * empty) and never regenerated by a later ->save(). The QR encodes the
 * canonical route (immutable) — Redirect 301s it to the property-path alias.
 */

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\ContentEntityInterface;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Url;
use Drupal\Core\File\FileExists;
use Drupal\Core\File\FileSystemInterface;
use Endroid\QrCode\Builder\Builder;
use Endroid\QrCode\Encoding\Encoding;
use Endroid\QrCode\ErrorCorrectionLevel;
use Endroid\QrCode\Writer\PngWriter;

/**
 * Implements hook_entity_insert().
 *
 * Only fires on insert (id now known). A normal later ->save() is an update
 * and never re-enters this hook, so the title and QR are written exactly once.
 */
function backflow_device_entity_insert(EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'property_backflow_device') {
    return;
  }
  _backflow_device_finalize($entity);
}

/**
 * Assigns the Device ID title and the permanent QR code, then saves once.
 *
 * Guarded so it is a no-op once the title is set and field_qr_code is
 * populated — a defensive belt-and-suspenders in addition to only hooking
 * insert.
 */
/**
 * The stable, clean device code: BF- + zero-padded entity id (BF-NNNNNN).
 *
 * This is the canonical device identifier used on the QR filename, the test
 * report, and the service tag. It never changes and never includes the model.
 * The human-facing TITLE may append the material model (see below), but the
 * code stays clean for documents and filenames.
 */
function _backflow_device_code(ContentEntityInterface $device): string {
  return 'BF-' . str_pad((string) $device->id(), 6, '0', STR_PAD_LEFT);
}

function _backflow_device_finalize(ContentEntityInterface $device) {
  $device_code = _backflow_device_code($device);

  // Title = device code, with the material model appended when one is set at
  // insert (e.g. "BF-000005 - 765 PVB"). Set once on insert; the code portion
  // is always the stable id, so the title stays meaningful even if the model
  // reference is later edited — the title does NOT auto-update (by design).
  $model = '';
  if ($device->hasField('field_material_backflow') && !$device->get('field_material_backflow')->isEmpty()) {
    $material = $device->get('field_material_backflow')->entity;
    if ($material) {
      $model = $material->hasField('field_name') && !$material->get('field_name')->isEmpty()
        ? trim((string) $material->get('field_name')->value)
        : trim((string) $material->label());
    }
  }
  $expected_title = $model !== '' ? $device_code . ' - ' . $model : $device_code;
  $needs_title = $device->label() !== $expected_title;
  $needs_qr = $device->get('field_qr_code')->isEmpty();
  if (!$needs_title && !$needs_qr) {
    return;
  }

  // Re-entrancy guard (the follow-up save below triggers update hooks).
  static $running = [];
  $id = $device->id();
  if (!empty($running[$id])) {
    return;
  }
  $running[$id] = TRUE;

  try {
    if ($needs_title) {
      $device->set('title', $expected_title);
    }

    if ($needs_qr) {
      try {
        $file = _backflow_device_generate_qr($device, $device_code);
        if ($file) {
          $device->set('field_qr_code', [
            'target_id' => $file->id(),
            'alt' => 'QR code for ' . $device_code,
          ]);
        }
      }
      catch (\Throwable $e) {
        // Never block device creation on QR failure; log and continue.
        \Drupal::logger('backflow_device')->error('QR generation failed for device @id: @msg', [
          '@id' => $id,
          '@msg' => $e->getMessage(),
        ]);
      }
    }

    // Single follow-up save (the cabb8a6e safe double-save: title set directly,
    // no AEL sentinel token).
    $device->save();

    // Title is now set, so (re)generate the pathauto alias from it.
    if (\Drupal::moduleHandler()->moduleExists('pathauto')) {
      \Drupal::service('pathauto.generator')->updateEntityAlias($device, 'update', ['force' => TRUE]);
    }
  }
  finally {
    unset($running[$id]);
  }
}

/**
 * Builds a PNG QR of the device's absolute canonical URL and saves it.
 *
 * @return \Drupal\file\FileInterface|null
 *   The managed file, or NULL on failure.
 */
function _backflow_device_generate_qr(ContentEntityInterface $device, string $title) {
  // Canonical route (immutable) — NOT the pathauto alias. The 'alias' => TRUE
  // option suppresses alias substitution so we encode the raw
  // /property_backflow_device/{id} path (Redirect 301s it to the property-path
  // alias). setAbsolute() yields a full https URL scannable off-site;
  // toString(TRUE) avoids leaked-metadata exceptions in this non-render context.
  $url = $device->toUrl('canonical', ['alias' => TRUE])
    ->setAbsolute()
    ->toString(TRUE)
    ->getGeneratedUrl();

  $result = (new Builder(
    writer: new PngWriter(),
    data: $url,
    encoding: new Encoding('UTF-8'),
    errorCorrectionLevel: ErrorCorrectionLevel::High,
    size: 300,
    margin: 10,
  ))->build();
  $png = $result->getString();

  $directory = 'public://property_backflow_device/device/qr';
  \Drupal::service('file_system')->prepareDirectory(
    $directory,
    FileSystemInterface::CREATE_DIRECTORY | FileSystemInterface::MODIFY_PERMISSIONS
  );
  $uri = $directory . '/qr-' . $title . '.png';

  return \Drupal::service('file.repository')->writeData($png, $uri, FileExists::Replace);
}

/**
 * Implements hook_entity_view().
 *
 * On the public "full" view mode, replace the field_property entity-reference
 * label (which is access-filtered for anonymous) with a pull-through street
 * address read directly from the referenced property by code. This exposes
 * ONLY street + city/zip + a maintained-by line — no owner, contact, gate
 * code, notes, or link — and does not change properties entity access.
 */
function backflow_device_entity_view(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display, $view_mode) {
  // Edit-test link on rendered backflow test children. The WO's "Backflow
  // Tests" EVA renders each wo_tasks_list:backflow_testing child as an entity
  // (default view mode), so add an "Edit Test" link to the render — this is how
  // a user gets back to the test (readings) form after the create flow's form
  // is closed. Destination returns to the parent WO after saving.
  if ($entity->getEntityTypeId() === 'wo_tasks_list'
      && $entity->bundle() === 'backflow_testing'
      && in_array($view_mode, ['default', 'full'], TRUE)
      && $entity->access('update')) {
    $options = [];
    if (!$entity->get('field_work_order')->isEmpty() && ($wo = $entity->get('field_work_order')->entity)) {
      $options['query']['destination'] = $wo->toUrl()->toString();
    }
    $build['backflow_edit_test'] = [
      '#type' => 'link',
      '#title' => 'Enter Test Results',
      '#url' => Url::fromRoute('entity.wo_tasks_list.edit_form', ['wo_tasks_list' => $entity->id()], $options),
      '#attributes' => [
        'style' => 'display:inline-block;background:#2E7D32;color:#fff;font-weight:bold;text-decoration:none;padding:8px 16px;border-radius:4px;font-family:Calibri,Arial,sans-serif;margin-top:8px;',
      ],
      '#weight' => 100,
      '#cache' => ['contexts' => ['user.permissions', 'user']],
    ];
    return;
  }

  if ($entity->getEntityTypeId() !== 'property_backflow_device' || $view_mode !== 'full') {
    return;
  }

  // Remove the property reference label render (kept on admin/default displays).
  unset($build['field_property']);

  $lines = [];
  $property = $entity->get('field_property')->entity;
  if ($property instanceof ContentEntityInterface) {
    $street = $property->hasField('field_street_address')
      ? trim((string) $property->get('field_street_address')->value) : '';
    if ($street !== '') {
      $lines[] = $street;
    }

    $city = '';
    $zip = '';
    if ($property->hasField('field_zipcode_reference') && !$property->get('field_zipcode_reference')->isEmpty()) {
      $zipcode = $property->get('field_zipcode_reference')->entity;
      if ($zipcode instanceof ContentEntityInterface) {
        if ($zipcode->hasField('field_zipcode')) {
          $zip = trim((string) $zipcode->get('field_zipcode')->value);
        }
        if ($zipcode->hasField('field_city') && !$zipcode->get('field_city')->isEmpty()) {
          $city_entity = $zipcode->get('field_city')->entity;
          if ($city_entity) {
            $city = (string) $city_entity->label();
          }
        }
      }
    }
    $city_zip = trim($city . (($city !== '' && $zip !== '') ? ', ' : ' ') . $zip);
    if ($city_zip !== '') {
      $lines[] = $city_zip;
    }
  }

  $address = [];
  foreach ($lines as $delta => $line) {
    $address['line_' . $delta] = [
      '#type' => 'html_tag',
      '#tag' => 'div',
      '#attributes' => ['class' => ['backflow-device-location__line']],
      '#value' => $line,
    ];
  }

  $build['backflow_public_address'] = [
    '#type' => 'container',
    '#attributes' => ['class' => ['backflow-device-location']],
    // Render above the configured device fields (Current Status is weight 0
    // on the full view display) so the location/address leads the page.
    '#weight' => -10,
    'heading' => [
      '#type' => 'html_tag',
      '#tag' => 'h3',
      '#value' => t('Device Location'),
    ],
    'address' => $address,
    'maintained_by' => [
      '#type' => 'html_tag',
      '#tag' => 'p',
      '#attributes' => ['class' => ['backflow-device-location__maintained-by']],
      '#value' => t('Maintained by Brookstone Outdoors'),
    ],
  ];

  // Pull-through: invalidate when the referenced property changes so a later
  // address correction shows the current value.
  if ($property instanceof ContentEntityInterface) {
    $build['backflow_public_address']['#cache']['tags'] = $property->getCacheTags();
  }

  // "+ Add Test Work Order" button below the test-history EVAs (weights 11/12).
  // Rendered as a render-array link, not a Views text area, so the CSRF-guarded
  // route gets a cache-safe token placeholder via RouteProcessorCsrf. The
  // device id is always available here, so the button works even when the
  // device has no tests yet. Shown only to users who can create both entities
  // (the route enforces the same), and only when the device has a property.
  $account = \Drupal::currentUser();
  if ($property instanceof ContentEntityInterface
      && $account->hasPermission('create work_order entities of bundle backflow_testing')
      && $account->hasPermission('create wo_tasks_list entities of bundle backflow_testing')) {
    $build['backflow_add_test_wo'] = [
      '#type' => 'link',
      '#title' => 'Enter Test Results',
      '#url' => Url::fromRoute('backflow_device.new_test_wo', ['property_backflow_device' => $entity->id()]),
      '#attributes' => [
        'style' => 'display:inline-block;background:#2E7D32;color:#fff;font-weight:bold;text-decoration:none;padding:8px 16px;border-radius:4px;font-family:Calibri,Arial,sans-serif;',
      ],
      '#weight' => 13,
      '#cache' => ['contexts' => ['user.permissions']],
    ];
  }
}

/**
 * Implements hook_views_pre_render().
 *
 * Attaches the status-card CSS to the Property Devices EVA (mirrors the way
 * bos_spray_route_ui attaches spray-route.css to its route views).
 */
function backflow_device_views_pre_render($view) {
  if ($view->id() === 'backflow_property_devices_eva') {
    $view->element['#attached']['library'][] = 'backflow_device/backflow_cards';
  }
}

/**
 * Implements hook_preprocess_HOOK() for views_view_fields.
 *
 * Computes the status-card data for each Property Devices EVA row from the
 * device entity, so the row template (views-view-fields--backflow-property-
 * devices-eva.html.twig) can render a card. Status + Next-Due logic live
 * here (PHP), keyed on the status MACHINE value.
 */
function backflow_device_preprocess_views_view_fields(array &$variables) {
  if (($variables['view']->id() ?? '') !== 'backflow_property_devices_eva') {
    return;
  }
  $device = $variables['row']->_entity ?? NULL;
  if (!$device instanceof ContentEntityInterface || $device->getEntityTypeId() !== 'property_backflow_device') {
    return;
  }

  $status = (string) ($device->get('field_current_status')->value ?? '');

  // Device type label.
  $device_type = '';
  if ($device->hasField('field_device_type') && !$device->get('field_device_type')->isEmpty()
      && ($term = $device->get('field_device_type')->entity)) {
    $device_type = (string) $term->label();
  }

  // Last test: stored UTC datetime -> site TZ, date only (BOS MM/DD/YYYY).
  $last_test = '';
  if ($device->hasField('field_last_test_date') && !$device->get('field_last_test_date')->isEmpty()) {
    try {
      $dt = new \DateTime((string) $device->get('field_last_test_date')->value, new \DateTimeZone('UTC'));
      $dt->setTimezone(new \DateTimeZone(date_default_timezone_get()));
      $last_test = $dt->format('m/d/Y');
    }
    catch (\Exception $e) {
      // Leave blank on a malformed stored value.
    }
  }

  $location = $device->hasField('field_physical_location')
    ? trim((string) $device->get('field_physical_location')->value) : '';

  $next_due = ($device->hasField('field_next_due_date') && !$device->get('field_next_due_date')->isEmpty())
    ? (string) $device->get('field_next_due_date')->value : '';

  $variables['bf_card'] = [
    'status' => $status,
    'status_label' => _backflow_device_status_label($status),
    'code' => _backflow_device_code($device),
    'url' => $device->toUrl()->toString(TRUE)->getGeneratedUrl(),
    'device_type' => $device_type,
    'last_test' => $last_test,
    'location' => $location,
  ] + _backflow_device_next_due_meta($next_due, $status);
}

/**
 * Human label for a field_current_status machine value (stable map).
 */
function _backflow_device_status_label(string $value): string {
  $map = [
    'active' => 'Active',
    'failed' => 'Failed',
    'repaired' => 'Repaired',
    'out_of_service' => 'Out of Service',
    'replaced' => 'Replaced',
  ];
  return $map[$value] ?? ucwords(str_replace('_', ' ', $value));
}

/**
 * Next-Due treatment for the card. Coloring applies ONLY when status is
 * active — a failed device reads via its red FAILED badge, never as an
 * "overdue date" (no double-signal). Returns nextdue_class/label/date.
 *
 * Date math: PHP DateTime in the site timezone, date-only comparison
 * (consistent with the date-only next-due field + the write-back).
 */
function _backflow_device_next_due_meta(string $next_due, string $status): array {
  // Non-active statuses: the badge is the signal. Show a muted date if any.
  if ($status !== 'active') {
    if ($next_due === '') {
      return ['nextdue_class' => 'muted', 'nextdue_label' => '', 'nextdue_date' => ''];
    }
    return ['nextdue_class' => 'muted', 'nextdue_label' => 'Next due', 'nextdue_date' => _backflow_device_fmt_due($next_due)];
  }

  // Active + no date on record -> amber "No test on record" (the BF-000002 case).
  if ($next_due === '') {
    return ['nextdue_class' => 'soon', 'nextdue_label' => 'No test on record', 'nextdue_date' => ''];
  }

  $tz = new \DateTimeZone(date_default_timezone_get());
  $today = new \DateTime('now', $tz);
  $today->setTime(0, 0, 0);
  $due = \DateTime::createFromFormat('Y-m-d', $next_due, $tz);
  if (!$due) {
    return ['nextdue_class' => 'soon', 'nextdue_label' => 'No test on record', 'nextdue_date' => ''];
  }
  $due->setTime(0, 0, 0);
  $days = (int) $today->diff($due)->format('%r%a');
  $date_str = $due->format('m/d/Y');

  if ($days < 0) {
    return ['nextdue_class' => 'overdue', 'nextdue_label' => 'Overdue', 'nextdue_date' => $date_str];
  }
  if ($days <= 60) {
    return ['nextdue_class' => 'soon', 'nextdue_label' => 'Due soon', 'nextdue_date' => $date_str];
  }
  return ['nextdue_class' => 'ok', 'nextdue_label' => 'Next due', 'nextdue_date' => $date_str];
}

/**
 * Format a date-only (Y-m-d) next-due value as MM/DD/YYYY.
 */
function _backflow_device_fmt_due(string $next_due): string {
  $tz = new \DateTimeZone(date_default_timezone_get());
  $d = \DateTime::createFromFormat('Y-m-d', $next_due, $tz);
  return $d ? $d->format('m/d/Y') : '';
}

/**
 * Implements hook_theme().
 *
 * Registers the Property Devices EVA row suggestion so this module's
 * templates/views-view-fields--backflow-property-devices-eva.html.twig is
 * discovered. A module template that overrides another module's theme hook
 * (views_view_fields) is not auto-scanned unless the suggestion hook is
 * registered with a base hook.
 */
function backflow_device_theme($existing, $type, $theme, $path) {
  return [
    'views_view_fields__backflow_property_devices_eva' => [
      'base hook' => 'views_view_fields',
    ],
  ];
}
