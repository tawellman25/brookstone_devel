      ],
    ],
    'daily_recap_detail' => [
      'variables' => [
        'dept_label' => '',
        'window_label' => '',
        'rows' => [],
        'total_value' => '',
        'total_count' => 0,
        'back_url' => '',
      ],
    ],
  ];
}
