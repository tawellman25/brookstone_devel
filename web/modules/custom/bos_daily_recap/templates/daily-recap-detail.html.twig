{#
/**
 * @file
 * Daily Recap drill-down: work orders behind one department's total.
 *
 * - dept_label, window_label
 * - rows: [{ wo, wo_url, service, property, dept, value, completed_at }]
 * - total_value, total_count, back_url
 */
#}
<div class="daily-recap daily-recap--detail">

  <p class="daily-recap__generated">
    <a href="{{ back_url }}">&larr; Back to Daily Recap</a>
  </p>

  <h2 class="daily-recap__section">{{ dept_label }} &middot; {{ window_label }}</h2>

  <table class="recap-table recap-table--list">
    <thead>
      <tr>
        <th>WO</th><th>Service</th><th>Property</th><th class="num">Value</th><th>Completed</th>
      </tr>
    </thead>
    <tbody>
      {% for c in rows %}
        <tr>
          <td><a href="{{ c.wo_url }}">{{ c.wo }}</a></td>
          <td>{{ c.service }}</td>
          <td>{{ c.property }}</td>
          <td class="num">{{ c.value }}</td>
          <td>{{ c.completed_at }}</td>
        </tr>
      {% else %}
        <tr><td colspan="5" class="recap-empty">No completions for this department in this range.</td></tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr>
        <th colspan="3">Total ({{ total_count }} work orders)</th>
        <th class="num">{{ total_value }}</th>
        <th></th>
      </tr>
    </tfoot>
  </table>

</div>
