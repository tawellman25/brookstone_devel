{#
/**
 * @file
 * Daily Recap dashboard.
 *
 * - generated_at
 * - windows: [{ key, label, rows: [{dept, value, count, url, active}], total_value, total_count }]
 * - list_label, list_rows: [{wo, wo_url, service, property, dept, value, completed_at}],
 *   list_total, list_count, selection_active, clear_url
 * - mowing_note
 *
 * Clicking a department's value up top reloads with ?range=&dept= and re-targets
 * the list below to those work orders.
 */
#}
<div class="daily-recap">

  <p class="daily-recap__generated">Generated {{ generated_at }}</p>

  <div class="daily-recap__windows">
    {% for w in windows %}
      <section class="recap-card">
        <h2 class="recap-card__title">{{ w.label }}</h2>
        <table class="recap-table">
          <thead>
            <tr><th>Department</th><th class="num">Value</th><th class="num">Jobs</th></tr>
          </thead>
          <tbody>
            {% for r in w.rows %}
              <tr{% if r.active %} class="is-active"{% endif %}>
                <td>{{ r.dept }}</td>
                <td class="num"><a href="{{ r.url }}" title="Show these work orders below">{{ r.value }}</a></td>
                <td class="num">{{ r.count }}</td>
              </tr>
            {% else %}
              <tr><td colspan="3" class="recap-empty">No completions.</td></tr>
            {% endfor %}
          </tbody>
          <tfoot>
            <tr><th>Total</th><th class="num">{{ w.total_value }}</th><th class="num">{{ w.total_count }}</th></tr>
          </tfoot>
        </table>
      </section>
    {% endfor %}
  </div>

  <div class="daily-recap__listhead">
    <h2 class="daily-recap__section">
      {{ list_label }}{% if list_count %} — {{ list_count }} work orders, {{ list_total }}{% endif %}
    </h2>
    {% if selection_active %}
      <a class="daily-recap__clear" href="{{ clear_url }}">&times; clear &middot; show yesterday (all)</a>
    {% endif %}
  </div>

  <table class="recap-table recap-table--list">
    <thead>
      <tr>
        <th>WO</th><th>Service</th><th>Property</th><th>Department</th><th class="num">Value</th><th>Completed</th>
      </tr>
    </thead>
    <tbody>
      {% for c in list_rows %}
        <tr>
          <td><a href="{{ c.wo_url }}">{{ c.wo }}</a></td>
          <td>{{ c.service }}</td>
          <td>{{ c.property }}</td>
          <td>{{ c.dept }}</td>
          <td class="num">{{ c.value }}</td>
          <td>{{ c.completed_at }}</td>
        </tr>
      {% else %}
        <tr><td colspan="6" class="recap-empty">No completions.</td></tr>
      {% endfor %}
    </tbody>
  </table>

  <p class="daily-recap__note">{{ mowing_note }}</p>

</div>
