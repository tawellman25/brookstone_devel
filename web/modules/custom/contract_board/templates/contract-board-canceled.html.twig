{# Canceled contracts tab #}

<div class="contract-board-section">
  <div class="contract-board-date-filter">
    <label for="contract-board-days">Show last:</label>
    <select id="contract-board-days" onchange="window.location.search='?days='+this.value">
      <option value="30"{% if days == 30 %} selected{% endif %}>30 days</option>
      <option value="90"{% if days == 90 %} selected{% endif %}>90 days</option>
      <option value="180"{% if days == 180 %} selected{% endif %}>180 days</option>
      <option value="365"{% if days == 365 %} selected{% endif %}>1 year</option>
    </select>
  </div>

  {% if rows|length > 0 %}
    <table class="contract-board-table">
      <thead>
        <tr>
          <th>Client</th>
          <th>Property</th>
          <th>Services</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        {% for row in rows %}
          <tr>
            <td><a href="{{ row.url }}" target="_blank">{{ row.client }}</a></td>
            <td>{{ row.property }}</td>
            <td>{{ row.services }}</td>
            <td>{{ row.date }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p class="contract-board-empty">No canceled contracts in this period.</p>
  {% endif %}
</div>
