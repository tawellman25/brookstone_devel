<?php

/**
 * @file
 * Estimate Task module for Deer Prevention.
 *
 * Calculates estimate total from increment-based labor pricing.
 * Syncs field_num_trees and field_num_shrubs to property_landscape_details on save.
 */

use Drupal\config_pages\Entity\ConfigPages;

/**
 * Implements hook_entity_presave().
 */
function est_deer_prevention_entity_presave($entity) {
  if ($entity->getEntityTypeId() !== 'estimate_tasks' || $entity->bundle() !== 'deer_prevention') {
    return;
  }

  $estimatedTime = (float) $entity->get('field_estimated_time')->value;
  if (empty($estimatedTime) || $estimatedTime <= 0) {
    return;
  }

  $businessSettings = ConfigPages::config('business_setting');
  if (!$businessSettings) {
    \Drupal::logger('est_deer_prevention')->error('Business settings config page not found.');
    return;
  }

  // Increment-based labor with minimum time guarantee.
  $billingIncrement = (float) $businessSettings->get('field_hour_billing_increment')->value;
  $laborRate = (float) $businessSettings->get('field_maintenance_crew_labor')->value;
  $hourlyMinimum = (float) $businessSettings->get('field_cleanup_labor_minimum')->value;
  $totalMinutes = $estimatedTime * 60;
  $totalIncrements = ceil($totalMinutes / $billingIncrement);
  $hourlyIncrement = $billingIncrement / 60;
  $laborSubtotal = $totalIncrements * $hourlyIncrement * $laborRate;
  if ($estimatedTime < $hourlyMinimum) {
    $laborSubtotal = $laborRate * $hourlyMinimum;
  }

  // TODO: Add trip fee when field_trip_fee is added to estimate_tasks.
  $billingAdj = (float) ($entity->get('field_billing_adjustment')->value ?? 0);
  $total = $laborSubtotal + $billingAdj;
  $entity->set('field_estimate_total', $total);

  \Drupal::logger('est_deer_prevention')->info(
    'EST Deer Prevention presave: time=@time, increments=@inc, labor=@labor, adj=@adj, total=@total',
    [
      '@time' => $estimatedTime,
      '@inc' => $totalIncrements,
      '@labor' => $laborSubtotal,
      '@adj' => $billingAdj,
      '@total' => $total,
    ]
  );
}

/**
 * Implements hook_entity_insert().
 */
function est_deer_prevention_entity_insert($entity) {
  if ($entity->getEntityTypeId() !== 'estimate_tasks' || $entity->bundle() !== 'deer_prevention') {
    return;
  }
  _est_deer_prevention_sync_property($entity);
}

/**
 * Implements hook_entity_update().
 */
function est_deer_prevention_entity_update($entity) {
  if ($entity->getEntityTypeId() !== 'estimate_tasks' || $entity->bundle() !== 'deer_prevention') {
    return;
  }
  _est_deer_prevention_sync_property($entity);
}

/**
 * Syncs tree and shrub counts to property_landscape_details:current.
 */
function _est_deer_prevention_sync_property($entity) {
  $numTrees = (int) $entity->get('field_num_trees')->value;
  $numShrubs = (int) $entity->get('field_num_shrubs')->value;
  if ((empty($numTrees) || $numTrees <= 0) && (empty($numShrubs) || $numShrubs <= 0)) {
    return;
  }

  // Traverse: estimate_tasks → estimate → estimate_request → property.
  $estimateRef = $entity->get('field_estimate')->referencedEntities();
  if (empty($estimateRef)) {
    return;
  }
  $estimate = reset($estimateRef);

  $requestRef = $estimate->get('field_estimate_request')->referencedEntities();
  if (empty($requestRef)) {
    return;
  }
  $request = reset($requestRef);

  $propertyRef = $request->get('field_property')->referencedEntities();
  if (empty($propertyRef)) {
    return;
  }
  $property = reset($propertyRef);
  $propertyId = $property->id();

  $landscapeEntities = \Drupal::entityTypeManager()
    ->getStorage('property_landscape_details')
    ->loadByProperties([
      'field_property' => $propertyId,
      'type' => 'current',
    ]);

  if (empty($landscapeEntities)) {
    \Drupal::logger('est_deer_prevention')->warning(
      'No property_landscape_details:current found for property @id.',
      ['@id' => $propertyId]
    );
    return;
  }

  $landscapeEntity = reset($landscapeEntities);
  if ($numTrees > 0) {
    $landscapeEntity->set('field_number_of_trees', $numTrees);
  }
  if ($numShrubs > 0) {
    $landscapeEntity->set('field_number_of_shrubs', $numShrubs);
  }
  $landscapeEntity->save();

  \Drupal::logger('est_deer_prevention')->info(
    'EST Deer Prevention: synced trees=@trees, shrubs=@shrubs to property @id.',
    ['@trees' => $numTrees, '@shrubs' => $numShrubs, '@id' => $propertyId]
  );
}
