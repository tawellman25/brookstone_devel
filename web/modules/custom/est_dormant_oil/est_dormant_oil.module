<?php

/**
 * @file
 * Estimate Task module for Dormant Oil.
 *
 * Calculates estimate total from chemical cost + sprayer fee + labor.
 */

use Drupal\config_pages\Entity\ConfigPages;

/**
 * Implements hook_entity_presave().
 */
function est_dormant_oil_entity_presave($entity) {
  if ($entity->getEntityTypeId() !== 'estimate_tasks' || $entity->bundle() !== 'dormant_oil') {
    return;
  }

  $gallons = (float) $entity->get('field_gallons')->value;
  $estimatedTime = (float) $entity->get('field_estimated_time')->value;
  if (empty($gallons) || $gallons <= 0 || empty($estimatedTime) || $estimatedTime <= 0) {
    return;
  }

  $businessSettings = ConfigPages::config('business_setting');
  if (!$businessSettings) {
    \Drupal::logger('est_dormant_oil')->error('Business settings config page not found.');
    return;
  }

  // Chemical cost.
  $dormantOilRate = (float) $businessSettings->get('field_dormant_oil_rate')->value;
  $chemical = $gallons * $dormantOilRate;

  // Sprayer fee (4-hour blocks).
  $sprayerRate = (float) $businessSettings->get('field_tree_sprayer_rate')->value;
  $sprayer = ceil($estimatedTime / 4) * $sprayerRate;

  // Labor with minimum time guarantee.
  $sprayLabor = (float) $businessSettings->get('field_spray_crew_labor')->value;
  $sprayMinTime = (float) $businessSettings->get('field_spray_minimum_time')->value;
  $laborTime = max($estimatedTime, $sprayMinTime);
  $labor = $laborTime * $sprayLabor;

  // TODO: Add trip fee when field_trip_fee is added to estimate_tasks.
  $billingAdj = (float) ($entity->get('field_billing_adjustment')->value ?? 0);
  $total = $chemical + $sprayer + $labor + $billingAdj;
  $entity->set('field_estimate_total', $total);

  \Drupal::logger('est_dormant_oil')->info(
    'EST Dormant Oil presave: gallons=@gal, chemical=@chem, sprayer=@spray, labor=@labor, adj=@adj, total=@total',
    [
      '@gal' => $gallons,
      '@chem' => $chemical,
      '@spray' => $sprayer,
      '@labor' => $labor,
      '@adj' => $billingAdj,
      '@total' => $total,
    ]
  );
}
