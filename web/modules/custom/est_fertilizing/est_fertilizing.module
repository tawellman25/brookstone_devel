<?php

/**
 * @file
 * Estimate Task module for Fertilizing.
 *
 * Calculates estimate total from tiered sq ft pricing.
 * Syncs field_turf_sq_footage to property_landscape_details on save.
 */

use Drupal\config_pages\Entity\ConfigPages;

/**
 * Implements hook_entity_presave().
 */
function est_fertilizing_entity_presave($entity) {
  if ($entity->getEntityTypeId() !== 'estimate_tasks' || $entity->bundle() !== 'fertilizing') {
    return;
  }

  $sqFt = (float) $entity->get('field_sq_ft')->value;
  if (empty($sqFt) || $sqFt <= 0) {
    return;
  }

  $businessSettings = ConfigPages::config('business_setting');
  if (!$businessSettings) {
    \Drupal::logger('est_fertilizing')->error('Business settings config page not found.');
    return;
  }

  // Tiered fertilizing pricing.
  $minimum = (float) $businessSettings->get('field_fertilizing_minimum')->value;
  $rate6k20k = (float) $businessSettings->get('field_fetilizing_6k_20k_per_ft')->value;
  $rate20k80k = (float) $businessSettings->get('field_fetilize_20k_80k_per_ft')->value;
  $rate80kPlus = (float) $businessSettings->get('field_fetilizing_80k_plus_per_ft')->value;

  if ($sqFt <= 6000) {
    $fertilizingRate = $minimum;
  }
  elseif ($sqFt <= 20000) {
    $fertilizingRate = $minimum + (($sqFt - 6000) * $rate6k20k);
  }
  elseif ($sqFt <= 80000) {
    $fertilizingRate = $minimum + (14000 * $rate6k20k) + (($sqFt - 20000) * $rate20k80k);
  }
  else {
    $fertilizingRate = $minimum + (14000 * $rate6k20k) + (60000 * $rate20k80k) + (($sqFt - 80000) * $rate80kPlus);
  }

  $billingAdj = (float) ($entity->get('field_billing_adjustment')->value ?? 0);
  $total = $fertilizingRate + $billingAdj;
  $entity->set('field_estimate_total', $total);

  \Drupal::logger('est_fertilizing')->info(
    'EST Fertilizing presave: sqFt=@sqft, rate=@rate, adj=@adj, total=@total',
    ['@sqft' => $sqFt, '@rate' => $fertilizingRate, '@adj' => $billingAdj, '@total' => $total]
  );
}

/**
 * Implements hook_entity_insert().
 */
function est_fertilizing_entity_insert($entity) {
  if ($entity->getEntityTypeId() !== 'estimate_tasks' || $entity->bundle() !== 'fertilizing') {
    return;
  }
  _est_fertilizing_sync_property($entity);
}

/**
 * Implements hook_entity_update().
 */
function est_fertilizing_entity_update($entity) {
  if ($entity->getEntityTypeId() !== 'estimate_tasks' || $entity->bundle() !== 'fertilizing') {
    return;
  }
  _est_fertilizing_sync_property($entity);
}

/**
 * Syncs sq ft to property_landscape_details:current.
 */
function _est_fertilizing_sync_property($entity) {
  $sqFt = (float) $entity->get('field_sq_ft')->value;
  if (empty($sqFt) || $sqFt <= 0) {
    return;
  }

  // Traverse: estimate_tasks → estimate → estimate_request → property.
  $estimateRef = $entity->get('field_estimate')->referencedEntities();
  if (empty($estimateRef)) {
    return;
  }
  $estimate = reset($estimateRef);

  $requestRef = $estimate->get('field_estimate_request')->referencedEntities();
  if (empty($requestRef)) {
    return;
  }
  $request = reset($requestRef);

  $propertyRef = $request->get('field_property')->referencedEntities();
  if (empty($propertyRef)) {
    return;
  }
  $property = reset($propertyRef);
  $propertyId = $property->id();

  $landscapeEntities = \Drupal::entityTypeManager()
    ->getStorage('property_landscape_details')
    ->loadByProperties([
      'field_property' => $propertyId,
      'type' => 'current',
    ]);

  if (empty($landscapeEntities)) {
    \Drupal::logger('est_fertilizing')->warning(
      'No property_landscape_details:current found for property @id.',
      ['@id' => $propertyId]
    );
    return;
  }

  $landscapeEntity = reset($landscapeEntities);
  $landscapeEntity->set('field_turf_sq_footage', $sqFt);
  $landscapeEntity->save();

  \Drupal::logger('est_fertilizing')->info(
    'EST Fertilizing: synced field_turf_sq_footage=@sqft to property @id.',
    ['@sqft' => $sqFt, '@id' => $propertyId]
  );
}
