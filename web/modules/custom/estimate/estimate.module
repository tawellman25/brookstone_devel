<?php

declare(strict_types=1);

use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\EntityTypeInterface;
use Drupal\Core\Url;
use Symfony\Component\Validator\ConstraintViolation;
use Symfony\Component\Validator\ConstraintViolationListInterface;

/**
 * @file
 * Estimate module glue code.
 *
 * This file contains ONLY hook implementations and small, module-local helpers.
 * Heavy business logic lives in services.
 *
 * Responsibilities:
 * - Attach scope code uniqueness constraint (service_scope_elements.field_scope_code)
 * - Estimate Request intake soft warnings + readiness validation gate (optional)
 * - Estimate Items pricing math (presave)
 * - Estimate total rollup triggers
 * - Revision enforcement trigger
 * - Convert to Work Order entity operation
 */

/* ---------------------------------------------------------------------------
 * Taxonomy Scope Code Uniqueness
 * --------------------------------------------------------------------------- */

/**
 * Implements hook_entity_bundle_field_info_alter().
 *
 * Enforces normalized uniqueness on:
 * taxonomy_term bundle = service_scope_elements
 * field_scope_code
 */
function estimate_entity_bundle_field_info_alter(array &$fields, EntityTypeInterface $entity_type, string $bundle): void {
  if ($entity_type->id() !== 'taxonomy_term') {
    return;
  }
  if ($bundle !== 'service_scope_elements') {
    return;
  }
  if (!isset($fields['field_scope_code'])) {
    return;
  }

  $fields['field_scope_code']->addConstraint('ScopeCodeUnique', [
    'vocabulary' => 'service_scope_elements',
    'field' => 'field_scope_code',
  ]);
}

/* ---------------------------------------------------------------------------
 * Entity Presave (single hook)
 * --------------------------------------------------------------------------- */

/**
 * Implements hook_entity_presave().
 *
 * Note:
 * - This hook must remain SINGLE (do not define another).
 * - Contains three flows:
 *   1) estimate_request: soft warnings only (never blocks)
 *   2) estimate_items: line math
 *   3) estimate: revision enforcement (+ optional defaults)
 */
function estimate_entity_presave(EntityInterface $entity): void {

  /* ---------------------------------------
   * Estimate Request: soft intake warnings
   * --------------------------------------- */
  if ($entity->getEntityTypeId() === 'estimate_request') {
    _estimate_request_add_intake_warnings($entity);
    return;
  }

  /* -----------------------------
   * Estimate Items pricing engine
   * ----------------------------- */
  if ($entity->getEntityTypeId() === 'estimate_items') {

    if (!$entity->hasField('field_quantity') ||
        !$entity->hasField('field_unit_price') ||
        !$entity->hasField('field_cost_subtotal') ||
        !$entity->hasField('field_line_total')) {
      return;
    }

    $qty = (int) ($entity->get('field_quantity')->value ?? 0);
    $unit = (float) ($entity->get('field_unit_price')->value ?? 0);

    // Defensive: disallow negative quantities/prices.
    if ($qty < 0) {
      $qty = 0;
    }
    if ($unit < 0) {
      $unit = 0.0;
    }

    $subtotal = (float) ($qty * $unit);

    // Optional markup field exists on some bundles (equipment/materials/subcontractor).
    $markup = 0.0;
    if ($entity->hasField('field_markup') && !$entity->get('field_markup')->isEmpty()) {
      $markup = (float) $entity->get('field_markup')->value;

      // Normalize: allow either "10" or "0.10".
      if ($markup > 1) {
        $markup = $markup / 100;
      }
      // Defensive clamp.
      if ($markup < 0) {
        $markup = 0.0;
      }
    }

    $line_total = (float) ($subtotal * (1 + $markup));

    $entity->set('field_cost_subtotal', $subtotal);
    $entity->set('field_line_total', $line_total);

    return;
  }

  /* -----------------------------
   * Estimate revision enforcement
   * ----------------------------- */
  if ($entity->getEntityTypeId() === 'estimate') {

    // Optional default assignment (only if the field exists).
    if ($entity->hasField('field_assigned_to') && $entity->get('field_assigned_to')->isEmpty()) {
      $entity->set('field_assigned_to', \Drupal::currentUser()->id());
    }

    // Auto-set field_estimate_type from the bundle's matching services term.
    // Skip landscaping containers — pipeline sets field_estimate_type = 364.
    if ($entity->hasField('field_estimate_type')) {
      $is_container = $entity->bundle() === 'landscaping'
        && $entity->hasField('field_is_container')
        && !empty($entity->get('field_is_container')->value);

      if (!$is_container) {
        $tids = \Drupal::entityTypeManager()
          ->getStorage('taxonomy_term')
          ->getQuery()
          ->accessCheck(FALSE)
          ->condition('vid', 'services')
          ->condition('field_service_bundle', $entity->bundle())
          ->range(0, 1)
          ->execute();

        if (!empty($tids)) {
          $entity->set('field_estimate_type', reset($tids));
        }
      }
    }

    /** @var \Drupal\estimate\Service\EstimateRevisionManager $rm */
    $rm = \Drupal::service('estimate.revision_manager');
    $rm->enforce($entity);

    return;
  }
}

/* ---------------------------------------------------------------------------
 * Estimate Request - Readiness Validation Gate (optional)
 * --------------------------------------------------------------------------- */

/**
 * Implements hook_entity_validate().
 *
 * Hard validation ONLY when transitioning Estimate Request to a configured
 * "Ready to Estimate" status.
 *
 * IMPORTANT:
 * - This is OPTIONAL and will do nothing unless estimate.settings contains:
 *   estimate_request_ready_status_tid
 * - Never blocks intake unless you explicitly configure that TID.
 */
function estimate_entity_validate(EntityInterface $entity, ConstraintViolationListInterface $violations): void {
  if ($entity->getEntityTypeId() !== 'estimate_request') {
    return;
  }

  $ready_tid = (int) \Drupal::config('estimate.settings')->get('estimate_request_ready_status_tid');
  if ($ready_tid <= 0) {
    // Not configured => no blocking validation.
    return;
  }

  $status_field = _estimate_request_get_status_field_name($entity);
  $new_status_tid = _estimate_request_get_status_tid($entity);
  if ($new_status_tid <= 0) {
    return;
  }

  // Only enforce when transitioning to Ready.
  if ($new_status_tid !== $ready_tid) {
    return;
  }

  // If already Ready and staying Ready, do nothing.
  $old_status_tid = 0;
  if (isset($entity->original) && $entity->original instanceof EntityInterface) {
    $old_status_tid = _estimate_request_get_status_tid($entity->original);
  }
  if ($old_status_tid === $ready_tid) {
    return;
  }

  $missing = _estimate_request_missing_ready_requirements($entity);

  if (!empty($missing)) {
    $msg = 'Cannot mark Ready to Estimate until the following are set: ' . implode(', ', $missing) . '.';

    // Attach violation to the status field.
    $violations->add(new ConstraintViolation(
      $msg,
      $msg,
      [],
      $entity,
      $status_field,
      (string) $new_status_tid
    ));
  }
}

/* ---------------------------------------------------------------------------
 * Estimate Request - Helpers
 * --------------------------------------------------------------------------- */

/**
 * Soft warnings shown to UI users on save.
 *
 * Never blocks saving. Never auto-changes status.
 */
function _estimate_request_add_intake_warnings(EntityInterface $req): void {
  // Avoid spamming during CLI runs (drush, cron, imports).
  if (PHP_SAPI === 'cli') {
    return;
  }

  $request = \Drupal::requestStack()->getCurrentRequest();
  if (!$request) {
    return;
  }

  // Only show warnings on estimate_request entity routes (form, canonical),
  // not on board pages, AJAX endpoints, or other contexts.
  $route = \Drupal::routeMatch()->getRouteName() ?? '';
  if (!str_starts_with($route, 'entity.estimate_request.')) {
    return;
  }

  // Warn if no contact info at all.
  $has_contact_entity = $req->hasField('field_contact') && !$req->get('field_contact')->isEmpty();
  $has_name = $req->hasField('field_requestor_name') && trim((string) ($req->get('field_requestor_name')->value ?? '')) !== '';
  $has_phone = $req->hasField('field_requestor_phone') && trim((string) ($req->get('field_requestor_phone')->value ?? '')) !== '';
  $has_email = $req->hasField('field_requestor_email') && trim((string) ($req->get('field_requestor_email')->value ?? '')) !== '';

  if (!$has_contact_entity && !$has_name && !$has_phone && !$has_email) {
    \Drupal::messenger()->addWarning('No contact information has been provided (no Contact linked and no Requestor Name/Phone/Email entered).');
  }

  // Helpful warnings (non-blocking).
  if ($req->hasField('field_property') && $req->get('field_property')->isEmpty()) {
    \Drupal::messenger()->addWarning('Property is not linked yet. This can be completed after intake, but should be confirmed before estimating and before converting an accepted Estimate into a Work Order.');
  }

  if ($req->hasField('field_owner') && $req->get('field_owner')->isEmpty()) {
    \Drupal::messenger()->addWarning('Owner is not confirmed yet. Owner is the point-in-time billing/authorization authority for this request.');
  }

  if ($req->hasField('field_service') && $req->get('field_service')->isEmpty()) {
    \Drupal::messenger()->addWarning('No Service Estimate(s) Requested have been selected yet. Select Service(s) before generating Estimates from this request.');
  }
}

/**
 * Returns the Estimate Request status field name (default: field_status).
 */
function _estimate_request_get_status_field_name(EntityInterface $req): string {
  if ($req->hasField('field_status')) {
    return 'field_status';
  }

  foreach (['field_estimate_request_status', 'field_request_status', 'status'] as $candidate) {
    if ($req->hasField($candidate)) {
      return $candidate;
    }
  }

  return 'field_status';
}

/**
 * Get the current status term id from an Estimate Request.
 */
function _estimate_request_get_status_tid(EntityInterface $req): int {
  $field = _estimate_request_get_status_field_name($req);
  if (!$req->hasField($field) || $req->get($field)->isEmpty()) {
    return 0;
  }
  return (int) ($req->get($field)->target_id ?? 0);
}

/**
 * Hard readiness requirements for "Ready to Estimate".
 *
 * Returns a list of human-readable missing labels.
 *
 * IMPORTANT:
 * This is a readiness gate for estimate generation, not intake.
 */
function _estimate_request_missing_ready_requirements(EntityInterface $req): array {
  $missing = [];

  // Property required at readiness.
  if ($req->hasField('field_property') && $req->get('field_property')->isEmpty()) {
    $missing[] = 'Property';
  }

  // Owner snapshot required at readiness (point-in-time).
  if ($req->hasField('field_owner') && $req->get('field_owner')->isEmpty()) {
    $missing[] = 'Owner';
  }

  // At least one service required to generate estimates deterministically.
  if ($req->hasField('field_service') && $req->get('field_service')->isEmpty()) {
    $missing[] = 'Service Estimate(s) Requested';
  }

  // Require either a linked Contact OR at least one requestor detail.
  $has_contact_entity = $req->hasField('field_contact') && !$req->get('field_contact')->isEmpty();
  $has_name = $req->hasField('field_requestor_name') && trim((string) ($req->get('field_requestor_name')->value ?? '')) !== '';
  $has_phone = $req->hasField('field_requestor_phone') && trim((string) ($req->get('field_requestor_phone')->value ?? '')) !== '';
  $has_email = $req->hasField('field_requestor_email') && trim((string) ($req->get('field_requestor_email')->value ?? '')) !== '';

  if (!$has_contact_entity && !$has_name && !$has_phone && !$has_email) {
    $missing[] = 'Contact or Requestor info (Name/Phone/Email)';
  }

  return $missing;
}

/* ---------------------------------------------------------------------------
 * Estimate Total Rollup Triggers
 * --------------------------------------------------------------------------- */

/**
 * Implements hook_entity_insert().
 */
function estimate_entity_insert(EntityInterface $entity): void {
  estimate__maybe_recalculate_total($entity);
  _estimate_log_note_added($entity);
  _estimate_maybe_update_request_status_on_wo_insert($entity);
}

/**
 * Implements hook_entity_update().
 */
function estimate_entity_update(EntityInterface $entity): void {
  estimate__maybe_recalculate_total($entity);
  _estimate_log_stage_change($entity);
  _estimate_log_request_status_change($entity);
  _estimate_auto_convert_on_acceptance($entity);
}

/**
 * Implements hook_entity_delete().
 */
function estimate_entity_delete(EntityInterface $entity): void {
  estimate__maybe_recalculate_total($entity);
  _estimate_log_note_deleted($entity);
}

/**
 * Recalculate parent estimate total when estimate_items change.
 */
function estimate__maybe_recalculate_total(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'estimate_items') {
    return;
  }

  if (!$entity->hasField('field_estimate') || $entity->get('field_estimate')->isEmpty()) {
    return;
  }

  $estimate_id = (int) $entity->get('field_estimate')->target_id;
  if ($estimate_id <= 0) {
    return;
  }

  /** @var \Drupal\estimate\Service\EstimateTotalCalculator $calculator */
  $calculator = \Drupal::service('estimate.total_calculator');
  $calculator->recalculate($estimate_id);
}

/* ---------------------------------------------------------------------------
 * Estimate Entity Operations (Convert to Work Order)
 * --------------------------------------------------------------------------- */

/**
 * Implements hook_entity_operation_alter().
 */
function estimate_entity_operation_alter(array &$operations, EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'estimate') {
    return;
  }

  $operations['convert_to_work_order'] = [
    'title' => t('Convert to Work Order'),
    'url' => Url::fromRoute('estimate.convert_to_work_order', [
      'estimate' => $entity->id(),
    ]),
    'weight' => 50,
  ];
}


/* ---------------------------------------------------------------------------
 * Estimate Display — Contact / Owner Card
 * --------------------------------------------------------------------------- */

/**
 * Implements hook_entity_extra_field_info().
 */
function estimate_entity_extra_field_info(): array {
  $extra = [];
  $bundles = array_keys(\Drupal::service('entity_type.bundle.info')->getBundleInfo('estimate'));

  foreach ($bundles as $bundle) {
    $extra['estimate'][$bundle]['display']['estimate_contact_card'] = [
      'label' => t('Contact / Owner'),
      'description' => t('Owner, contact, or requestor info from the parent estimate request.'),
      'weight' => -10,
      'visible' => TRUE,
    ];
    $extra['estimate'][$bundle]['display']['estimate_stage_form'] = [
      'label' => t('Stage Actions'),
      'description' => t('Dropdown to change estimate stage and convert to Work Order.'),
      'weight' => -9,
      'visible' => TRUE,
    ];
  }

  return $extra;
}

/**
 * Implements hook_entity_view().
 *
 * Renders the Contact/Owner card on estimate entities by traversing
 * the parent estimate_request. Priority: Owner → Contact → Requestor.
 */
function estimate_entity_view(
  array &$build,
  EntityInterface $entity,
  EntityViewDisplayInterface $display,
  string $view_mode
): void {
  if ($entity->getEntityTypeId() !== 'estimate') {
    return;
  }

  // --- Contact / Owner card ---
  if ($display->getComponent('estimate_contact_card')) {
    if (!$entity->hasField('field_estimate_request') || $entity->get('field_estimate_request')->isEmpty()) {
      $build['estimate_contact_card'] = ['#markup' => ''];
    }
    else {
      try {
        $request = $entity->get('field_estimate_request')->entity;
        if (!$request) {
          $build['estimate_contact_card'] = ['#markup' => ''];
        }
        else {
          $etm = \Drupal::entityTypeManager();
          $html = '';

          // Priority 1: Owner.
          if ($request->hasField('field_owner') && !$request->get('field_owner')->isEmpty()) {
            $owner = $request->get('field_owner')->entity;
            if ($owner) {
              $html = _estimate_build_owner_card($owner, $request, $etm);
            }
          }

          // Priority 2: Contact.
          if (empty($html) && $request->hasField('field_contact') && !$request->get('field_contact')->isEmpty()) {
            $contact = $request->get('field_contact')->entity;
            if ($contact) {
              $html = _estimate_build_contact_card($contact);
            }
          }

          // Priority 3: Requestor info.
          if (empty($html)) {
            $html = _estimate_build_requestor_card($request);
          }

          $build['estimate_contact_card'] = [
            '#markup' => $html ?: '<div class="er-card er-card--empty">No contact information available.</div>',
            '#weight' => -10,
          ];
        }
      }
      catch (\Throwable $e) {
        \Drupal::logger('estimate')->error('Estimate contact card error on estimate @id: @msg', [
          '@id' => $entity->id(),
          '@msg' => $e->getMessage(),
        ]);
        $build['estimate_contact_card'] = ['#markup' => ''];
      }
    }
  }

  // --- Stage change form ---
  if ($display->getComponent('estimate_stage_form')) {
    $build['estimate_stage_form'] = \Drupal::formBuilder()->getForm(
      'Drupal\estimate\Form\EstimateStageChangeForm',
      $entity
    );
  }
}

/**
 * Build owner card HTML (same pattern as estimate_request_cards).
 */
function _estimate_build_owner_card($owner, $request, $etm): string {
  // Load customer_profile.
  $profiles = $etm->getStorage('profile')
    ->loadByProperties([
      'uid' => $owner->id(),
      'type' => 'customer_profile',
      'status' => 1,
    ]);
  $profile = $profiles ? reset($profiles) : NULL;

  // Name.
  $name = '';
  if ($profile) {
    $first = $profile->hasField('field_first_name') ? (string) $profile->get('field_first_name')->value : '';
    $last  = $profile->hasField('field_last_name')  ? (string) $profile->get('field_last_name')->value  : '';
    $name  = trim($first . ' ' . $last);
  }
  if (empty($name)) {
    $name = $owner->getDisplayName();
  }

  // Phone from phone_number.profile_phone_numbers via field_user.
  $phone = '';
  $phone_entities = $etm->getStorage('phone_number')
    ->loadByProperties([
      'type' => 'profile_phone_numbers',
      'field_user' => $owner->id(),
    ]);
  foreach ($phone_entities as $pe) {
    if ($pe->hasField('field_primary_phone') && (bool) $pe->get('field_primary_phone')->value) {
      $phone = (string) $pe->get('field_phone_number')->value;
      break;
    }
  }
  if (empty($phone) && !empty($phone_entities)) {
    $first_phone = reset($phone_entities);
    $phone = (string) $first_phone->get('field_phone_number')->value;
  }

  // Mailing address from address.profile_mailing_addresses via field_user.
  $addr_line = $city = $state = $zip = '';
  $addresses = $etm->getStorage('address')
    ->loadByProperties([
      'type' => 'profile_mailing_addresses',
      'field_user' => $owner->id(),
    ]);
  $addr_entity = NULL;
  foreach ($addresses as $ae) {
    if ($ae->hasField('field_primary_address') && (bool) $ae->get('field_primary_address')->value) {
      $addr_entity = $ae;
      break;
    }
  }
  if (!$addr_entity && !empty($addresses)) {
    $addr_entity = reset($addresses);
  }
  if ($addr_entity) {
    $addr_line = (string) $addr_entity->get('field_address')->value;
    $city      = (string) $addr_entity->get('field_city')->value;
    $state     = (string) $addr_entity->get('field_state')->value;
    $zip       = (string) $addr_entity->get('field_zipcode')->value;
  }

  // Fallback address from field_property on the request.
  if (empty($addr_line) && $request->hasField('field_property') && !$request->get('field_property')->isEmpty()) {
    $property = $request->get('field_property')->entity;
    if ($property) {
      $addr_line = (string) $property->get('field_street_address')->value;
      if (!$property->get('field_zipcode_reference')->isEmpty()) {
        $zip_ref = $property->get('field_zipcode_reference')->entity;
        if ($zip_ref) {
          $zip = (string) $zip_ref->get('field_zipcode')->value;
          if ($zip_ref->hasField('field_city') && !$zip_ref->get('field_city')->isEmpty()) {
            $city_entity = $zip_ref->get('field_city')->entity;
            if ($city_entity && $city_entity->hasField('field_city_name')) {
              $city = (string) $city_entity->get('field_city_name')->value;
            }
          }
        }
      }
    }
  }

  // Email.
  $email = $owner->getEmail();

  // Build HTML.
  $html = '<div class="er-card er-card--owner">';
  $html .= '<h3 class="er-card__role">Owner</h3>';
  if ($name) {
    $url = $owner->toUrl()->toString();
    $html .= '<div class="er-card__name"><a href="' . htmlspecialchars($url) . '">' . htmlspecialchars($name) . '</a></div>';
  }
  if ($addr_line) {
    $html .= '<div class="er-card__address">' . htmlspecialchars($addr_line);
    if ($city || $state || $zip) {
      $html .= '<br>' . htmlspecialchars(trim($city . ', ' . $state . ' ' . $zip));
    }
    $html .= '</div>';
  }
  if ($phone) {
    $html .= '<div class="er-card__phone">Primary Phone: ' . htmlspecialchars($phone) . '</div>';
  }
  if ($email) {
    $html .= '<div class="er-card__email">Email: ' . htmlspecialchars($email) . '</div>';
  }
  $html .= '</div>';

  return $html;
}

/**
 * Build contact card HTML (same pattern as estimate_request_cards).
 */
function _estimate_build_contact_card($contact): string {
  $first = $contact->hasField('field_first_name') ? (string) $contact->get('field_first_name')->value : '';
  $last  = $contact->hasField('field_last_name')  ? (string) $contact->get('field_last_name')->value  : '';
  $name  = trim($first . ' ' . $last);

  $email = $contact->hasField('field_email') ? (string) $contact->get('field_email')->value : '';

  // Phone via forward reference: contacts.contact.field_phone_number → phone_number.contacts.
  $phone = '';
  if ($contact->hasField('field_phone_number') && !$contact->get('field_phone_number')->isEmpty()) {
    $first_phone = $contact->get('field_phone_number')->entity;
    if ($first_phone) {
      $phone = (string) $first_phone->get('field_phone_number')->value;
    }
  }

  // Address via forward reference: contacts.contact.field_address → address.contact_address.
  $addr_line = $city = $state = $zip = '';
  if ($contact->hasField('field_address') && !$contact->get('field_address')->isEmpty()) {
    $addr_entity = $contact->get('field_address')->entity;
    if ($addr_entity) {
      $addr_line = (string) $addr_entity->get('field_address')->value;
      $city      = (string) $addr_entity->get('field_city')->value;
      $state     = (string) $addr_entity->get('field_state')->value;
      $zip       = (string) $addr_entity->get('field_zipcode')->value;
    }
  }

  $html = '<div class="er-card er-card--contact">';
  $html .= '<h3 class="er-card__role">Contact</h3>';
  if ($name) {
    $html .= '<div class="er-card__name">' . htmlspecialchars($name) . '</div>';
  }
  if ($addr_line) {
    $html .= '<div class="er-card__address">' . htmlspecialchars($addr_line);
    if ($city || $state || $zip) {
      $html .= '<br>' . htmlspecialchars(trim($city . ', ' . $state . ' ' . $zip));
    }
    $html .= '</div>';
  }
  if ($phone) {
    $html .= '<div class="er-card__phone">Phone: ' . htmlspecialchars($phone) . '</div>';
  }
  if ($email) {
    $html .= '<div class="er-card__email">Email: ' . htmlspecialchars($email) . '</div>';
  }
  $html .= '</div>';

  return $html;
}

/**
 * Build requestor info card from estimate_request fields.
 */
function _estimate_build_requestor_card($request): string {
  $name    = $request->hasField('field_requestor_name')    ? trim((string) ($request->get('field_requestor_name')->value ?? ''))    : '';
  $phone   = $request->hasField('field_requestor_phone')   ? trim((string) ($request->get('field_requestor_phone')->value ?? ''))   : '';
  $email   = $request->hasField('field_requestor_email')   ? trim((string) ($request->get('field_requestor_email')->value ?? ''))   : '';
  $address = $request->hasField('field_requestor_address') ? trim((string) ($request->get('field_requestor_address')->value ?? '')) : '';

  if (empty($name) && empty($phone) && empty($email) && empty($address)) {
    return '';
  }

  $html = '<div class="er-card er-card--requestor">';
  $html .= '<h3 class="er-card__role">Requestor</h3>';
  if ($name) {
    $html .= '<div class="er-card__name">' . htmlspecialchars($name) . '</div>';
  }
  if ($address) {
    $html .= '<div class="er-card__address">' . htmlspecialchars($address) . '</div>';
  }
  if ($phone) {
    $html .= '<div class="er-card__phone">Phone: ' . htmlspecialchars($phone) . '</div>';
  }
  if ($email) {
    $html .= '<div class="er-card__email">Email: ' . htmlspecialchars($email) . '</div>';
  }
  $html .= '</div>';

  return $html;
}

/* ---------------------------------------------------------------------------
 * Estimate Action Log — Lifecycle Event Recording
 * --------------------------------------------------------------------------- */

/**
 * Log estimate stage changes (called from hook_entity_update).
 */
function _estimate_log_stage_change(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'estimate') {
    return;
  }
  if (!$entity->hasField('field_stage') || !isset($entity->original)) {
    return;
  }

  $old_tid = (int) ($entity->original->get('field_stage')->target_id ?? 0);
  $new_tid = (int) ($entity->get('field_stage')->target_id ?? 0);

  if ($old_tid === $new_tid || $new_tid === 0) {
    return;
  }

  try {
    $from_label = _estimate_load_term_label($old_tid);
    $to_label = _estimate_load_term_label($new_tid);
    $context = 'Stage changed from ' . ($from_label ?: '(none)') . ' to ' . $to_label;

    \Drupal::entityTypeManager()->getStorage('estimate_action_log')->create([
      'type' => 'log',
      'uid' => \Drupal::currentUser()->id(),
      'field_estimate' => $entity->id(),
      'field_from_stage' => $old_tid ?: NULL,
      'field_to_stage' => $new_tid,
      'field_action' => 'stage_change',
      'field_context' => $context,
      'field_admin_override' => FALSE,
    ])->save();
  }
  catch (\Throwable $e) {
    \Drupal::logger('estimate')->error('Failed to log estimate stage change on @id: @msg', [
      '@id' => $entity->id(),
      '@msg' => $e->getMessage(),
    ]);
  }
}

/**
 * Auto-convert estimate to Work Order when stage changes to Accepted.
 *
 * Called from hook_entity_update. Only fires on the transition INTO
 * Accepted — not on re-saves where stage is already Accepted.
 */
function _estimate_auto_convert_on_acceptance(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'estimate') {
    return;
  }
  if (!$entity->hasField('field_stage') || !isset($entity->original)) {
    return;
  }

  $accepted_tid = (int) \Drupal::config('estimate.settings')->get('accepted_stage_tid');
  if ($accepted_tid <= 0) {
    return;
  }

  $old_tid = (int) ($entity->original->get('field_stage')->target_id ?? 0);
  $new_tid = (int) ($entity->get('field_stage')->target_id ?? 0);

  // Only fire on the transition into Accepted, not re-saves.
  if ($new_tid !== $accepted_tid || $old_tid === $accepted_tid) {
    return;
  }

  // Already linked to a WO — nothing to do.
  if ($entity->hasField('field_work_order') && !$entity->get('field_work_order')->isEmpty()) {
    return;
  }

  try {
    /** @var \Drupal\estimate\Service\WorkOrderConverter $converter */
    $converter = \Drupal::service('estimate.work_order_converter');
    $work_order = $converter->convert($entity);

    \Drupal::messenger()->addStatus(t('Work Order #@wid automatically created from accepted Estimate #@eid.', [
      '@wid' => $work_order->id(),
      '@eid' => $entity->id(),
    ]));
  }
  catch (\Throwable $e) {
    \Drupal::logger('estimate')->error('Auto-conversion failed for Estimate @eid: @msg', [
      '@eid' => $entity->id(),
      '@msg' => $e->getMessage(),
    ]);
    \Drupal::messenger()->addWarning(t('Estimate accepted but Work Order could not be created automatically: @msg', [
      '@msg' => $e->getMessage(),
    ]));
  }
}

/**
 * Log estimate_request status changes (called from hook_entity_update).
 */
function _estimate_log_request_status_change(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'estimate_request') {
    return;
  }
  if (!$entity->hasField('field_status') || !isset($entity->original)) {
    return;
  }

  $old_tid = (int) ($entity->original->get('field_status')->target_id ?? 0);
  $new_tid = (int) ($entity->get('field_status')->target_id ?? 0);

  if ($old_tid === $new_tid || $new_tid === 0) {
    return;
  }

  try {
    $from_label = _estimate_load_term_label($old_tid);
    $to_label = _estimate_load_term_label($new_tid);
    $context = 'Status changed from ' . ($from_label ?: '(none)') . ' to ' . $to_label;

    \Drupal::entityTypeManager()->getStorage('estimate_action_log')->create([
      'type' => 'request_log',
      'uid' => \Drupal::currentUser()->id(),
      'field_request' => $entity->id(),
      'field_from_status' => $old_tid ?: NULL,
      'field_to_status' => $new_tid,
      'field_action' => 'status_change',
      'field_context' => $context,
      'field_admin_override' => FALSE,
    ])->save();
  }
  catch (\Throwable $e) {
    \Drupal::logger('estimate')->error('Failed to log estimate_request status change on @id: @msg', [
      '@id' => $entity->id(),
      '@msg' => $e->getMessage(),
    ]);
  }
}

/**
 * Update estimate_request status when a Work Order is created from an Estimate.
 *
 * Walks back from the new WO → estimate → estimate_request, then checks
 * every estimate on the request. If all estimates have reached a terminal
 * stage (Accepted=1418 or Declined=1419), sets the request status to
 * Converted (1658) when at least one was Accepted, or Declined/Canceled
 * (1657) when none were.
 *
 * Called from estimate_entity_insert(). Only acts on work_order entities.
 * Idempotent — landscaping containers create multiple WOs and each will
 * re-fire this, but the status will simply be set to the same value.
 */
function _estimate_maybe_update_request_status_on_wo_insert(EntityInterface $entity): void {
  // Only process work_order entities.
  if ($entity->getEntityTypeId() !== 'work_order') {
    return;
  }

  // Must have field_estimate populated.
  if (!$entity->hasField('field_estimate') || $entity->get('field_estimate')->isEmpty()) {
    return;
  }

  $estimate_id = (int) $entity->get('field_estimate')->target_id;
  $estimate_storage = \Drupal::entityTypeManager()->getStorage('estimate');
  $estimate = $estimate_storage->load($estimate_id);
  if (!$estimate) {
    return;
  }

  // Walk back to the estimate_request.
  if (!$estimate->hasField('field_estimate_request') || $estimate->get('field_estimate_request')->isEmpty()) {
    return;
  }

  $request_id = (int) $estimate->get('field_estimate_request')->target_id;
  $request_storage = \Drupal::entityTypeManager()->getStorage('estimate_request');
  $estimate_request = $request_storage->load($request_id);
  if (!$estimate_request) {
    return;
  }

  // Load all estimates on this request.
  $sibling_estimate_ids = array_column(
    $estimate_request->get('field_estimates')->getValue(),
    'target_id'
  );

  if (empty($sibling_estimate_ids)) {
    return;
  }

  $open_stages = [1412, 1413, 1414, 1415, 1416, 1417, 1420, 1421];
  $has_open = FALSE;
  $has_accepted = FALSE;

  foreach ($sibling_estimate_ids as $sibling_id) {
    $sibling = $estimate_storage->load($sibling_id);
    if (!$sibling) {
      continue;
    }
    $stage_id = (int) $sibling->get('field_stage')->target_id;
    if (in_array($stage_id, $open_stages, TRUE)) {
      $has_open = TRUE;
      break;
    }
    if ($stage_id === 1418) {
      $has_accepted = TRUE;
    }
  }

  // If any estimates are still open, do not change request status yet.
  if ($has_open) {
    return;
  }

  // All estimates are terminal — set request status accordingly.
  $new_status_tid = $has_accepted ? 1658 : 1657;

  try {
    $estimate_request->set('field_status', ['target_id' => $new_status_tid]);
    $estimate_request->save();
  }
  catch (\Exception $e) {
    \Drupal::logger('estimate')->warning(
      'Could not update estimate_request @id status after WO creation: @message',
      ['@id' => $request_id, '@message' => $e->getMessage()]
    );
  }
}

/**
 * Log note additions (called from hook_entity_insert).
 */
function _estimate_log_note_added(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'estimate_notes') {
    return;
  }

  $bundle = $entity->bundle();
  $user_name = \Drupal::currentUser()->getDisplayName();

  try {
    if ($bundle === 'note' && $entity->hasField('field_estimate') && !$entity->get('field_estimate')->isEmpty()) {
      \Drupal::entityTypeManager()->getStorage('estimate_action_log')->create([
        'type' => 'log',
        'uid' => \Drupal::currentUser()->id(),
        'field_estimate' => (int) $entity->get('field_estimate')->target_id,
        'field_action' => 'note_added',
        'field_context' => 'Note added by ' . $user_name,
        'field_admin_override' => FALSE,
      ])->save();
    }
    elseif ($bundle === 'request' && $entity->hasField('field_estimate_request') && !$entity->get('field_estimate_request')->isEmpty()) {
      \Drupal::entityTypeManager()->getStorage('estimate_action_log')->create([
        'type' => 'request_log',
        'uid' => \Drupal::currentUser()->id(),
        'field_request' => (int) $entity->get('field_estimate_request')->target_id,
        'field_action' => 'note_added',
        'field_context' => 'Note added by ' . $user_name,
        'field_admin_override' => FALSE,
      ])->save();
    }
  }
  catch (\Throwable $e) {
    \Drupal::logger('estimate')->error('Failed to log note addition on estimate_notes @id: @msg', [
      '@id' => $entity->id(),
      '@msg' => $e->getMessage(),
    ]);
  }
}

/**
 * Log note deletions (called from hook_entity_delete).
 */
function _estimate_log_note_deleted(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'estimate_notes') {
    return;
  }

  $bundle = $entity->bundle();
  $user_name = \Drupal::currentUser()->getDisplayName();

  try {
    if ($bundle === 'note' && $entity->hasField('field_estimate') && !$entity->get('field_estimate')->isEmpty()) {
      \Drupal::entityTypeManager()->getStorage('estimate_action_log')->create([
        'type' => 'log',
        'uid' => \Drupal::currentUser()->id(),
        'field_estimate' => (int) $entity->get('field_estimate')->target_id,
        'field_action' => 'note_deleted',
        'field_context' => 'Note deleted by ' . $user_name,
        'field_admin_override' => FALSE,
      ])->save();
    }
    elseif ($bundle === 'request' && $entity->hasField('field_estimate_request') && !$entity->get('field_estimate_request')->isEmpty()) {
      \Drupal::entityTypeManager()->getStorage('estimate_action_log')->create([
        'type' => 'request_log',
        'uid' => \Drupal::currentUser()->id(),
        'field_request' => (int) $entity->get('field_estimate_request')->target_id,
        'field_action' => 'note_deleted',
        'field_context' => 'Note deleted by ' . $user_name,
        'field_admin_override' => FALSE,
      ])->save();
    }
  }
  catch (\Throwable $e) {
    \Drupal::logger('estimate')->error('Failed to log note deletion on estimate_notes @id: @msg', [
      '@id' => $entity->id(),
      '@msg' => $e->getMessage(),
    ]);
  }
}

/**
 * Load a taxonomy term label by TID.
 */
function _estimate_load_term_label(int $tid): string {
  if ($tid <= 0) {
    return '';
  }
  try {
    $term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($tid);
    return $term ? (string) $term->label() : '';
  }
  catch (\Throwable $e) {
    return '';
  }
}

/* -------------------------------------------------------------------------- */
/* Internal helpers (do not call outside this module)                         */
/* -------------------------------------------------------------------------- */

/* ---------------------------------------------------------------------------
 * Property creation from Estimate Request
 * --------------------------------------------------------------------------- */

/**
 * Implements hook_form_alter().
 *
 * Pre-fills the property add form when redirected from an Estimate Request's
 * "Create Property from Address" button. Query parameters:
 * - from_estimate_request: the request ID (stored in hidden field for post-save linking)
 * - street: parsed street address
 * - zip: parsed zip code (used to look up zipcodes entity)
 * - owner_uid: property owner user ID
 */
function estimate_form_alter(array &$form, \Drupal\Core\Form\FormStateInterface $form_state, string $form_id): void {
  // Scope summary validation for estimate edit forms.
  estimate_form_alter_estimate_scope($form, $form_state, $form_id);

  // Pre-fill field_property on estimate_request add form when ?property_id= is present.
  if ($form_id === 'estimate_request_standard_form') {
    $property_id = (int) \Drupal::request()->query->get('property_id', 0);
    if ($property_id > 0 && isset($form['field_property']['widget'][0]['target_id'])) {
      $property = \Drupal::entityTypeManager()->getStorage('properties')->load($property_id);
      if ($property) {
        $form['field_property']['widget'][0]['target_id']['#default_value'] = $property;
      }
    }
    return;
  }

  // Property form ID is "properties_property_form" (ECK pattern).
  if ($form_id !== 'properties_property_form') {
    return;
  }

  $request = \Drupal::request();
  $er_id = (int) $request->query->get('from_estimate_request', 0);
  if ($er_id <= 0) {
    return;
  }

  $etm = \Drupal::entityTypeManager();

  // --- Street address ---
  $street = $request->query->get('street', '');
  if ($street !== '' && isset($form['field_street_address']['widget'][0]['value'])) {
    $form['field_street_address']['widget'][0]['value']['#default_value'] = $street;
  }

  // --- Zipcode reference (select widget — set #default_value on widget root) ---
  $zip = $request->query->get('zip', '');
  $zipcode_entity = NULL;
  if ($zip !== '' && isset($form['field_zipcode_reference'])) {
    $zip_ids = $etm->getStorage('zipcodes')
      ->getQuery()
      ->accessCheck(FALSE)
      ->condition('field_zipcode', $zip)
      ->range(0, 1)
      ->execute();
    if (!empty($zip_ids)) {
      $zip_id = (int) array_values($zip_ids)[0];
      $zipcode_entity = $etm->getStorage('zipcodes')->load($zip_id);
      $form['field_zipcode_reference']['widget']['#default_value'] = [$zip_id];
    }
  }

  // --- Geocode address (geofield_map widget's built-in geocode input) ---
  $geocode_address = $request->query->get('geocode_address', '');
  if ($geocode_address !== '' && isset($form['field_geofield']['widget'][0]['value'])) {
    // The geofield_map widget renders the geocode address box via JS.
    // Pass the address as a data attribute so JS or the user can use it.
    $form['field_geofield']['widget'][0]['value']['#default_value'] = [
      'lat' => 0,
      'lon' => 0,
    ];
    // Attach the address for the geocode search box via drupalSettings.
    $form['#attached']['drupalSettings']['estimatePropertyGeocode'] = $geocode_address;
  }

  // --- Full address (computed on presave, but pre-fill for reference) ---
  if ($geocode_address !== '' && isset($form['field_full_address']['widget'][0]['value'])) {
    $form['field_full_address']['widget'][0]['value']['#default_value'] = $geocode_address;
  }

  // --- Primary contact from estimate request ---
  $contact_id = (int) $request->query->get('contact_id', 0);
  if ($contact_id > 0 && isset($form['field_primary_contact_ref']['widget'][0]['target_id'])) {
    $contact = $etm->getStorage('contacts')->load($contact_id);
    if ($contact) {
      $form['field_primary_contact_ref']['widget'][0]['target_id']['#default_value'] = $contact;
    }
  }

  // --- County account/parcel lookup hint ---
  if ($zipcode_entity && $geocode_address !== '') {
    $county_name = '';
    if (!$zipcode_entity->get('field_county')->isEmpty()) {
      $county_entity = $zipcode_entity->get('field_county')->entity;
      if ($county_entity) {
        $county_name = $county_entity->label();
      }
    }
    if ($county_name && isset($form['field_county_account_number']['widget'][0]['value'])) {
      $form['field_county_account_number']['widget'][0]['value']['#description'] =
        t('Look up at the @county assessor website using address: @addr', [
          '@county' => $county_name,
          '@addr' => $geocode_address,
        ]);
    }
    if ($county_name && isset($form['field_parcel_number']['widget'][0]['value'])) {
      $form['field_parcel_number']['widget'][0]['value']['#description'] =
        t('Look up at the @county assessor website using address: @addr', [
          '@county' => $county_name,
          '@addr' => $geocode_address,
        ]);
    }
  }

  // Store the estimate request ID so we can link back after save.
  $form['from_estimate_request'] = [
    '#type' => 'hidden',
    '#value' => $er_id,
  ];

  // Add submit handler to link the property back to the request.
  $form['actions']['submit']['#submit'][] = '_estimate_property_created_from_request_submit';
}

/**
 * Submit handler: link newly created property back to the estimate request.
 */
function _estimate_property_created_from_request_submit(array &$form, \Drupal\Core\Form\FormStateInterface $form_state): void {
  $er_id = (int) $form_state->getValue('from_estimate_request');
  if ($er_id <= 0) {
    return;
  }

  $entity = $form_state->getFormObject()->getEntity();
  if (!$entity || $entity->getEntityTypeId() !== 'properties') {
    return;
  }

  $property_id = (int) $entity->id();
  if ($property_id <= 0) {
    return;
  }

  $req = \Drupal::entityTypeManager()->getStorage('estimate_request')->load($er_id);
  if (!$req) {
    return;
  }

  // Link property to request.
  if ($req->hasField('field_property') && $req->get('field_property')->isEmpty()) {
    $req->set('field_property', ['target_id' => $property_id]);
    $req->save();

    \Drupal::messenger()->addStatus(t('Property linked to Estimate Request #@id.', ['@id' => $er_id]));
    \Drupal::logger('estimate')->notice('Linked Property @pid to Estimate Request @rid.', [
      '@pid' => $property_id,
      '@rid' => $er_id,
    ]);
  }

  // Redirect back to the estimate request.
  $form_state->setRedirect('entity.estimate_request.canonical', ['estimate_request' => $er_id]);
}

/* --------------------------------------------------------------------------
 * Scope Summary Validation — prevents advancing past "In Preparation"
 * without a real scope summary.
 * -------------------------------------------------------------------------- */

/**
 * Implements hook_form_FORM_ID_alter() pattern for estimate edit forms.
 *
 * Adds a validation handler that requires field_scope_summary to be filled
 * with real content (not the auto-generated placeholder) before the estimate
 * stage can advance past "In Preparation".
 */
function estimate_form_alter_estimate_scope(&$form, \Drupal\Core\Form\FormStateInterface $form_state, string $form_id): void {
  // Only target estimate edit forms (estimate_{bundle}_edit_form).
  if (!str_starts_with($form_id, 'estimate_') || !str_ends_with($form_id, '_edit_form')) {
    return;
  }
  // Exclude estimate_request, estimate_items, etc.
  if (str_starts_with($form_id, 'estimate_request_')
      || str_starts_with($form_id, 'estimate_items_')
      || str_starts_with($form_id, 'estimate_notes_')
      || str_starts_with($form_id, 'estimate_action_log_')
      || str_starts_with($form_id, 'estimate_tasks_')
      || str_starts_with($form_id, 'estimate_board_')) {
    return;
  }
  // Only if the form has both fields.
  if (!isset($form['field_scope_summary']) || !isset($form['field_stage'])) {
    return;
  }
  $form['#validate'][] = '_estimate_scope_summary_validate';
}

/**
 * Validation handler: scope summary must have real content for advanced stages.
 */
function _estimate_scope_summary_validate(array $form, \Drupal\Core\Form\FormStateInterface $form_state): void {
  $requires_scope_tids = [1420, 1416, 1421, 1417, 1418];

  $stage_value = $form_state->getValue('field_stage');
  $stage_tid = (int) ($stage_value[0]['target_id'] ?? 0);

  if (!in_array($stage_tid, $requires_scope_tids, TRUE)) {
    return;
  }

  $scope_value = $form_state->getValue('field_scope_summary');
  $scope = trim(strip_tags($scope_value[0]['value'] ?? ''));

  if (_estimate_scope_is_placeholder($scope)) {
    $form_state->setErrorByName('field_scope_summary',
      t('Scope Summary must be updated with specific project details before advancing past "In Preparation". Replace the placeholder text with a description of the actual work to be done at this property.')
    );
  }
}

/**
 * Checks if scope text is empty or still contains placeholder text.
 */
function _estimate_scope_is_placeholder(string $scope): bool {
  if ($scope === '') {
    return TRUE;
  }
  $placeholders = [
    'CLIENT REQUEST (update after site visit)',
    'Update this scope summary after the site visit.',
    'Client is requesting a Landscaping project. Please review and update',
  ];
  foreach ($placeholders as $p) {
    if (str_starts_with($scope, $p)) {
      return TRUE;
    }
  }
  return FALSE;
}

/**
 * IMPORTANT:
 * This file intentionally does NOT contain:
 * - Work Order conversion logic (belongs in WorkOrderConverter service).
 * - Revision enforcement logic (belongs in EstimateRevisionManager service).
 * - Stage term ID constants (must be config in estimate.settings).
 *
 * Those live in services/classes so they can be tested and reused.
 */

/**
 * Implements hook_views_query_alter().
 *
 * For the scope_elements_by_bundle entity reference view: makes the
 * field_applicable_bundles contextual filter include terms where the field
 * is empty (NULL), so "empty = show for all bundles".
 */
/**
 * Implements hook_views_query_alter().
 *
 * No custom logic needed — the contextual filter on field_applicable_bundles
 * handles filtering directly. Only terms explicitly tagged with the bundle
 * are returned. Untagged terms do not appear.
 */
function estimate_views_query_alter(\Drupal\views\ViewExecutable $view, \Drupal\views\Plugin\views\query\Sql $query): void {
}
