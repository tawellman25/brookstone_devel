{# Estimate Board dashboard #}

{# ── Section 1: Needs Follow-Up ──────────────────────────────────── #}
<div class="estimate-board-section estimate-board-needs-followup">
  <h2 class="estimate-board-section__title">
    Needs Follow-Up
    {% if followups|length > 0 %}
      <span class="estimate-board-badge estimate-board-badge--critical">{{ followups|length }}</span>
    {% endif %}
  </h2>
  {% if followups|length > 0 %}
    <table>
      <thead>
        <tr>
          <th>Client</th>
          <th>Status</th>
          <th>Property</th>
          <th>Services</th>
          <th>Coordinator</th>
          <th>Days</th>
          <th>Last Action</th>
        </tr>
      </thead>
      <tbody>
        {% for item in followups %}
          <tr class="overdue-{{ item.severity }}">
            <td><a href="{{ item.url }}" target="_blank">{{ item.client }}</a></td>
            <td>{{ item.status }}</td>
            <td>{{ item.property }}</td>
            <td>{{ item.services }}</td>
            <td>{{ item.assigned }}</td>
            <td><strong>{{ item.days }}d</strong></td>
            <td>{{ item.last_action ?: '—' }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p class="estimate-board-empty">All estimates are up to date — no follow-ups needed.</p>
  {% endif %}
</div>

{# ── Section 2: Pipeline Swimlanes (one per status) ────────────── #}
{% for group in pipeline %}
  <div class="estimate-board-section estimate-board-swimlane estimate-board-swimlane--{{ group.slug }}">
    <details {% if group.count > 0 %}open{% endif %}>
      <summary class="estimate-board-section__title">
        {{ group.label }}
        <span class="estimate-board-badge estimate-board-badge--{{ group.slug }}{% if group.count == 0 %} estimate-board-badge--empty{% endif %}">
          {{ group.count }}
        </span>
      </summary>

      {% if group.count == 0 %}
        <p class="estimate-board-empty">No requests.</p>
      {% else %}
        <table class="estimate-board-table">
          <thead>
            <tr>
              <th>Client</th>
              <th>Property</th>
              <th>Services</th>
              <th>Coordinator</th>
              <th>Age</th>
              <th>Estimates</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for request in group.requests %}
            <tr class="estimate-board-request-row" data-request-id="{{ request.id }}">
              <td>
                <a href="{{ request.url }}" target="_blank">{{ request.client_name }}</a>
              </td>
              <td>{{ request.property }}</td>
              <td>{{ request.services }}</td>
              <td>{{ request.coordinator }}</td>
              <td class="{% if request.age_days > 7 %}estimate-board-age--warning{% endif %}">
                {{ request.age_days }}d
              </td>
              <td class="estimate-board-estimates-cell">
                {% for est in request.estimates %}
                  <a href="{{ est.url }}" target="_blank" class="estimate-board-est-link">
                    {{ est.label }}
                    {% if est.total %}
                      <span class="estimate-board-est-total">{{ est.total }}</span>
                    {% endif %}
                  </a>
                {% endfor %}
              </td>
              <td class="estimate-board-actions-cell">
                {% if request.prev_status_tid %}
                  <button type="button"
                    class="estimate-board-status-btn estimate-board-status-btn--back"
                    data-request-id="{{ request.id }}"
                    data-status-tid="{{ request.prev_status_tid }}"
                    data-status-label="{{ request.prev_status_label }}"
                    title="Move back to: {{ request.prev_status_label }}">
                    ← Back
                  </button>
                {% endif %}

                {% if request.next_status_tid %}
                  <button type="button"
                    class="estimate-board-status-btn estimate-board-status-btn--next estimate-board-status-btn--{{ group.slug }}"
                    data-request-id="{{ request.id }}"
                    data-status-tid="{{ request.next_status_tid }}"
                    data-status-label="{{ request.next_status_label }}"
                    title="Advance to: {{ request.next_status_label }}">
                    {{ request.next_status_label }} →
                  </button>
                {% endif %}

                <button type="button"
                  class="estimate-board-status-btn estimate-board-status-btn--decline"
                  data-request-id="{{ request.id }}"
                  data-status-tid="{{ decline_tid }}"
                  data-status-label="Declined"
                  data-confirm="Mark this estimate request as Declined?"
                  title="Decline">
                  ✕
                </button>

                <button type="button"
                  class="estimate-board-status-btn estimate-board-status-btn--hold"
                  data-request-id="{{ request.id }}"
                  data-action="hold"
                  title="Put on hold">
                  ⏸
                </button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}
    </details>
  </div>
{% endfor %}

{# ── On Hold Section ────────────────────────────────────────────── #}
<div class="estimate-board-section estimate-board-on-hold"{% if on_hold_requests|length == 0 %} style="display:none"{% endif %}>
  <details>
    <summary class="estimate-board-section__title">
      ⏸ On Hold
      <span class="estimate-board-badge estimate-board-badge--on-hold">{{ on_hold_requests|length }}</span>
    </summary>

    <table class="estimate-board-table">
      <thead>
        <tr>
          <th>Client</th>
          <th>Pipeline Stage</th>
          <th>Property</th>
          <th>Services</th>
          <th>Coordinator</th>
          <th>Hold Until</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for request in on_hold_requests %}
        <tr class="estimate-board-request-row estimate-board-request-row--on-hold"
            data-request-id="{{ request.id }}">
          <td><a href="{{ request.url }}" target="_blank">{{ request.client_name }}</a></td>
          <td><span class="estimate-board-hold-stage">{{ request.current_status_label }}</span></td>
          <td>{{ request.property }}</td>
          <td>{{ request.services }}</td>
          <td>{{ request.coordinator }}</td>
          <td class="estimate-board-hold-date">{{ request.hold_until ?: 'Indefinite' }}</td>
          <td class="estimate-board-actions-cell">
            <button type="button"
              class="estimate-board-status-btn estimate-board-status-btn--lift-hold"
              data-request-id="{{ request.id }}"
              data-action="lift_hold"
              data-status-slug="{{ request.current_status_slug }}"
              title="Lift hold — return to pipeline">
              ▶ Resume
            </button>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </details>
</div>

{# ── Section 3: Estimator Workload ───────────────────────────────── #}
<div class="estimate-board-section estimate-board-workload">
  <h2 class="estimate-board-section__title">Estimator Workload</h2>
  {% if workload|length > 0 %}
    <table>
      <thead>
        <tr>
          <th>Estimator</th>
          <th>Active Estimates</th>
        </tr>
      </thead>
      <tbody>
        {% for row in workload %}
          <tr{% if row.is_current %} class="workload-current"{% endif %}>
            <td>{{ row.name }}</td>
            <td>{{ row.count }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p class="estimate-board-empty">No active estimate assignments.</p>
  {% endif %}
</div>

{# ── Section 4: Recent Activity ──────────────────────────────────── #}
<div class="estimate-board-section estimate-board-activity">
  <h2 class="estimate-board-section__title">Recent Activity (48h)</h2>
  {% if activity|length > 0 %}
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Who</th>
          <th>Action</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody>
        {% for item in activity %}
          <tr>
            <td>{{ item.date }}</td>
            <td>{{ item.user }}</td>
            <td>{{ item.action }}</td>
            <td>
              {% if item.url %}
                <a href="{{ item.url }}" target="_blank">{{ item.context }}</a>
              {% else %}
                {{ item.context }}
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p class="estimate-board-empty">No activity in the last 48 hours.</p>
  {% endif %}
</div>
