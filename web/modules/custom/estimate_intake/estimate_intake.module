<?php

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Ajax\AjaxResponse;
use Drupal\Core\Ajax\ReplaceCommand;

/**
 * Implements hook_form_FORM_ID_alter() for estimate_request_standard_form.
 *
 * Auto-populates field_owner when the office selects a property.
 */
function estimate_intake_form_estimate_request_standard_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (isset($form['field_property']['widget'][0]['target_id'])) {
    $form['field_property']['widget'][0]['target_id']['#ajax'] = [
      'callback' => '_estimate_intake_property_owner_ajax',
      'event' => 'autocompleteclose',
      'wrapper' => 'estimate-request-owner-wrapper',
      'progress' => ['type' => 'throbber', 'message' => NULL],
    ];
  }
  if (isset($form['field_owner'])) {
    $form['field_owner']['#prefix'] = '<div id="estimate-request-owner-wrapper">';
    $form['field_owner']['#suffix'] = '</div>';
  }

  // Pre-fill owner when property_id is in the query string (e.g. "Add Estimate" from property page).
  $property_id = (int) \Drupal::request()->query->get('property_id', 0);
  if ($property_id > 0 && isset($form['field_owner']['widget'][0]['target_id'])) {
    $owner_default = $form['field_owner']['widget'][0]['target_id']['#default_value'] ?? NULL;
    if (empty($owner_default)) {
      /** @var \Drupal\estimate_intake\Service\EstimateRequestIntakeLookup $lookup */
      $lookup = \Drupal::service('estimate_intake.intake_lookup');
      $owner_uid = $lookup->findLatestOwner($property_id);
      if ($owner_uid !== NULL) {
        $owner = \Drupal::entityTypeManager()->getStorage('user')->load($owner_uid);
        if ($owner) {
          $form['field_owner']['widget'][0]['target_id']['#default_value'] = $owner;
        }
      }
    }
  }
}

/**
 * AJAX callback: look up property owner when field_property changes.
 */
function _estimate_intake_property_owner_ajax(array &$form, FormStateInterface $form_state): AjaxResponse {
  $response = new AjaxResponse();

  // Check if owner is already set — don't overwrite.
  $owner_value = $form_state->getValue('field_owner');
  $owner_target = $owner_value[0]['target_id'] ?? NULL;
  if (!empty($owner_target)) {
    $response->addCommand(new ReplaceCommand('#estimate-request-owner-wrapper', $form['field_owner']));
    return $response;
  }

  // Get the selected property ID from the submitted value.
  $property_value = $form_state->getValue('field_property');
  $property_id = (int) ($property_value[0]['target_id'] ?? 0);

  if ($property_id > 0) {
    /** @var \Drupal\estimate_intake\Service\EstimateRequestIntakeLookup $lookup */
    $lookup = \Drupal::service('estimate_intake.intake_lookup');
    $owner_uid = $lookup->findLatestOwner($property_id);

    if ($owner_uid !== NULL) {
      $owner = \Drupal::entityTypeManager()->getStorage('user')->load($owner_uid);
      if ($owner) {
        $form['field_owner']['widget'][0]['target_id']['#value'] = $owner->getDisplayName() . ' (' . $owner_uid . ')';
        \Drupal::messenger()->addStatus(t('Owner auto-filled: @name', ['@name' => $owner->getDisplayName()]));
      }
    }
  }

  $response->addCommand(new ReplaceCommand('#estimate-request-owner-wrapper', $form['field_owner']));
  return $response;
}

/**
 * Implements hook_module_implements_alter().
 */
function estimate_intake_module_implements_alter(array &$implementations, string $hook): void {
  if (($hook === 'entity_presave' || $hook === 'entity_insert') && isset($implementations['estimate_intake'])) {
    // Move estimate_intake to the front so fields are populated
    // before estimate's warning builder checks them.
    $group = $implementations['estimate_intake'];
    unset($implementations['estimate_intake']);
    $implementations = ['estimate_intake' => $group] + $implementations;
  }
}

/**
 * Implements hook_entity_presave().
 */
function estimate_intake_entity_presave(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'estimate_request' || $entity->bundle() !== 'standard') {
    return;
  }

  /** @var \Drupal\estimate_intake\Service\EstimateRequestIntakeLookup $lookup */
  $lookup = \Drupal::service('estimate_intake.intake_lookup');

  $address = '';
  if ($entity->hasField('field_requestor_address') && !$entity->get('field_requestor_address')->isEmpty()) {
    $address = trim((string) $entity->get('field_requestor_address')->value);
  }

  $name = '';
  if ($entity->hasField('field_requestor_name') && !$entity->get('field_requestor_name')->isEmpty()) {
    $name = trim((string) $entity->get('field_requestor_name')->value);
  }

  $phone = '';
  if ($entity->hasField('field_requestor_phone') && !$entity->get('field_requestor_phone')->isEmpty()) {
    $phone = trim((string) $entity->get('field_requestor_phone')->value);
  }

  $email = '';
  if ($entity->hasField('field_requestor_email') && !$entity->get('field_requestor_email')->isEmpty()) {
    $email = trim((string) $entity->get('field_requestor_email')->value);
  }

  // If no requestor info, skip orchestrate but still try owner lookup below.
  $has_requestor_info = ($address !== '' || $name !== '' || $phone !== '' || $email !== '');

  $messages = [];
  $result = ['properties' => [], 'owner_uid' => NULL, 'contact_id' => 0, 'contact_created' => FALSE];
  $property_already_set = $entity->hasField('field_property') && !$entity->get('field_property')->isEmpty();

  // --- Requestor-based lookup (property, contact) ---
  if ($has_requestor_info) {
    // Split name on first space.
    $first_name = $name;
    $last_name = '';
    if (str_contains($name, ' ')) {
      $parts = explode(' ', $name, 2);
      $first_name = $parts[0];
      $last_name = $parts[1];
    }

    $result = $lookup->orchestrate($address, $first_name, $last_name, $phone, $email);

    // --- Property: only populate if not already set ---
    if (!$property_already_set && $address !== '') {
      $properties = $result['properties'];
      if (count($properties) === 1) {
        $prop = reset($properties);
        $entity->set('field_property', ['target_id' => (int) $prop->id()]);
        $label = $prop->hasField('field_street_address') ? ($prop->get('field_street_address')->value ?? '') : '';
        $messages[] = t('Property matched: @label (#@id)', ['@label' => $label, '@id' => $prop->id()]);
      }
      elseif (count($properties) > 1) {
        $addrs = [];
        foreach ($properties as $prop) {
          $addr = $prop->hasField('field_street_address') ? ($prop->get('field_street_address')->value ?? '') : ('Property ' . $prop->id());
          $addrs[] = $addr . ' (#' . $prop->id() . ')';
        }
        $messages[] = t('Multiple properties match "@address": @list — set field_property manually.', [
          '@address' => $address,
          '@list' => implode(', ', $addrs),
        ]);
      }
      else {
        $messages[] = t('No property found matching "@address".', ['@address' => $address]);
      }
    }

    // --- Contact: only populate if not already set ---
    $contact_already_set = $entity->hasField('field_contact') && !$entity->get('field_contact')->isEmpty();
    if (!$contact_already_set && $result['contact_id'] > 0) {
      $entity->set('field_contact', ['target_id' => $result['contact_id']]);
      $contact = \Drupal::entityTypeManager()->getStorage('contacts')->load($result['contact_id']);
      if ($result['contact_created']) {
        $messages[] = t('Contact created: @name (#@id)', [
          '@name' => $contact ? $contact->label() : 'Unknown',
          '@id' => $result['contact_id'],
        ]);
      }
      else {
        $messages[] = t('Existing contact found: @name (#@id)', [
          '@name' => $contact ? $contact->label() : 'Unknown',
          '@id' => $result['contact_id'],
        ]);
      }
    }
  }

  // --- Owner: always populate if not set and property is available ---
  $owner_already_set = $entity->hasField('field_owner') && !$entity->get('field_owner')->isEmpty();
  if (!$owner_already_set && $entity->hasField('field_property') && !$entity->get('field_property')->isEmpty()) {
    $property_id = (int) $entity->get('field_property')->target_id;
    $owner_uid = $result['owner_uid'];
    // If orchestrate didn't find it (property was pre-set or no requestor info), look up directly.
    if ($owner_uid === NULL) {
      $owner_uid = $lookup->findLatestOwner($property_id);
    }
    if ($owner_uid !== NULL) {
      $entity->set('field_owner', ['target_id' => $owner_uid]);
      $owner = \Drupal::entityTypeManager()->getStorage('user')->load($owner_uid);
      $messages[] = t('Owner set: @name (#@uid)', [
        '@name' => $owner ? $owner->getDisplayName() : 'Unknown',
        '@uid' => $owner_uid,
      ]);
    }
  }

  // Show summary messages after save.
  if (!empty($messages)) {
    $messenger = \Drupal::messenger();
    foreach ($messages as $msg) {
      $messenger->addStatus($msg);
    }
  }
}

/**
 * Implements hook_entity_insert().
 *
 * Assigns "Estimate Request #ID" title to manually-created estimate requests
 * that have empty, generic, or default titles. Then auto-creates an estimate
 * entity if the request's service term has field_estimate_service enabled.
 */
function estimate_intake_entity_insert(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'estimate_request' || $entity->bundle() !== 'standard') {
    return;
  }

  // --- Title assignment ---
  $title = trim((string) ($entity->label() ?? ''));
  $generic_titles = ['', 'Standard', 'Estimate Request - Pending'];

  if (in_array($title, $generic_titles, TRUE)) {
    $entity->set('title', 'Estimate Request #' . $entity->id());
    $entity->save();
  }

  // --- Auto-create estimate entity from service term ---
  try {
    _estimate_intake_create_estimate($entity);
  }
  catch (\Throwable $e) {
    \Drupal::logger('estimate_intake')
      ->error('Estimate auto-creation failed for request #@rid: @msg', [
        '@rid' => $entity->id(),
        '@msg' => $e->getMessage(),
      ]);
  }
}

/**
 * Implements hook_entity_update().
 *
 * Creates estimates for any new services added to an existing request.
 * The duplicate check in _estimate_intake_create_estimate ensures we only
 * create estimates for services that don't already have one.
 */
function estimate_intake_entity_update(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'estimate_request' || $entity->bundle() !== 'standard') {
    return;
  }

  try {
    _estimate_intake_create_estimate($entity);
  }
  catch (\Throwable $e) {
    \Drupal::logger('estimate_intake')
      ->error('Estimate auto-creation failed on update for request #@rid: @msg', [
        '@rid' => $entity->id(),
        '@msg' => $e->getMessage(),
      ]);
  }
}

/**
 * Creates estimate entities for an estimate request's services.
 *
 * Reads the service term's field_service_bundle to determine the estimate
 * bundle. Skips if field_estimate_service is not enabled or if an estimate
 * already exists for this bundle on the request (safe for insert and update).
 */
function _estimate_intake_create_estimate(EntityInterface $request): void {
  // 1. Load field_service taxonomy terms — loop over ALL values.
  if (!$request->hasField('field_service') || $request->get('field_service')->isEmpty()) {
    return;
  }

  $service_values = $request->get('field_service')->getValue();

  foreach ($service_values as $service_ref) {
    $service_tid = (int) ($service_ref['target_id'] ?? 0);
    if ($service_tid <= 0) {
      continue;
    }
    $service_term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($service_tid);
    if ($service_term === NULL) {
      continue;
    }

    $term_name = $service_term->label();

    // 2. Read field_service_bundle — estimate bundle machine name.
    if (!$service_term->hasField('field_service_bundle') || $service_term->get('field_service_bundle')->isEmpty()) {
      continue;
    }
    $bundle = trim((string) $service_term->get('field_service_bundle')->value);
    if ($bundle === '') {
      continue;
    }

    // 3. Check field_estimate_service boolean — skip if not an estimate service.
    if (!$service_term->hasField('field_estimate_service') || $service_term->get('field_estimate_service')->isEmpty()) {
      \Drupal::logger('estimate_intake')
        ->notice('Skipping estimate for service "@name" (tid @tid): field_estimate_service is empty or missing.', [
          '@name' => $term_name,
          '@tid' => $service_tid,
        ]);
      continue;
    }
    $estimate_service_value = $service_term->get('field_estimate_service')->value;
    if (!(bool) $estimate_service_value) {
      \Drupal::logger('estimate_intake')
        ->notice('Skipping estimate for service "@name" (tid @tid): field_estimate_service is @val (disabled).', [
          '@name' => $term_name,
          '@tid' => $service_tid,
          '@val' => $estimate_service_value,
        ]);
      continue;
    }

    // 4. Verify estimate bundle exists.
    $bundle_info = \Drupal::service('entity_type.bundle.info')->getBundleInfo('estimate');
    if (!isset($bundle_info[$bundle])) {
      \Drupal::logger('estimate_intake')
        ->warning('Estimate bundle @bundle does not exist (service term @tid). Skipping auto-creation for request #@rid.', [
          '@bundle' => $bundle,
          '@tid' => $service_tid,
          '@rid' => $request->id(),
        ]);
      \Drupal::messenger()->addWarning(t('Estimate bundle "@bundle" does not exist. Estimate was not auto-created.', [
        '@bundle' => $bundle,
      ]));
      continue;
    }

    // 4a. Skip if an estimate already exists for this bundle on this request.
    $existing = \Drupal::entityTypeManager()->getStorage('estimate')
      ->getQuery()
      ->accessCheck(FALSE)
      ->condition('type', $bundle)
      ->condition('field_estimate_request.target_id', (int) $request->id())
      ->range(0, 1)
      ->execute();
    if (!empty($existing)) {
      continue;
    }

    // 5. Build estimate entity values.
    $values = [
      'type' => $bundle,
      'title' => 'Estimate - Pending',
      'field_estimate_request' => ['target_id' => (int) $request->id()],
      'field_revision_number' => 1,
      'field_is_current_revision' => TRUE,
    ];

    // field_assigned_to from service term's field_default_estimator.
    if ($service_term->hasField('field_default_estimator') && !$service_term->get('field_default_estimator')->isEmpty()) {
      $values['field_assigned_to'] = ['target_id' => (int) $service_term->get('field_default_estimator')->target_id];
    }

    // 6. Create and save estimate.
    $estimate_storage = \Drupal::entityTypeManager()->getStorage('estimate');
    $estimate = $estimate_storage->create($values);
    $estimate->save();
    $estimate_id = (int) $estimate->id();

    // 7. Update title with entity ID.
    $estimate->set('title', 'Estimate #' . $estimate_id);
    $estimate->save();

    // 8. Add estimate to request's field_estimates and resave request.
    if ($request->hasField('field_estimates')) {
      $current = $request->get('field_estimates')->getValue();
      $current[] = ['target_id' => $estimate_id];
      $request->set('field_estimates', $current);
      $request->save();
    }

    // 8b. Link estimate ↔ contract section (bidirectional).
    _estimate_intake_link_contract_section($request, $estimate, $service_tid);

    // 8c. Auto-create estimate_task if bundle supports it.
    _estimate_intake_create_estimate_task($estimate, $bundle);

    // 9. Log success.
    \Drupal::logger('estimate_intake')
      ->info('Created estimate #@eid (@bundle) for request #@rid.', [
        '@eid' => $estimate_id,
        '@bundle' => $bundle,
        '@rid' => $request->id(),
      ]);

    // 10. Status message.
    $estimator_name = '';
    if (isset($values['field_assigned_to'])) {
      $estimator = \Drupal::entityTypeManager()->getStorage('user')->load($values['field_assigned_to']['target_id']);
      $estimator_name = $estimator ? $estimator->getDisplayName() : ('user ' . $values['field_assigned_to']['target_id']);
    }
    if ($estimator_name !== '') {
      \Drupal::messenger()->addStatus(t('Estimate #@eid created and assigned to @name.', [
        '@eid' => $estimate_id,
        '@name' => $estimator_name,
      ]));
    }
    else {
      \Drupal::messenger()->addStatus(t('Estimate #@eid created.', ['@eid' => $estimate_id]));
    }
  }
}

/**
 * Creates an estimate_tasks entity for a new estimate.
 *
 * Only creates a task for bundles that have a corresponding estimate_tasks
 * bundle. Silently skips all others. Failure never blocks estimate creation.
 */
function _estimate_intake_create_estimate_task($estimate, string $bundle): void {
  $estimateTaskBundles = [
    'aerating', 'aspen_twig_gall', 'backflow_testing', 'cooley_spruce_gall',
    'deciduous_bore', 'deer_prevention', 'dethatching', 'dormant_oil',
    'fertilizing', 'fertilizing_trees_and_shrubs', 'lawn_mowing',
    'pinyon_pine_ips_beetle', 'pre_emergent', 'special_mowing',
    'sprinkler_start_up', 'sprinkler_winterizing', 'summer_pruning',
    'trunk_bore', 'winter_pruning',
  ];

  if (!in_array($bundle, $estimateTaskBundles, TRUE)) {
    return;
  }

  try {
    // Verify estimate_tasks bundle exists.
    $bundle_info = \Drupal::service('entity_type.bundle.info')->getBundleInfo('estimate_tasks');
    if (!isset($bundle_info[$bundle])) {
      \Drupal::logger('estimate_intake')
        ->warning('estimate_tasks bundle @bundle does not exist. Skipping task creation for estimate #@eid.', [
          '@bundle' => $bundle,
          '@eid' => $estimate->id(),
        ]);
      return;
    }

    // No duplicates — check if one already exists.
    $existing = \Drupal::entityTypeManager()
      ->getStorage('estimate_tasks')
      ->loadByProperties([
        'field_estimate' => $estimate->id(),
        'type' => $bundle,
      ]);
    if (!empty($existing)) {
      return;
    }

    // Create estimate_tasks entity.
    $task_storage = \Drupal::entityTypeManager()->getStorage('estimate_tasks');
    $task = $task_storage->create([
      'type' => $bundle,
      'title' => 'ET-Pending',
      'field_estimate' => ['target_id' => (int) $estimate->id()],
    ]);
    $task->save();

    \Drupal::logger('estimate_intake')
      ->info('Created estimate_task #@tid (@bundle) for estimate #@eid.', [
        '@tid' => $task->id(),
        '@bundle' => $bundle,
        '@eid' => $estimate->id(),
      ]);
  }
  catch (\Throwable $e) {
    \Drupal::logger('estimate_intake')
      ->error('estimate_task creation failed for estimate #@eid (@bundle): @msg', [
        '@eid' => $estimate->id(),
        '@bundle' => $bundle,
        '@msg' => $e->getMessage(),
      ]);
  }
}

/**
 * Links an estimate to its matching contract section (bidirectional).
 *
 * Finds the contract_section on the request's contract whose field_service
 * matches the estimate's service term. Sets:
 * - estimate.field_contract_section → the matching section
 * - contract_section.field_estimates[] += the estimate
 *
 * Failure never blocks estimate creation.
 */
function _estimate_intake_link_contract_section($request, $estimate, int $service_tid): void {
  try {
    // Request must have a contract.
    if (!$request->hasField('field_contract') || $request->get('field_contract')->isEmpty()) {
      return;
    }
    $contract_id = (int) $request->get('field_contract')->target_id;
    if ($contract_id <= 0) {
      return;
    }

    // Find contract_sections on this contract matching the service term.
    $section_storage = \Drupal::entityTypeManager()->getStorage('contract_sections');
    $section_ids = $section_storage->getQuery()
      ->accessCheck(FALSE)
      ->condition('field_contract.target_id', $contract_id)
      ->condition('field_service.target_id', $service_tid)
      ->range(0, 1)
      ->execute();

    if (empty($section_ids)) {
      return;
    }

    $section_id = (int) array_values($section_ids)[0];
    $section = $section_storage->load($section_id);
    if ($section === NULL) {
      return;
    }

    $estimate_id = (int) $estimate->id();
    $changed = FALSE;

    // Set field_contract_section on the estimate.
    if ($estimate->hasField('field_contract_section')) {
      $current_cs = (int) ($estimate->get('field_contract_section')->target_id ?? 0);
      if ($current_cs !== $section_id) {
        $estimate->set('field_contract_section', ['target_id' => $section_id]);
        $estimate->save();
        $changed = TRUE;
      }
    }

    // Add the estimate to the section's field_estimates.
    if ($section->hasField('field_estimates')) {
      $existing = $section->get('field_estimates')->getValue();
      $existing_ids = array_map(fn($item) => (int) ($item['target_id'] ?? 0), $existing);

      if (!in_array($estimate_id, $existing_ids, TRUE)) {
        $existing[] = ['target_id' => $estimate_id];
        $section->set('field_estimates', $existing);
        $section->save();
        $changed = TRUE;
      }
    }

    if ($changed) {
      \Drupal::logger('estimate_intake')
        ->info('Linked estimate #@eid to contract_section #@sid.', [
          '@eid' => $estimate_id,
          '@sid' => $section_id,
        ]);
    }
  }
  catch (\Throwable $e) {
    \Drupal::logger('estimate_intake')
      ->error('Failed linking estimate #@eid to contract section: @msg', [
        '@eid' => $estimate->id(),
        '@msg' => $e->getMessage(),
      ]);
  }
}
