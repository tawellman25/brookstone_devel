<?php

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Url;

/**
 * Implements hook_entity_extra_field_info().
 */
function estimate_request_cards_entity_extra_field_info(): array {
  return [
    'estimate_request' => [
      'standard' => [
        'display' => [
          'owner_card' => [
            'label' => t('Owner Card'),
            'description' => t('Owner name, address, and phone.'),
            'weight' => 10,
            'visible' => TRUE,
          ],
          'contact_card' => [
            'label' => t('Contact Card'),
            'description' => t('Contact name, address, phone, and email.'),
            'weight' => 11,
            'visible' => TRUE,
          ],
          'property_actions' => [
            'label' => t('Property Actions'),
            'description' => t('Create Property button when property is not linked.'),
            'weight' => 12,
            'visible' => TRUE,
          ],
        ],
      ],
    ],
  ];
}

/**
 * Implements hook_entity_view().
 */
function estimate_request_cards_entity_view(
  array &$build,
  EntityInterface $entity,
  EntityViewDisplayInterface $display,
  string $view_mode
): void {
  if ($entity->getEntityTypeId() !== 'estimate_request') {
    return;
  }

  $entity_type_manager = \Drupal::entityTypeManager();

  // --- OWNER CARD ---
  if ($display->getComponent('owner_card')) {
    try {
      $owner_html = '';

      if (!$entity->get('field_owner')->isEmpty()) {
        $owner = $entity->get('field_owner')->entity;

        if ($owner) {
          // Load customer_profile.
          $profiles = $entity_type_manager->getStorage('profile')
            ->loadByProperties([
              'uid' => $owner->id(),
              'type' => 'customer_profile',
              'status' => 1,
            ]);
          $profile = $profiles ? reset($profiles) : NULL;

          // Name.
          $name = '';
          if ($profile) {
            $first = $profile->hasField('field_first_name') ? (string) $profile->get('field_first_name')->value : '';
            $last  = $profile->hasField('field_last_name')  ? (string) $profile->get('field_last_name')->value  : '';
            $name  = trim($first . ' ' . $last);
          }
          if (empty($name)) {
            $name = $owner->getDisplayName();
          }

          // Primary phone from phone_number.profile_phone_numbers via field_user.
          $phone = '';
          $phone_entities = $entity_type_manager->getStorage('phone_number')
            ->loadByProperties([
              'type' => 'profile_phone_numbers',
              'field_user' => $owner->id(),
            ]);
          foreach ($phone_entities as $pe) {
            if ($pe->hasField('field_primary_phone') && (bool) $pe->get('field_primary_phone')->value) {
              $phone = (string) $pe->get('field_phone_number')->value;
              break;
            }
          }
          if (empty($phone) && !empty($phone_entities)) {
            $first_phone = reset($phone_entities);
            $phone = (string) $first_phone->get('field_phone_number')->value;
          }

          // Mailing address from address.profile_mailing_addresses via field_user.
          $addr_line = $city = $state = $zip = '';
          $addresses = $entity_type_manager->getStorage('address')
            ->loadByProperties([
              'type' => 'profile_mailing_addresses',
              'field_user' => $owner->id(),
            ]);
          $addr_entity = NULL;
          foreach ($addresses as $ae) {
            if ($ae->hasField('field_primary_address') && (bool) $ae->get('field_primary_address')->value) {
              $addr_entity = $ae;
              break;
            }
          }
          if (!$addr_entity && !empty($addresses)) {
            $addr_entity = reset($addresses);
          }
          if ($addr_entity) {
            $addr_line = (string) $addr_entity->get('field_address')->value;
            $city      = (string) $addr_entity->get('field_city')->value;
            $state     = (string) $addr_entity->get('field_state')->value;
            $zip       = (string) $addr_entity->get('field_zipcode')->value;
          }

          // Fallback address from field_property.
          if (empty($addr_line) && !$entity->get('field_property')->isEmpty()) {
            $property = $entity->get('field_property')->entity;
            if ($property) {
              $addr_line = (string) $property->get('field_street_address')->value;
              if (!$property->get('field_zipcode_reference')->isEmpty()) {
                $zip_ref = $property->get('field_zipcode_reference')->entity;
                if ($zip_ref) {
                  $zip = (string) $zip_ref->get('field_zipcode')->value;
                  if ($zip_ref->hasField('field_city') && !$zip_ref->get('field_city')->isEmpty()) {
                    $city_entity = $zip_ref->get('field_city')->entity;
                    if ($city_entity && $city_entity->hasField('field_city_name')) {
                      $city = (string) $city_entity->get('field_city_name')->value;
                    }
                  }
                }
              }
            }
          }

          // Build HTML.
          $owner_html .= '<div class="er-card er-card--owner">';
          $owner_html .= '<h3 class="er-card__role">Owner</h3>';
          if ($name) {
            $owner_html .= '<div class="er-card__name">' . htmlspecialchars($name) . '</div>';
          }
          if ($addr_line) {
            $full_addr = $addr_line;
            $csz = trim($city . ', ' . $state . ' ' . $zip);
            if ($csz && $csz !== ',') {
              $full_addr .= ', ' . $csz;
            }
            $maps_url = 'https://www.google.com/maps/search/' . rawurlencode($full_addr);
            $owner_html .= '<div class="er-card__address">' . htmlspecialchars($addr_line);
            if ($city || $state || $zip) {
              $owner_html .= '<br>' . htmlspecialchars(trim($city . ', ' . $state . ' ' . $zip));
            }
            $owner_html .= ' <a href="' . htmlspecialchars($maps_url) . '" target="_blank" title="View on Google Maps"><i class="fa fa-map-marker-alt"></i></a>';
            $owner_html .= '</div>';
          }
          if ($phone) {
            $owner_html .= '<div class="er-card__phone">Primary Phone: ' . htmlspecialchars($phone) . '</div>';
          }
          $owner_html .= '</div>';
        }
      }

      $build['owner_card'] = [
        '#markup' => $owner_html ?: '<div class="er-card er-card--owner er-card--empty">No owner information available.</div>',
        '#weight' => 10,
      ];
    }
    catch (\Throwable $e) {
      \Drupal::logger('estimate_request_cards')->error('Owner card error: @msg', ['@msg' => $e->getMessage()]);
      $build['owner_card'] = ['#markup' => ''];
    }
  }

  // --- CONTACT CARD ---
  if ($display->getComponent('contact_card')) {
    try {
      $contact_html = '';
      $name = '';
      $email = '';
      $phone = '';
      $addr_line = '';
      $city = '';
      $state = '';
      $zip = '';

      // Try the linked contact entity first.
      if (!$entity->get('field_contact')->isEmpty()) {
        $contact = $entity->get('field_contact')->entity;

        if ($contact) {
          $first = $contact->hasField('field_first_name') ? (string) $contact->get('field_first_name')->value : '';
          $last  = $contact->hasField('field_last_name')  ? (string) $contact->get('field_last_name')->value  : '';
          $name  = trim($first . ' ' . $last);

          $email = $contact->hasField('field_email') ? (string) $contact->get('field_email')->value : '';

          if ($contact->hasField('field_phone_number') && !$contact->get('field_phone_number')->isEmpty()) {
            $first_phone = $contact->get('field_phone_number')->entity;
            if ($first_phone) {
              $phone = (string) $first_phone->get('field_phone_number')->value;
            }
          }

          if ($contact->hasField('field_address') && !$contact->get('field_address')->isEmpty()) {
            $addr_entity = $contact->get('field_address')->entity;
            if ($addr_entity) {
              $addr_line = (string) $addr_entity->get('field_address')->value;
              $city      = (string) $addr_entity->get('field_city')->value;
              $state     = (string) $addr_entity->get('field_state')->value;
              $zip       = (string) $addr_entity->get('field_zipcode')->value;
            }
          }
        }
      }

      // Fallback to requestor fields for any blanks.
      if (empty($name) && $entity->hasField('field_requestor_name') && !$entity->get('field_requestor_name')->isEmpty()) {
        $name = trim((string) $entity->get('field_requestor_name')->value);
      }
      if (empty($phone) && $entity->hasField('field_requestor_phone') && !$entity->get('field_requestor_phone')->isEmpty()) {
        $phone = trim((string) $entity->get('field_requestor_phone')->value);
      }
      if (empty($email) && $entity->hasField('field_requestor_email') && !$entity->get('field_requestor_email')->isEmpty()) {
        $email = trim((string) $entity->get('field_requestor_email')->value);
      }

      // Requestor address — used as fallback for contact address AND as
      // the property address when field_property is empty.
      $requestor_address = '';
      if ($entity->hasField('field_requestor_address') && !$entity->get('field_requestor_address')->isEmpty()) {
        $requestor_address = trim((string) $entity->get('field_requestor_address')->value);
      }

      // Build HTML.
      $has_anything = $name || $addr_line || $requestor_address || $phone || $email;

      if ($has_anything) {
        $contact_html .= '<div class="er-card er-card--contact">';
        $contact_html .= '<h3 class="er-card__role">Contact</h3>';

        if ($name) {
          $contact_html .= '<div class="er-card__name">' . htmlspecialchars($name) . '</div>';
        }

        // Contact entity address.
        if ($addr_line) {
          $full_addr = $addr_line;
          $csz = trim($city . ', ' . $state . ' ' . $zip);
          if ($csz && $csz !== ',') {
            $full_addr .= ', ' . $csz;
          }
          $maps_url = 'https://www.google.com/maps/search/' . rawurlencode($full_addr);
          $contact_html .= '<div class="er-card__address">';
          $contact_html .= htmlspecialchars($addr_line);
          if ($city || $state || $zip) {
            $contact_html .= '<br>' . htmlspecialchars(trim($city . ', ' . $state . ' ' . $zip));
          }
          $contact_html .= ' <a href="' . htmlspecialchars($maps_url) . '" target="_blank" title="View on Google Maps"><i class="fa fa-map-marker-alt"></i></a>';
          $contact_html .= '</div>';
        }

        // Requestor-supplied address (shown when property is not linked,
        // or as supplemental when contact has no address).
        if ($requestor_address && $requestor_address !== $addr_line) {
          $maps_url = 'https://www.google.com/maps/search/' . rawurlencode($requestor_address);
          $label = $entity->get('field_property')->isEmpty() ? 'Property Address (not yet in system)' : 'Requestor Address';
          $contact_html .= '<div class="er-card__requestor-address">';
          $contact_html .= '<strong>' . $label . ':</strong> ';
          $contact_html .= htmlspecialchars($requestor_address);
          $contact_html .= ' <a href="' . htmlspecialchars($maps_url) . '" target="_blank" title="View on Google Maps"><i class="fa fa-map-marker-alt"></i></a>';
          $contact_html .= '</div>';
        }

        if ($phone) {
          $contact_html .= '<div class="er-card__phone">Phone: ' . htmlspecialchars($phone) . '</div>';
        }
        if ($email) {
          $contact_html .= '<div class="er-card__email">Email: ' . htmlspecialchars($email) . '</div>';
        }
        $contact_html .= '</div>';
      }

      $build['contact_card'] = [
        '#markup' => $contact_html ?: '<div class="er-card er-card--contact er-card--empty">No contact information available.</div>',
        '#weight' => 11,
      ];
    }
    catch (\Throwable $e) {
      \Drupal::logger('estimate_request_cards')->error('Contact card error: @msg', ['@msg' => $e->getMessage()]);
      $build['contact_card'] = ['#markup' => ''];
    }
  }

  // --- PROPERTY ACTIONS ---
  if ($display->getComponent('property_actions')) {
    $property_actions_html = '';

    // Show "Create Property" button when property is not linked.
    $property_linked = $entity->hasField('field_property') && !$entity->get('field_property')->isEmpty();

    if (!$property_linked) {
      $create_url = Url::fromRoute('estimate.estimate_request_create_property', [
        'estimate_request' => $entity->id(),
      ]);

      if ($create_url->access()) {
        $has_address = $entity->hasField('field_requestor_address') && !$entity->get('field_requestor_address')->isEmpty();
        $button_label = $has_address ? 'Create Property from Address' : 'Create Property';

        $property_actions_html .= '<div class="er-property-actions">';
        $property_actions_html .= '<a href="' . $create_url->toString() . '" class="button button--primary">';
        $property_actions_html .= '<i class="fa fa-home"></i> ' . $button_label;
        $property_actions_html .= '</a>';
        $property_actions_html .= '</div>';
      }
    }

    $build['property_actions'] = [
      '#markup' => $property_actions_html,
      '#weight' => 12,
    ];
  }
}
