<?php

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_ENTITY_TYPE_presave() for the 'properties' entity type.
 *
 * Contact handling on property save:
 * 1. Deduplicate Additional Contacts (unique target_ids).
 * 2. Ensure the Primary Contact is not also in Additional Contacts.
 *
 * Note: Primary Contact is NOT auto-filled from the owner. Instead, the
 * property_contacts view shows the current owner's info as a live fallback
 * when field_primary_contact_ref is empty (see property_contacts preprocess).
 */
function properties_properties_presave(EntityInterface $entity): void {
  _properties_separate_primary_from_additional($entity);
}

/**
 * Deduplicates field_contacts and removes the primary contact from it.
 */
function _properties_separate_primary_from_additional(EntityInterface $property): void {
  if (!$property->hasField('field_contacts') || $property->get('field_contacts')->isEmpty()) {
    return;
  }

  $primary_id = 0;
  if ($property->hasField('field_primary_contact_ref') && !$property->get('field_primary_contact_ref')->isEmpty()) {
    $primary_id = (int) $property->get('field_primary_contact_ref')->target_id;
  }

  $seen = [];
  $clean = [];
  foreach ($property->get('field_contacts')->getValue() as $item) {
    $target = (int) ($item['target_id'] ?? 0);
    if ($target <= 0) {
      continue;
    }
    if ($target === $primary_id) {
      continue;
    }
    if (isset($seen[$target])) {
      continue;
    }
    $seen[$target] = TRUE;
    $clean[] = ['target_id' => $target];
  }

  $property->set('field_contacts', $clean);
}

/**
 * Implements hook_entity_insert().
 * Ensure a sprinkler info record exists when a Properties entity is created.
 */
function properties_entity_insert(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() === 'properties') {
    _properties_ensure_property_sprinkler_info($entity);
  }
}

/**
 * Implements hook_entity_update().
 * Ensure a sprinkler info record exists when a Properties entity is updated.
 */
function properties_entity_update(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() === 'properties') {
    _properties_ensure_property_sprinkler_info($entity);
  }
}

/**
 * Implements hook_preprocess_views_view().
 *
 * When the property_contacts view has no primary contact, render the
 * property's current owner info (name, phones, email) in the empty state
 * as a live fallback. Source of truth stays on the user/profile — no
 * data duplication.
 */
function properties_preprocess_views_view(array &$variables): void {
  $view = $variables['view'] ?? NULL;
  if (!$view || $view->id() !== 'property_contacts') {
    return;
  }

  // Only act when the view returned no primary contact rows.
  if (!empty($view->result)) {
    return;
  }

  // The view argument is the property ID.
  $args = $view->args ?? [];
  $property_id = (int) ($args[0] ?? 0);
  if ($property_id <= 0) {
    return;
  }

  $html = _properties_render_owner_fallback($property_id);
  if ($html === '') {
    return;
  }

  // Inject the fallback into the empty area so it replaces whatever empty
  // text is there (e.g. the "Set Primary Contact" button).
  $variables['empty'] = [
    '#markup' => $html,
    '#allowed_tags' => ['h4', 'h5', 'p', 'div', 'br', 'a', 'em', 'strong', 'span', 'button'],
  ];
}

/**
 * Builds the owner-as-primary-contact fallback HTML for a property.
 */
function _properties_render_owner_fallback(int $property_id): string {
  $etm = \Drupal::entityTypeManager();

  // Find the most recent ownership_record for this property.
  $or_ids = $etm->getStorage('ownership_record')->getQuery()
    ->accessCheck(FALSE)
    ->condition('field_property_reference', $property_id)
    ->sort('created', 'DESC')
    ->range(0, 1)
    ->execute();

  if (empty($or_ids)) {
    return _properties_owner_fallback_set_button($property_id);
  }

  $record = $etm->getStorage('ownership_record')->load(reset($or_ids));
  if (!$record || !$record->hasField('field_property_owner') || $record->get('field_property_owner')->isEmpty()) {
    return _properties_owner_fallback_set_button($property_id);
  }

  $owner_uid = (int) $record->get('field_property_owner')->target_id;
  if ($owner_uid <= 0) {
    return _properties_owner_fallback_set_button($property_id);
  }

  $user = $etm->getStorage('user')->load($owner_uid);
  if (!$user) {
    return _properties_owner_fallback_set_button($property_id);
  }

  // Try the customer_profile for name fields first; fall back to user label.
  $first = '';
  $last = '';
  $profile_ids = $etm->getStorage('profile')->getQuery()
    ->accessCheck(FALSE)
    ->condition('type', 'customer_profile')
    ->condition('uid', $owner_uid)
    ->range(0, 1)
    ->execute();

  if (!empty($profile_ids)) {
    $profile = $etm->getStorage('profile')->load(reset($profile_ids));
    if ($profile) {
      if ($profile->hasField('field_first_name')) {
        $first = trim((string) ($profile->get('field_first_name')->value ?? ''));
      }
      if ($profile->hasField('field_last_name')) {
        $last = trim((string) ($profile->get('field_last_name')->value ?? ''));
      }
    }
  }
  $name = trim($first . ' ' . $last);
  if ($name === '') {
    $name = (string) ($user->getDisplayName() ?? '');
  }

  // Owner phone numbers from phone_number.profile_phone_numbers.
  $phones = [];
  $phone_ids = $etm->getStorage('phone_number')->getQuery()
    ->accessCheck(FALSE)
    ->condition('type', 'profile_phone_numbers')
    ->condition('field_user', $owner_uid)
    ->execute();
  if (!empty($phone_ids)) {
    foreach ($etm->getStorage('phone_number')->loadMultiple($phone_ids) as $phone) {
      if ($phone->hasField('field_phone_number') && !$phone->get('field_phone_number')->isEmpty()) {
        $num = trim((string) $phone->get('field_phone_number')->value);
        if ($num !== '') {
          $phones[] = $num;
        }
      }
    }
  }

  $email = (string) ($user->getEmail() ?? '');

  $html = '<h4>Primary Contact</h4>';
  $html .= '<p style="margin:0 0 0.25em;color:#6c757d;font-size:0.85rem;font-style:italic;">Using Current Owner (no Primary Contact set)</p>';
  if ($name !== '') {
    $html .= '<strong>' . htmlspecialchars($name) . '</strong><br>';
  }
  foreach ($phones as $p) {
    $html .= htmlspecialchars($p) . '<br>';
  }
  if ($email !== '') {
    $html .= '<a href="mailto:' . htmlspecialchars($email) . '">' . htmlspecialchars($email) . '</a><br>';
  }
  $html .= '<p style="margin-top:0.5em;">' . _properties_owner_fallback_set_button($property_id) . '</p>';

  return $html;
}

/**
 * Returns the "Set Primary Contact" button HTML.
 */
function _properties_owner_fallback_set_button(int $property_id): string {
  return '<a class="button--primary button js-form-submit form-submit use-ajax"'
    . ' href="/admin/content/contacts/add/contact?bos_host=property&bos_host_id=' . $property_id
    . '&bos_field=field_primary_contact_ref&destination=/properties/' . $property_id . '"'
    . ' data-dialog-type="modal" data-dialog-options=\'{"width":"min(100%, 700px)"}\'>'
    . 'Set Primary Contact</a>';
}

/**
 * Ensure a property_sprinkler_info entity exists for the given Properties entity.
 *
 * Entity type: property_sprinkler_info
 * Bundle: general_information
 * Reference field: field_property (references properties)
 */
function _properties_ensure_property_sprinkler_info(EntityInterface $property): void {
  $property_id = $property->id();
  if (!$property_id) {
    return;
  }

  $storage = \Drupal::entityTypeManager()->getStorage('property_sprinkler_info');

  // Check whether a related sprinkler info entity already exists.
  $ids = $storage->getQuery()
    ->condition('field_property', $property_id)
    ->range(0, 1)
    ->accessCheck(FALSE)
    ->execute();

  // If one exists, do nothing.
  if (!empty($ids)) {
    return;
  }

  // Create new sprinkler info entity.
  $entity = $storage->create([
    'type' => 'general_information',
    'field_property' => [
      'target_id' => $property_id,
    ],
  ]);

  $entity->save();

  // Logging is optional, but useful.
  \Drupal::logger('properties')->notice(
    'Created property_sprinkler_info @sid for property @pid.',
    [
      '@sid' => $entity->id(),
      '@pid' => $property_id,
    ]
  );
}
