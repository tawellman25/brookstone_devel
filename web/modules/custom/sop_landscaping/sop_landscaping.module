<?php

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;

/**
 * @file
 * Registers Landscaping SOP code format and completeness rules.
 *
 * All validation (format, uniqueness, immutability, completeness) is handled
 * by sop_code_validation. This module only registers bundle-specific rules.
 */

/**
 * Implements hook_sop_code_validation_bundle_rules_alter().
 *
 * Register the Landscaping SOP code format.
 * Expected: LND-<TYPE>-<SEQUENCE>
 * Example:  LND-MOW-001
 */
function sop_landscaping_sop_code_validation_bundle_rules_alter(array &$rules): void {
  $rules['landscaping'] = [
    'regex' => '/^LND-[A-Z0-9]{2,20}-\d{3}$/',
    'example' => 'LND-MOW-001',
  ];
}

/**
 * Implements hook_sop_code_validation_missing_fields_alter().
 *
 * Require field_service for Landscaping SOPs when becoming locked.
 */
function sop_landscaping_sop_code_validation_missing_fields_alter(array &$missing, EntityInterface $entity): void {
  if ($entity->bundle() !== 'landscaping') {
    return;
  }

  if (!$entity->hasField('field_service') || $entity->get('field_service')->isEmpty()) {
    $missing[] = 'Service (field_service)';
  }
}
