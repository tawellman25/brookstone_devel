<?php

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;

/**
 * @file
 * Registers Lighting SOP code format and completeness rules.
 *
 * All validation (format, uniqueness, immutability, completeness) is handled
 * by sop_code_validation. This module only registers bundle-specific rules.
 */

/**
 * Implements hook_sop_code_validation_bundle_rules_alter().
 *
 * Register the Lighting SOP code format.
 * Expected: LGT-<TYPE>-<SEQUENCE>
 * Example:  LGT-EXT-001
 */
function sop_lighting_sop_code_validation_bundle_rules_alter(array &$rules): void {
  $rules['lighting'] = [
    'regex' => '/^LGT-[A-Z0-9]{2,20}-\d{3}$/',
    'example' => 'LGT-EXT-001',
  ];
}

/**
 * Implements hook_sop_code_validation_missing_fields_alter().
 *
 * Require field_service for Lighting SOPs when becoming locked.
 */
function sop_lighting_sop_code_validation_missing_fields_alter(array &$missing, EntityInterface $entity): void {
  if ($entity->bundle() !== 'lighting') {
    return;
  }

  if (!$entity->hasField('field_service') || $entity->get('field_service')->isEmpty()) {
    $missing[] = 'Service (field_service)';
  }
}
