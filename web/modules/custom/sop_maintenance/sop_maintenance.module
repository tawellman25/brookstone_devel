<?php

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;

/**
 * @file
 * Registers Maintenance SOP code format and completeness rules.
 *
 * All validation (format, uniqueness, immutability, completeness) is handled
 * by sop_code_validation. This module only registers bundle-specific rules.
 */

/**
 * Implements hook_sop_code_validation_bundle_rules_alter().
 *
 * Register the Maintenance SOP code format.
 * Expected: MNT-<TYPE>-<SEQUENCE>
 * Example:  MNT-LWN-001
 */
function sop_maintenance_sop_code_validation_bundle_rules_alter(array &$rules): void {
  $rules['maintenance'] = [
    'regex' => '/^MNT-[A-Z0-9]{2,20}-\d{3}$/',
    'example' => 'MNT-LWN-001',
  ];
}

/**
 * Implements hook_sop_code_validation_missing_fields_alter().
 *
 * Require field_service for Maintenance SOPs when becoming locked.
 */
function sop_maintenance_sop_code_validation_missing_fields_alter(array &$missing, EntityInterface $entity): void {
  if ($entity->bundle() !== 'maintenance') {
    return;
  }

  if (!$entity->hasField('field_service') || $entity->get('field_service')->isEmpty()) {
    $missing[] = 'Service (field_service)';
  }
}
