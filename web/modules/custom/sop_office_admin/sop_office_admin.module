<?php

declare(strict_types=1);

/**
 * @file
 * Registers Office Administration SOP code format with sop_code_validation.
 *
 * All validation (format, uniqueness, immutability, completeness) is handled
 * by sop_code_validation. This module only registers the bundle-specific regex.
 *
 * Previously this module implemented its own validation with an inconsistent
 * lock check (moderation_state / field_sop_approved / isPublished). That logic
 * has been removed; locking is now driven exclusively by field_sop_status
 * (consistent with sop_code_validation).
 */

/**
 * Implements hook_sop_code_validation_bundle_rules_alter().
 *
 * Register the Office Admin SOP code format.
 * Expected: OFF-ADM-<SERVICE>-<SEQUENCE>
 * Example:  OFF-ADM-QB-001
 */
function sop_office_admin_sop_code_validation_bundle_rules_alter(array &$rules): void {
  $rules['office_administration'] = [
    'regex' => '/^OFF-ADM-[A-Z0-9]{2,20}-\d{3}$/',
    'example' => 'OFF-ADM-QB-001',
  ];
}
