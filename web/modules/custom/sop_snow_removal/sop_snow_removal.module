<?php

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;

/**
 * @file
 * Registers Snow Removal SOP code format and completeness rules.
 *
 * All validation (format, uniqueness, immutability, completeness) is handled
 * by sop_code_validation. This module only registers bundle-specific rules.
 */

/**
 * Implements hook_sop_code_validation_bundle_rules_alter().
 *
 * Register the Snow Removal SOP code format.
 * Expected: SNW-<TYPE>-<SEQUENCE>
 * Example:  SNW-PLW-001
 */
function sop_snow_removal_sop_code_validation_bundle_rules_alter(array &$rules): void {
  $rules['snow_removal'] = [
    'regex' => '/^SNW-[A-Z0-9]{2,20}-\d{3}$/',
    'example' => 'SNW-PLW-001',
  ];
}

/**
 * Implements hook_sop_code_validation_missing_fields_alter().
 *
 * Require field_service for Snow Removal SOPs when becoming locked.
 */
function sop_snow_removal_sop_code_validation_missing_fields_alter(array &$missing, EntityInterface $entity): void {
  if ($entity->bundle() !== 'snow_removal') {
    return;
  }

  if (!$entity->hasField('field_service') || $entity->get('field_service')->isEmpty()) {
    $missing[] = 'Service (field_service)';
  }
}
