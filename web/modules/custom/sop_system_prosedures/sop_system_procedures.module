<?php

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\EntityStorageException;
use Drupal\Core\Form\FormStateInterface;

/**
 * @file
 * Validation helpers for SOP codes (System Procedures bundle).
 *
 * This module intentionally DOES NOT auto-generate SOP codes.
 * It enforces:
 * - Required format for System Procedures SOPs.
 * - Uniqueness across all SOP entities.
 * - Immutability after approval/publish.
 */

/**
 * System Procedures SOP code regex.
 *
 * Expected: WEB-SYS-<SERVICE>-<SEQUENCE>
 * Example:  WEB-SYS-CFG-001
 */
const SOP_SYSTEM_PROCEDURES_CODE_REGEX = '/^WEB-SYS-[A-Z0-9]{2,20}-\d{3}$/';

/**
 * Entity/bundle targeting.
 */
const SOP_SYSTEM_PROCEDURES_ENTITY_TYPE = 'sop';
const SOP_SYSTEM_PROCEDURES_BUNDLE = 'system_procedures';

/**
 * Implements hook_form_alter().
 *
 * Attach validation broadly (works even if form IDs differ).
 */
function sop_system_procedures_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $form_object = $form_state->getFormObject();
  if (!is_object($form_object) || !method_exists($form_object, 'getEntity')) {
    return;
  }

  $entity = $form_object->getEntity();
  if (!$entity instanceof EntityInterface) {
    return;
  }

  if ($entity->getEntityTypeId() !== SOP_SYSTEM_PROCEDURES_ENTITY_TYPE || $entity->bundle() !== SOP_SYSTEM_PROCEDURES_BUNDLE) {
    return;
  }

  $form['#validate'][] = 'sop_system_procedures_validate_sop_code';
}

/**
 * Back-compat: if your form ID is exactly this, still works.
 */
function sop_system_procedures_form_sop_system_procedures_form_alter(array &$form, FormStateInterface $form_state): void {
  $form['#validate'][] = 'sop_system_procedures_validate_sop_code';
}

/**
 * Form validation callback: enforce SOP code rules.
 */
function sop_system_procedures_validate_sop_code(array &$form, FormStateInterface $form_state): void {
  $entity = $form_state->getFormObject()->getEntity();
  if (!$entity instanceof EntityInterface) {
    return;
  }

  if ($entity->getEntityTypeId() !== SOP_SYSTEM_PROCEDURES_ENTITY_TYPE || $entity->bundle() !== SOP_SYSTEM_PROCEDURES_BUNDLE) {
    return;
  }

  $code = sop_system_procedures_get_sop_code_value($entity);
  if ($code === '') {
    $form_state->setErrorByName('field_sop_code', t('SOP Code is required.'));
    return;
  }

  $code_norm = strtoupper(trim($code));

  // Format validation.
  if (!preg_match(SOP_SYSTEM_PROCEDURES_CODE_REGEX, $code_norm)) {
    $form_state->setErrorByName(
      'field_sop_code',
      t('Invalid SOP Code format. System Procedures SOP codes must match WEB-SYS-<SERVICE>-<SEQUENCE> (example: WEB-SYS-CFG-001). Use uppercase letters/numbers; sequence must be 3 digits.')
    );
    return;
  }

  // Uniqueness validation (across all SOP entities).
  if (!sop_system_procedures_is_sop_code_unique($code_norm, $entity)) {
    $form_state->setErrorByName('field_sop_code', t('That SOP Code is already in use. SOP Codes must be unique.'));
    return;
  }

  // Immutability after approval/publish (prevent changes).
  if (sop_system_procedures_is_locked($entity) && sop_system_procedures_sop_code_changed($entity, $code_norm)) {
    $form_state->setErrorByName('field_sop_code', t('SOP Code cannot be changed after the SOP is approved/published.'));
    return;
  }
}

/**
 * Implements hook_entity_presave().
 *
 * Safety net so code cannot be altered via API/import once locked.
 */
function sop_system_procedures_entity_presave(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== SOP_SYSTEM_PROCEDURES_ENTITY_TYPE || $entity->bundle() !== SOP_SYSTEM_PROCEDURES_BUNDLE) {
    return;
  }

  $code = sop_system_procedures_get_sop_code_value($entity);
  $code_norm = strtoupper(trim($code));

  if ($code_norm === '' || !preg_match(SOP_SYSTEM_PROCEDURES_CODE_REGEX, $code_norm)) {
    throw new EntityStorageException('Invalid or missing SOP Code for System Procedures SOP. Expected WEB-SYS-<SERVICE>-<SEQUENCE> (example: WEB-SYS-CFG-001).');
  }

  if (!sop_system_procedures_is_sop_code_unique($code_norm, $entity)) {
    throw new EntityStorageException('Duplicate SOP Code detected. SOP Codes must be unique.');
  }

  if (sop_system_procedures_is_locked($entity) && sop_system_procedures_sop_code_changed($entity, $code_norm)) {
    throw new EntityStorageException('SOP Code cannot be changed after the SOP is approved/published.');
  }
}

/**
 * Get SOP code field value safely.
 */
function sop_system_procedures_get_sop_code_value(EntityInterface $entity): string {
  if (!$entity->hasField('field_sop_code')) {
    return '';
  }
  $value = $entity->get('field_sop_code')->value;
  return is_string($value) ? $value : '';
}

/**
 * Check if SOP code is unique across SOP entities, excluding current entity.
 */
function sop_system_procedures_is_sop_code_unique(string $code_norm, EntityInterface $entity): bool {
  $query = \Drupal::entityQuery(SOP_SYSTEM_PROCEDURES_ENTITY_TYPE)
    ->accessCheck(FALSE)
    ->condition('field_sop_code', $code_norm);

  if (!$entity->isNew() && $entity->id() !== NULL) {
    $query->condition('id', (int) $entity->id(), '<>');
  }

  $ids = $query->range(0, 1)->execute();
  return empty($ids);
}

/**
 * Determine whether this SOP is locked (approved/published).
 *
 * Supports either:
 * - content moderation field "moderation_state" with a state like "approved" or "published"
 * - a boolean field "field_sop_approved" (true = locked)
 * - published status (fallback)
 */
function sop_system_procedures_is_locked(EntityInterface $entity): bool {
  if ($entity->hasField('moderation_state')) {
    $state = (string) $entity->get('moderation_state')->value;
    $state = strtolower(trim($state));
    if (in_array($state, ['approved', 'published'], TRUE)) {
      return TRUE;
    }
  }

  if ($entity->hasField('field_sop_approved')) {
    return (bool) $entity->get('field_sop_approved')->value;
  }

  if (method_exists($entity, 'isPublished')) {
    return (bool) $entity->isPublished();
  }

  return FALSE;
}

/**
 * Detect if SOP code changed compared to the stored/original entity.
 */
function sop_system_procedures_sop_code_changed(EntityInterface $entity, string $code_norm): bool {
  if ($entity->isNew()) {
    return FALSE;
  }

  if (isset($entity->original) && $entity->original instanceof EntityInterface) {
    $orig_code = sop_system_procedures_get_sop_code_value($entity->original);
    $orig_norm = strtoupper(trim($orig_code));
    return $orig_norm !== $code_norm;
  }

  if ($entity->id() !== NULL) {
    $stored = \Drupal::entityTypeManager()->getStorage($entity->getEntityTypeId())->load($entity->id());
    if ($stored instanceof EntityInterface) {
      $orig_code = sop_system_procedures_get_sop_code_value($stored);
      $orig_norm = strtoupper(trim($orig_code));
      return $orig_norm !== $code_norm;
    }
  }

  return FALSE;
}
