<?php

/**
 * @file
 * Supplier Price Ingest — Phase 3.2.
 *
 * Phase 3.1 shipped the data-model foundation only. Phase 3.2 adds:
 *   - hook_ENTITY_TYPE_presave for supplier_ingest_config:
 *       * uniqueness (one config per supplier)
 *       * JSON shape validation for field_column_mapping and
 *         field_bundle_policy
 *   - hook_form_alter for the supplier_ingest_config edit form:
 *       * JSON-shape help on the two JSON textareas
 *       * marker class so verifiers can assert plain textarea (vs CKE)
 *       * hide uid / created / pathauto noise
 *       * pre-submit guard for JSON-decode errors
 *   - hook_theme for the placeholder batch view template
 *
 * Matching (3.3), dry-run UI (3.5), commit logic (3.6), and dashboards
 * (3.7) still ahead.
 *
 * See __BOS_AI/Architecture/supplier_pricing_pipeline_phase2.md and
 * __BOS_AI/Architecture/supplier_pricing_pipeline_phase3_sequencing.md.
 */

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\EntityStorageException;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\supplier_price_ingest\Service\IngestParser;

const SUPPLIER_PRICE_INGEST_BUNDLE_POLICY_VALUES = [
  'matched_only',
  'discovery',
  'both',
  'excluded',
];

// Phase 3.7 had a "Load default bundle policy" button and a "Load
// SiteOne column mapping" button next to the two JSON textareas.
// Both buttons are removed in the 2026-05-25 follow-up — Office staff
// paste the JSON directly from Claude Chat output, which is faster
// than maintaining the button-mediated workflow and avoids the
// Drupal-form-rebuild-doesn't-update-textarea trap (documented in
// __BOS_AI/Governance/drupal_bos_gotchas.md "Form-state setValue
// alone doesn't update field-widget textareas on rebuild" — the
// notes from the failed fix attempt are kept for future reference).
// The default bundle policy + SiteOne column mapping seed values
// live in the governance docs as copy-pasteable JSON snippets.

/**
 * Implements hook_theme().
 *
 * Phase 3.5 — single theme hook for the batch detail / dry-run report.
 * Replaces the Phase 3.2 placeholder theme hook
 * (`supplier_price_ingest_batch_placeholder`). The placeholder template
 * and BatchPlaceholderController class were removed in 3.5.
 */
function supplier_price_ingest_theme(): array {
  return [
    'supplier_price_ingest_batch_detail' => [
      'variables' => [
        'header' => [],
        'status' => '',
        'actions' => [],
        'report' => NULL,
        'auto_refresh_seconds' => NULL,
        'failure_report' => NULL,
        'rejection_reason' => NULL,
      ],
      'template' => 'supplier-price-ingest-batch-detail',
    ],
  ];
}

/**
 * Implements hook_ENTITY_TYPE_presave() for supplier_ingest_config.
 *
 * Enforces:
 *   1. One supplier_ingest_config per supplier (uniqueness).
 *   2. field_column_mapping JSON shape + target-field whitelist.
 *   3. field_bundle_policy JSON shape + key/value whitelist.
 *
 * Throws EntityStorageException with a single human-readable message.
 * Form layer (supplier_price_ingest_form_alter) catches and surfaces.
 */
function supplier_price_ingest_supplier_ingest_config_presave(EntityInterface $entity): void {
  _supplier_price_ingest_validate_uniqueness($entity);
  _supplier_price_ingest_validate_column_mapping($entity);
  _supplier_price_ingest_validate_bundle_policy($entity);
  _supplier_price_ingest_validate_sku_transformations($entity);
}

/**
 * Throws if another supplier_ingest_config exists with the same
 * field_supplier (excluding the entity being saved).
 */
function _supplier_price_ingest_validate_uniqueness(EntityInterface $entity): void {
  $supplierId = (int) ($entity->get('field_supplier')->target_id ?? 0);
  if ($supplierId <= 0) {
    // Required-field validation on field_supplier will catch this in
    // form context; presave here just ensures we don't false-positive
    // on a not-yet-set reference.
    return;
  }
  $existing = \Drupal::entityTypeManager()
    ->getStorage('supplier_ingest_config')
    ->loadByProperties(['field_supplier' => $supplierId]);
  foreach ($existing as $other) {
    if ($entity->isNew() || (int) $other->id() !== (int) $entity->id()) {
      throw new EntityStorageException(sprintf(
        'A supplier_ingest_config already exists for this supplier (existing config id=%d). One config per supplier is the invariant; edit the existing config instead.',
        $other->id(),
      ));
    }
  }
}

/**
 * Validates field_column_mapping JSON shape.
 *
 * Allows the field to be empty (incremental edits welcome) — but if
 * present, it must be valid JSON with at minimum:
 *   - source_columns: object
 *   - all source_columns values are in IngestParser::ALLOWED_ROW_FIELDS
 *   - at least one identifier field mapped
 *   - field_unit_cost mapped
 */
function _supplier_price_ingest_validate_column_mapping(EntityInterface $entity): void {
  $raw = (string) ($entity->get('field_column_mapping')->value ?? '');
  if ($raw === '') {
    return;
  }
  $decoded = json_decode($raw, TRUE);
  if (!is_array($decoded)) {
    throw new EntityStorageException(sprintf(
      'field_column_mapping is not valid JSON: %s',
      json_last_error_msg(),
    ));
  }
  if (!isset($decoded['source_columns']) || !is_array($decoded['source_columns'])) {
    throw new EntityStorageException(
      'field_column_mapping must contain a "source_columns" object mapping CSV header strings to BOS row field names.',
    );
  }
  $allowed = IngestParser::ALLOWED_ROW_FIELDS;
  $identifierFields = IngestParser::IDENTIFIER_FIELDS;

  // Per-header destination is either a string (1:1) or an array of
  // strings (1:many). Both shapes are valid; mixed shapes across
  // headers are also allowed.
  $mappedTargets = [];
  foreach ($decoded['source_columns'] as $header => $target) {
    if (is_array($target)) {
      if ($target === []) {
        throw new EntityStorageException(sprintf(
          'field_column_mapping source_columns["%s"] is an empty array. A destination must name at least one BOS field, e.g. ["field_supplier_sku","field_manufacturer_item_number"].',
          $header,
        ));
      }
      foreach ($target as $t) {
        if (!is_string($t) || $t === '' || !in_array($t, $allowed, TRUE)) {
          throw new EntityStorageException(sprintf(
            'field_column_mapping source_columns["%s"] array contains invalid entry "%s". Each entry must be a non-empty string in: %s',
            $header,
            is_scalar($t) ? (string) $t : gettype($t),
            implode(', ', $allowed),
          ));
        }
        $mappedTargets[] = $t;
      }
      continue;
    }
    if (!is_string($target) || !in_array($target, $allowed, TRUE)) {
      throw new EntityStorageException(sprintf(
        'field_column_mapping source_columns["%s"] = "%s" is not a valid supplier_price_ingest_row field. Allowed: %s (or an array of those names for 1:many destinations).',
        $header,
        is_scalar($target) ? (string) $target : gettype($target),
        implode(', ', $allowed),
      ));
    }
    $mappedTargets[] = $target;
  }
  $hasIdentifier = !empty(array_intersect($identifierFields, $mappedTargets));
  if (!$hasIdentifier) {
    throw new EntityStorageException(sprintf(
      'field_column_mapping must map at least one identifier column to one of: %s',
      implode(', ', $identifierFields),
    ));
  }
  if (!in_array('field_unit_cost', $mappedTargets, TRUE)) {
    throw new EntityStorageException(
      'field_column_mapping must map a column to field_unit_cost.',
    );
  }
}

/**
 * Validates field_bundle_policy JSON shape.
 *
 * Allows empty (defaults to matched_only for every bundle at runtime).
 * If present:
 *   - valid JSON object
 *   - every key is a real material bundle machine name
 *   - every value is in SUPPLIER_PRICE_INGEST_BUNDLE_POLICY_VALUES
 */
function _supplier_price_ingest_validate_bundle_policy(EntityInterface $entity): void {
  $raw = (string) ($entity->get('field_bundle_policy')->value ?? '');
  if ($raw === '') {
    return;
  }
  $decoded = json_decode($raw, TRUE);
  if (!is_array($decoded)) {
    throw new EntityStorageException(sprintf(
      'field_bundle_policy is not valid JSON: %s',
      json_last_error_msg(),
    ));
  }
  $bundleInfo = \Drupal::service('entity_type.bundle.info')->getBundleInfo('material');
  $materialBundles = array_keys($bundleInfo);
  $allowedValues = SUPPLIER_PRICE_INGEST_BUNDLE_POLICY_VALUES;
  foreach ($decoded as $bundle => $policy) {
    if (!in_array($bundle, $materialBundles, TRUE)) {
      throw new EntityStorageException(sprintf(
        'field_bundle_policy key "%s" is not a valid material bundle. Valid bundles: %s',
        $bundle,
        implode(', ', $materialBundles),
      ));
    }
    if (!is_string($policy) || !in_array($policy, $allowedValues, TRUE)) {
      throw new EntityStorageException(sprintf(
        'field_bundle_policy["%s"] = "%s" is not an allowed policy. Allowed: %s',
        $bundle,
        is_scalar($policy) ? (string) $policy : gettype($policy),
        implode(', ', $allowedValues),
      ));
    }
  }
}

/**
 * Validates field_sku_transformations JSON shape.
 *
 * Allows empty (no transformations). If present:
 *   - Valid JSON object
 *   - Recognized top-level keys only: strip_prefix, strip_suffix
 *     (both optional; unrecognized keys throw)
 *   - Each value must be an array of strings (not nested objects,
 *     not bare strings)
 *   - Empty arrays are valid
 */
function _supplier_price_ingest_validate_sku_transformations(EntityInterface $entity): void {
  if (!$entity->hasField('field_sku_transformations')) {
    return;
  }
  $raw = (string) ($entity->get('field_sku_transformations')->value ?? '');
  if ($raw === '') {
    return;
  }
  $decoded = json_decode($raw, TRUE);
  if (!is_array($decoded)) {
    throw new EntityStorageException(sprintf(
      'field_sku_transformations is not valid JSON: %s',
      json_last_error_msg(),
    ));
  }
  $allowedKeys = ['strip_prefix', 'strip_suffix'];
  foreach ($decoded as $key => $value) {
    if (!in_array($key, $allowedKeys, TRUE)) {
      throw new EntityStorageException(sprintf(
        'field_sku_transformations key "%s" is not recognized. Allowed: %s.',
        $key,
        implode(', ', $allowedKeys),
      ));
    }
    if (!is_array($value)) {
      throw new EntityStorageException(sprintf(
        'field_sku_transformations["%s"] must be an array (got %s).',
        $key,
        gettype($value),
      ));
    }
    foreach ($value as $idx => $item) {
      if (!is_string($item)) {
        throw new EntityStorageException(sprintf(
          'field_sku_transformations["%s"][%s] must be a string (got %s).',
          $key,
          (string) $idx,
          gettype($item),
        ));
      }
    }
  }
}

/**
 * Implements hook_form_alter().
 *
 * Targets the supplier_ingest_config entity edit/add form to:
 *   - Add inline help with the JSON shape on each JSON textarea
 *   - Tag each JSON textarea with a marker class for verifier checks
 *   - Hide author / created / pathauto-alias noise from office users
 *   - Pre-submit-guard to surface JSON-decode errors on the right field
 */
function supplier_price_ingest_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (!str_starts_with($form_id, 'supplier_ingest_config_')) {
    return;
  }

  // Both JSON fields are string_long (converted from text_long in the
  // 2026-05-25 fix) so their widget is a plain textarea — no format
  // selector, no CKEditor. See __BOS_AI/Governance/drupal_bos_gotchas.md
  // "text_long vs string_long for structured-text fields" for why.
  //
  // What this hook does:
  //   * Append JSON-shape help to each field's description so users
  //     know what valid input looks like
  //   * Apply a marker CSS class to each textarea so verifiers can
  //     assert "plain textarea, not CKEditor"
  //   * Hide uid / created / pathauto noise from office users
  //   * Register a pre-submit guard that surfaces JSON-decode errors
  //     against the correct field
  //
  // The Phase 3.7 "Load default bundle policy" and "Load SiteOne
  // column mapping" seed buttons were removed in the 2026-05-25
  // follow-up — Office staff paste JSON directly from Chat output
  // which is faster than maintaining button-mediated population. The
  // seed JSON lives in governance docs as copy-pasteable snippets.
  $jsonTextareaClass = 'supplier-price-ingest-json-textarea';

  if (isset($form['field_column_mapping']['widget'][0]['value'])) {
    $existing = (string) ($form['field_column_mapping']['widget'][0]['value']['#description'] ?? '');
    $form['field_column_mapping']['widget'][0]['value']['#description'] = $existing
      . '<br><strong>JSON shape (Phase 3.2):</strong> see <code>__BOS_AI/Entities/supplier_ingest_config.md</code>. Required keys: <code>source_columns</code> (object mapping CSV headers → BOS row field names). Allowed BOS fields: <code>'
      . implode('</code>, <code>', IngestParser::ALLOWED_ROW_FIELDS)
      . '</code>. Must map at least one identifier (supplier SKU, mfr item #, or description) and <code>field_unit_cost</code>.';
    $form['field_column_mapping']['widget'][0]['value']['#attributes']['class'][] = $jsonTextareaClass;
  }

  if (isset($form['field_bundle_policy']['widget'][0]['value'])) {
    $existing = (string) ($form['field_bundle_policy']['widget'][0]['value']['#description'] ?? '');
    $form['field_bundle_policy']['widget'][0]['value']['#description'] = $existing
      . '<br><strong>JSON shape:</strong> object mapping material bundle machine names to policy values (<code>matched_only</code>, <code>discovery</code>, <code>both</code>, <code>excluded</code>). Default for unlisted bundles: <code>matched_only</code>. See <code>__BOS_AI/Entities/supplier_ingest_config.md</code> for a copy-pasteable seed.';
    $form['field_bundle_policy']['widget'][0]['value']['#attributes']['class'][] = $jsonTextareaClass;
  }

  // Hide author / created / URL-alias fields from office users —
  // uid + created are populated automatically on entity save; pathauto
  // generates the alias from field_supplier per the Phase 3.1 pattern.
  // Office staff editing supplier configs don't need to see any of these.
  foreach (['uid', 'created', 'path'] as $noise) {
    if (isset($form[$noise])) {
      $form[$noise]['#access'] = FALSE;
    }
  }

  // Pre-submit guard to surface JSON errors on the right field.
  if (isset($form['actions']['submit']['#submit'])) {
    array_unshift($form['actions']['submit']['#submit'], '_supplier_price_ingest_pre_submit_guard');
  }
}

/**
 * Pre-submit guard: surface JSON-decode errors on the source field.
 *
 * Presave hook still backstops; this is purely a better-UX layer.
 */
function _supplier_price_ingest_pre_submit_guard(array &$form, FormStateInterface $form_state): void {
  $colMap = (string) ($form_state->getValue(['field_column_mapping', 0, 'value']) ?? '');
  if ($colMap !== '') {
    $decoded = json_decode($colMap, TRUE);
    if (!is_array($decoded)) {
      $form_state->setErrorByName(
        'field_column_mapping',
        sprintf('Invalid JSON in Column Mapping: %s', json_last_error_msg()),
      );
    }
  }
  $bundlePol = (string) ($form_state->getValue(['field_bundle_policy', 0, 'value']) ?? '');
  if ($bundlePol !== '') {
    $decoded = json_decode($bundlePol, TRUE);
    if (!is_array($decoded)) {
      $form_state->setErrorByName(
        'field_bundle_policy',
        sprintf('Invalid JSON in Bundle Policy: %s', json_last_error_msg()),
      );
    }
  }
}

/**
 * Implements hook_entity_operation().
 *
 * Injects per-row review-queue operations for supplier_price_ingest_row
 * entities. The set of operations is gated by the row's match-tier so the
 * dropdown only ever shows the ops applicable to that row's review path:
 *
 *   - discovery rows (field_match_tier=discovery) get the four discovery
 *     ops (create / link / mark-as-replacement / reject).
 *   - fuzzy_med rows (field_match_tier=tier_3_fuzzy_med, including
 *     Tier-1-ambiguous rows the matcher reroutes there) get the four
 *     fuzzy ops (confirm / override / send-to-discovery / reject).
 *
 * Rows in any other state (auto-applied, errored, already resolved) get
 * no custom ops. Views' entity_operations field plugin renders the
 * returned array as the native Drupal admin dropdown.
 *
 * Wired up to:
 *   - views.view.supplier_ingest_discovery_queue (Discovery Queue)
 *   - views.view.supplier_ingest_fuzzy_review (Fuzzy Match Review)
 */
function supplier_price_ingest_entity_operation(EntityInterface $entity): array {
  if ($entity->getEntityTypeId() !== 'supplier_price_ingest_row') {
    return [];
  }
  $tier = (string) ($entity->get('field_match_tier')->value ?? '');
  $status = (string) ($entity->get('field_row_status')->value ?? '');
  if ($status !== 'discovery_pending') {
    return [];
  }

  // Phase 3.7.5 iteration 2 (2026-05-31) — single "Resolve →" entry
  // for the unified ResolveRowForm. Replaces the 4-button-per-row
  // dropdown that was here previously. The 4 legacy per-operation
  // routes are still callable via direct URL (deep-link fallback);
  // they just don't appear in the queue's Operations column anymore.
  if ($tier === 'discovery'
      || $tier === 'tier_3_fuzzy_med'
      || $tier === 'tier_1_5_title_substring') {
    return [
      'resolve' => [
        'title'  => t('Resolve →'),
        'url'    => Url::fromRoute('supplier_price_ingest.resolve_row', ['supplier_price_ingest_row' => $entity->id()]),
        'weight' => 10,
      ],
    ];
  }

  return [];
}

