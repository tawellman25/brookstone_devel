{#
/**
 * @file
 * Phase 3.2 placeholder view for a supplier_price_ingest_batch.
 *
 * Available variables:
 * - batch:    array of batch metadata (see BatchPlaceholderController::view)
 * - rows:     array of up to 10 sample rows
 */
#}
<div class="supplier-price-ingest-batch-placeholder">
  <div class="messages messages--status">
    Phase 3.2 placeholder. Full dry-run review UI ships in 3.5.
  </div>

  <h2>Batch Metadata</h2>
  <table class="responsive-enabled">
    <tbody>
      <tr><th>Batch ID</th><td>{{ batch.id }}</td></tr>
      <tr><th>Title</th><td>{{ batch.title }}</td></tr>
      <tr><th>Status</th><td><strong>{{ batch.status }}</strong></td></tr>
      <tr><th>Supplier</th><td>{{ batch.supplier }}</td></tr>
      <tr><th>Source file</th>
        <td>
          {% if batch.source_file_url %}
            <a href="{{ batch.source_file_url }}">{{ batch.source_filename }}</a>
          {% else %}
            {{ batch.source_filename }}
          {% endif %}
        </td>
      </tr>
      <tr><th>Uploaded by</th><td>{{ batch.uploaded_by }}</td></tr>
      <tr><th>Uploaded on</th><td>{{ batch.uploaded_on }}</td></tr>
      <tr><th>Rows created</th><td>{{ batch.actual_row_count }}</td></tr>
      <tr><th>Rows skipped (no identifier / no cost)</th><td>{{ batch.row_count_skipped }}</td></tr>
      <tr><th>Rows errored (parse problem)</th><td>{{ batch.errored_count }}</td></tr>
      {% if batch.notes %}
        <tr><th>Notes</th><td>{{ batch.notes|nl2br }}</td></tr>
      {% endif %}
    </tbody>
  </table>

  {% if batch.status == 'failed' and batch.dry_run_report %}
    <h2>Parse Failure Detail</h2>
    <pre style="background:#fef0f0; padding:1em; border-left:4px solid #b71c1c; overflow:auto;">{{ batch.dry_run_report }}</pre>
  {% endif %}

  <h2>Sample Rows (first 10)</h2>
  {% if rows is empty %}
    <p><em>No rows persisted for this batch yet. (Either the parse hasn't run, or the file produced zero usable rows.)</em></p>
  {% else %}
    <table class="responsive-enabled">
      <thead>
        <tr>
          <th>#</th>
          <th>Supplier SKU</th>
          <th>Mfr Item #</th>
          <th>Description</th>
          <th>Unit Cost</th>
          <th>UOM</th>
          <th>Match Tier</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        {% for r in rows %}
          <tr>
            <td>{{ r.row_number }}</td>
            <td>{{ r.supplier_sku }}</td>
            <td>{{ r.mfr_item }}</td>
            <td>{{ r.description }}</td>
            <td>{{ r.unit_cost }}</td>
            <td>{{ r.cost_uom }}</td>
            <td>
              {% if r.match_tier == 'error' %}
                <strong style="color:#b71c1c;">ERROR</strong>
              {% else %}
                {{ r.match_tier ?: '—' }}
              {% endif %}
            </td>
            <td>{{ r.resolution_notes|nl2br }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
</div>
