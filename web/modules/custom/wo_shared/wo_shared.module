<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\EntityStorageException;

/**
 * Maps WO bundles to their property_spraying_info bundle equivalent.
 *
 * Only bundles that have a corresponding property_spraying_info type
 * are included here.
 */
function _wo_shared_get_spraying_info_bundle_map(): array {
  return [
    'pre_emergent'           => 'pre_emergent',
    'weed_spraying'          => 'weed_spraying',
    'aspen_twig_gall'        => 'aspen_twig_gall',
    'cooley_spruce_gall'     => 'cooley_spruce',
    'deciduous_bore'         => 'deciduous_bore',
    'dormant_oil'            => 'dormant_oil',
    'grub_prevention'        => 'grub_prevention',
    'pinion_pine_ips_beetle' => 'ips_beetle',
    'trunk_bore'             => 'trunk_bore',
    'deer_prevention'        => NULL,
  ];
}

/**
 * Implements hook_entity_insert().
 *
 * When a spray-related Work Order is created, ensure a matching
 * property_spraying_info record exists for the property.
 * Creates a bare record if one doesn't exist.
 * Never overwrites an existing record.
 */
function wo_shared_entity_insert(EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'work_order') {
    return;
  }

  $bundle = $entity->bundle();
  $map = _wo_shared_get_spraying_info_bundle_map();

  if (!array_key_exists($bundle, $map)) {
    return;
  }

  $spraying_info_bundle = $map[$bundle];
  if ($spraying_info_bundle === NULL) {
    return;
  }

  $property_id = $entity->get('field_property')->target_id ?? NULL;
  if (!$property_id) {
    return;
  }

  $existing = \Drupal::entityTypeManager()
    ->getStorage('property_spraying_info')
    ->loadByProperties([
      'type'           => $spraying_info_bundle,
      'field_property' => $property_id,
    ]);

  if (!empty($existing)) {
    return;
  }

  $record = \Drupal::entityTypeManager()
    ->getStorage('property_spraying_info')
    ->create([
      'type'           => $spraying_info_bundle,
      'field_property' => $property_id,
    ]);
  $record->save();

  \Drupal::logger('wo_shared')->notice(
    'Auto-created property_spraying_info:@bundle for property @pid on WO @woid insert.',
    [
      '@bundle' => $spraying_info_bundle,
      '@pid'    => $property_id,
      '@woid'   => $entity->id(),
    ]
  );
}

/**
 * Implements hook_ENTITY_TYPE_presave() for work_order entities.
 *
 * Recalculates field_total_time = sum(wo_time_clock.field_total_time)
 * for the WO's closed clock entries, but only while the WO is in
 * Complete status (1097):
 *   - Pre-completion WOs are skipped — clock data is mid-flight and a
 *     partial total would mislead.
 *   - Invoiced (1281), Paid (1504), Canceled (1098), and Warrantied
 *     (1283) are skipped implicitly because they're not Complete — the
 *     captured-at-billing-time value is preserved once the WO leaves
 *     the Complete state.
 *
 * Pairs with wo_total_time's _wo_total_time_trigger_wo_recalc(): that
 * helper saves the parent WO whenever a wo_time_clock entry is
 * inserted/updated, which then flows through this hook to refresh the
 * roll-up. The combined chain means editing a clock entry on a
 * Complete WO will produce a refreshed total without anyone needing
 * to manually re-save the WO.
 *
 * For lawn_mowing WOs, wo_lawn_mowing also recalculates field_total_time
 * (alongside field_labor_total and other bundle-specific derived
 * fields). Both produce the same value here — sum of clock entries, no
 * multiplier — so the redundancy is idempotent.
 */
function wo_shared_work_order_presave(EntityInterface $entity) {
  // Guard runs before the recalc: an invalid status transition halts
  // the save via EntityStorageException before any totals are touched.
  _wo_shared_assert_invoiced_transition_valid($entity);

  if ($entity->isNew()) {
    return;
  }
  if (!$entity->hasField('field_total_time')) {
    return;
  }
  $status = (int) ($entity->get('field_status')->target_id ?? 0);
  if ($status !== 1097) {
    return;
  }

  $tcIds = \Drupal::entityQuery('wo_time_clock')
    ->accessCheck(FALSE)
    ->condition('field_work_order', $entity->id())
    ->condition('field_end_time', NULL, 'IS NOT NULL')
    ->execute();

  $sum = 0.0;
  if ($tcIds) {
    foreach (\Drupal::entityTypeManager()->getStorage('wo_time_clock')->loadMultiple($tcIds) as $tc) {
      $sum += (float) ($tc->get('field_total_time')->value ?? 0);
    }
  }

  $entity->set('field_total_time', round($sum, 2));
}

/**
 * Block any work_order save that transitions field_status to Invoiced
 * (1281) without the prior status having been Complete (1097).
 *
 * Catches the recurring "office invoices before crew signs off" mistake
 * — the orphan clock entry and incomplete wo_tasks_list left behind by
 * a premature Invoiced transition blocks the crew from creating new
 * mowing WOs (see WO 49892 — three crew members stuck on 2026-05-13).
 *
 * Allowed transitions:
 *   - any status -> any non-Invoiced status (1281)
 *   - Complete (1097) -> Invoiced (1281)             (normal billing flow)
 *   - Invoiced (1281) -> Invoiced (1281)             (no-op resave)
 *
 * Blocked:
 *   - In Progress / Open / any non-Complete status -> Invoiced
 *   - New entity inserted directly with status = Invoiced
 *
 * Bypass for scripts and migrations: set
 *   $work_order->_skip_invoiced_guard = TRUE;
 * before saving. The UI flow has no path to this flag, so office staff
 * cannot bypass through the form. The flag is documented inline so
 * future maintainers can find it.
 *
 * Throws EntityStorageException with a message that names the WO and
 * explains the required next step.
 */
function _wo_shared_assert_invoiced_transition_valid(EntityInterface $entity): void {
  // 1281 = Invoiced, 1097 = Complete (BOS status taxonomy term IDs).
  $INVOICED = 1281;
  $COMPLETE = 1097;

  if (!empty($entity->_skip_invoiced_guard)) {
    return;
  }
  if (!$entity->hasField('field_status')) {
    return;
  }
  $new_status = (int) ($entity->get('field_status')->target_id ?? 0);
  if ($new_status !== $INVOICED) {
    return;
  }

  if ($entity->isNew()) {
    $prior_status = 0;
  }
  else {
    /** @var \Drupal\Core\Entity\ContentEntityInterface|null $original */
    $original = $entity->original ?? NULL;
    if (!$original instanceof EntityInterface) {
      // Original not available — can't compare. Better to allow than
      // to block legitimate operations that don't carry $entity->original
      // (e.g. some programmatic paths). Logged so we can spot it.
      \Drupal::logger('wo_shared')->warning(
        'Invoiced-transition guard: $entity->original not present on save for WO @id. Allowing save.',
        ['@id' => $entity->id() ?: '(new)']
      );
      return;
    }
    $prior_status = (int) ($original->get('field_status')->target_id ?? 0);
  }

  if ($prior_status === $INVOICED) {
    return;
  }
  if ($prior_status === $COMPLETE) {
    return;
  }

  $wo_label = $entity->hasField('field_work_order_id') && !$entity->get('field_work_order_id')->isEmpty()
    ? '#' . $entity->get('field_work_order_id')->value
    : '#' . ($entity->id() ?: '(new)');

  throw new EntityStorageException(
    "Cannot mark WO $wo_label as Invoiced: the work order must be Complete first. "
    . "The crew has not signed off — wait for them to finish, or contact them to complete the sign-off, "
    . "before flipping the status to Invoiced. "
    . "(Current status term ID: $prior_status; required: $COMPLETE Complete.)"
  );
}
