<?php

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Entity\EntityFormInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\EntityStorageException;
use Drupal\Core\Form\FormStateInterface;
use Drupal\wo_sign_off\Service\WoCrewRosterService;

/**
 * Implements hook_entity_presave() for wo_status_update entities.
 */
function wo_sign_off_entity_presave(EntityInterface $entity) {
  // Set allowed bundles for this presave.
  $allowedBundles = ['complete', 'landscape_crew', 'clean_up_crew', 'fertilizing_crew', 'irrigation_crew', 'spray_crew'];

  // Check if the entity type is 'wo_complete_info' and bundle is allowed.
  if ($entity->getEntityTypeId() !== 'wo_complete_info' || !in_array($entity->bundle(), $allowedBundles)) {
    return;
  }

  // Phase 2b defense-in-depth: refuse save if any roster member lacks a
  // complete wo_time_clock entry on this WO. Catches programmatic /
  // REST / VBO writes that bypass the form-layer reconciliation.
  // Skipped when the legitimate reconciliation flow is in flight (the
  // form submit handler sets _signoff_reconciliation_in_progress on
  // the entity right before saving so this guard doesn't fire on the
  // already-reconciled save).
  if (empty($entity->_signoff_reconciliation_in_progress)) {
    _wo_sign_off_assert_roster_complete($entity);
  }

  // Get the work order ID from the reference field.
  $work_order_id = $entity->get('field_work_order')->target_id ?? NULL;
  if (!$work_order_id) {
    \Drupal::logger('wo_sign_off')->error('No work order referenced in wo_complete_info ID: @id', ['@id' => $entity->id()]);
    return;
  }

  // Load the work order entity.
  $work_order = \Drupal::entityTypeManager()->getStorage('work_order')->load($work_order_id);
  if (!$work_order) {
    \Drupal::logger('wo_sign_off')->error('Failed to load work order with ID: @id', ['@id' => $work_order_id]);
    return;
  }

  $current_user = \Drupal::currentUser();

  // Check if the work order is marked as canceled.
  $is_canceled = $entity->hasField('field_canceled') && $entity->get('field_canceled')->value;
  if ($is_canceled) {
    // Get the cancellation reason from field_canceled_why, if available.
    $cancel_reason = $entity->hasField('field_canceled_why') && !$entity->get('field_canceled_why')->isEmpty() 
      ? $entity->get('field_canceled_why')->value 
      : '';
    // Update status to Canceled (term ID 1098) and log.
    update_work_order_status($work_order, $current_user, 1098, 'Work Order canceled by crew due to customer request', $cancel_reason);
    $work_order->save();

    // Prepare email notification.
    $to = 'wo_notices@brookstoneoutdoors.com'; // Replace with your desired email if different.
    $subject = "Work Order #$work_order_id Canceled";
    $user_name = $current_user->id() ? ($current_user->getDisplayName() ?: $current_user->getAccountName()) : 'Unknown User';
    // Build absolute URL for the work order.
    $base_url = \Drupal::request()->getSchemeAndHttpHost();
    $work_order_url = "$base_url/work_order/$work_order_id";
    $html_body = [
      "<p style=\"font-family: Arial, sans-serif; font-size: 14px; margin: 0 0 10px 0;\">Work Order #$work_order_id has been canceled by $user_name.</p>",
      "<p style=\"font-family: Arial, sans-serif; font-size: 14px; margin: 0 0 10px 0;\">Cancellation Reason: " . ($cancel_reason ?: 'No reason provided') . "</p>",
      "<p style=\"font-family: Arial, sans-serif; font-size: 14px; margin: 0 0 10px 0;\">Please review the work order: <a href=\"$work_order_url\">View Work Order</a></p>",
    ];
    $plain_body = [
      "Work Order #$work_order_id has been canceled by $user_name.",
      "",
      "Cancellation Reason: " . ($cancel_reason ?: 'No reason provided'),
      "",
      "Please review the work order: $work_order_url",
    ];

    $params = [
      'subject' => $subject,
      'body' => $html_body,
      'plain' => $plain_body,
    ];

    $mail_manager = \Drupal::service('plugin.manager.mail');
    $result = $mail_manager->mail('wo_sign_off', 'work_order_canceled', $to, 'en', $params, NULL, TRUE);

    if ($result['result']) {
      \Drupal::logger('wo_sign_off')->info('Cancellation email sent for Work Order ID: @id to @to', [
        '@id' => $work_order_id,
        '@to' => $to,
      ]);
    } else {
      \Drupal::logger('wo_sign_off')->error('Failed to send cancellation email for Work Order ID: @id to @to', [
        '@id' => $work_order_id,
        '@to' => $to,
      ]);
    }

    return; // Exit early to prevent any further field updates.
  }

  // If not canceled, proceed with Complete status and field calculations.
  $workOrderStatus = $work_order->get('field_status')->value;
  if ($workOrderStatus != 1097) {
    update_work_order_status($work_order, $current_user, 1097, 'Teammate Completed Work Order');
  }

  // Calculate trip fee.
  $excludedTripBundles = [
    'sprinkler_start_up', 'sprinkler_winterizing'
  ];
  if (!in_array($work_order->bundle(), $excludedTripBundles)) {
    $propertyId = $work_order->get('field_property')->target_id ?? NULL;
    $trucks = $entity->get('field_how_many_trucks_taken')->value ?? 0;
    if ($propertyId && $work_order->hasField('field_trip_fee')) {
      $tripFee = get_trip_fee_for_property($propertyId);
      $work_order->set('field_trip_fee', $tripFee * $trucks);
    }

    if ($work_order->hasField('field_trucks')) {
      $work_order->set('field_trucks', $trucks);
    }
  }

  // Calculate hours for eligible bundles.
  $excludedBundles = [
    'dethatching', 'lawn_mowing', 'landscaping', 'sprinkler_repair', 'sprinkler_check_up',
    'sprinkler_start_up', 'sprinkler_winterizing', 'sprinkler_installation', 'sprinkler_design',
    'in_house_tasks', 'christmas_decorations', 'misc_services'
  ];
  if (!in_array($work_order->bundle(), $excludedBundles)) {
    $timeSpent = 0;

    $woTimeClockEntities = \Drupal::entityTypeManager()
      ->getStorage('wo_time_clock')
      ->loadByProperties([
        'field_work_order' => $work_order_id,
        'type' => 'entry',
      ]);

    foreach ($woTimeClockEntities as $timeEntity) {
      $timeSpent += $timeEntity->get('field_total_time')->value ?? 0;
    }

    if ($work_order->hasField('field_total_time')) {
      // Sum already represents total man-hours: Phase 2c reconciliation
      // creates one wo_time_clock entry per crew member, so each crew
      // member's hours are counted exactly once. No crew-count multiplier.
      $work_order->set('field_total_time', $timeSpent);
    }
  }

  // Save the work order with updated fields.
  $work_order->save();
}

/**
 * Implements hook_mail().
 */
function wo_sign_off_mail($key, &$message, $params) {
  if ($key === 'work_order_canceled') {
    $message['subject'] = $params['subject'] ?? 'Work Order Cancellation';
    // Use HTML body if available, otherwise fall back.
    $message['body'] = is_array($params['body']) ? $params['body'] : [$params['body']];
    // Join HTML body for Mime Mail rendering.
    $message['mimemail']['text'] = implode('', $params['body']);
    // Plain text fallback for non-HTML clients.
    $message['plain'] = is_array($params['plain']) ? implode("\n", $params['plain']) : $params['plain'];
    $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
  }
}

/**
 * Helper function to update work order status and create a status update log.
 *
 * @param EntityInterface $work_order The work order entity.
 * @param \Drupal\Core\Session\AccountInterface $current_user The current user.
 * @param int $status_id The taxonomy term ID for the status.
 * @param string $base_note The base status change note.
 * @param string $additional_note Optional additional note (e.g., cancellation reason).
 */
function update_work_order_status(EntityInterface $work_order, $current_user, $status_id, $base_note, $additional_note = '') {
  // Only update if the current status is different.
  if ($work_order->get('field_status')->value != $status_id) {
    // Combine base note with additional note, if provided.
    $note = $base_note;
    if (!empty($additional_note)) {
      $note .= ': ' . $additional_note;
    }
    $wo_status_updates = \Drupal::entityTypeManager()
      ->getStorage('wo_status_updates')
      ->create([
        'type' => 'update',
        'field_status_of_wo' => $work_order->id(),
        'field_status' => $status_id,
        'field_status_change_note' => ['value' => $note],
        'uid' => $current_user->id(),
      ]);
    $wo_status_updates->save();

    // Update the work order's status.
    if ($work_order->hasField('field_status')) {
      $work_order->set('field_status', $status_id);
    }
  }
}

/**
 * Implements hook_entity_update() for updating wo_complete_info entities.
 */
function wo_sign_off_entity_update(EntityInterface $entity) {
  // Check if the entity type is 'wo_complete_info'.
  if ($entity->getEntityTypeId() === 'wo_complete_info') {
    $work_order_id = $entity->get('field_work_order')->target_id ?? NULL;
    if ($work_order_id) {
      $work_order = \Drupal::entityTypeManager()->getStorage('work_order')->load($work_order_id);
      if ($work_order) {
        $work_order->save();
      } else {
        \Drupal::logger('wo_sign_off')->error('Work order not found for ID: @id', ['@id' => $work_order_id]);
      }
    }
  }
}

/**
 * Implements hook_entity_delete() for wo_complete_info entities.
 */
function wo_sign_off_entity_delete(EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'wo_complete_info') {
    return;
  }

  $work_order_id = $entity->get('field_work_order')->target_id ?? NULL;
  if (!$work_order_id) {
    return;
  }

  $work_order = \Drupal::entityTypeManager()->getStorage('work_order')->load($work_order_id);
  if (!$work_order) {
    \Drupal::logger('wo_sign_off')->error('Work order not found for ID: @id when attempting to revert status', ['@id' => $work_order_id]);
    return;
  }

  // Fields to clear.
  $fields_to_clear = [
    'field_total_time' => NULL,
    'field_trucks' => 0,
    'field_labor_total' => NULL,
    'field_material_chemical_total' => NULL,
    'field_die_total' => NULL,
    'field_atv_total' => NULL,
    'field_trip_fee' => NULL,
    'field_rental_total' => NULL,
    'field_wo_total' => NULL,
  ];

  foreach ($fields_to_clear as $field_name => $value) {
    if ($work_order->hasField($field_name)) {
      $work_order->set($field_name, $value);
    }
  }

  // Revert status to In Progress (1092).
  $current_user = \Drupal::currentUser();
  update_work_order_status($work_order, $current_user, 1092, 'Work Order "Sign Off" was deleted. Clearing all totals and setting it back to "In Progress"');

  // Save the work order.
  $work_order->save();

  \Drupal::logger('wo_sign_off')->info('Work Order status updated to In Progress due to deletion of wo_complete_info with ID: @id', ['@id' => $entity->id()]);
}

/**
 * Helper function to retrieve the trip fee for a given property ID.
 *
 * @param int $propertyId The ID of the property.
 * @return float The calculated trip fee based on property's zipcode, or 0 if data is not available.
 */
function get_trip_fee_for_property($propertyId) {
  $tripFee = 0;
  if ($propertyId) {
    $propertyEntity = \Drupal::entityTypeManager()->getStorage('properties')->load($propertyId);
    if ($propertyEntity) {
      $zipcodeId = $propertyEntity->get('field_zipcode_reference')->target_id ?? NULL;
      if ($zipcodeId) {
        $zipcodeEntity = \Drupal::entityTypeManager()->getStorage('zipcodes')->load($zipcodeId);
        if ($zipcodeEntity) {
          $tripFee = $zipcodeEntity->get('field_trip_fee')->value ?? 0;
        }
      }
    }
  }
  return $tripFee;
}

// ─────────────────────────────────────────────────────────────────────
// Phase 2b — wo_complete_info reconciliation form alter
// ─────────────────────────────────────────────────────────────────────

/**
 * Implements hook_form_alter().
 *
 * Injects a "Time Entry Reconciliation" fieldset on Phase 2 sign-off
 * forms when any roster member has an orphaned or missing
 * wo_time_clock entry on the parent WO.
 *
 * Two paths:
 *
 *   - Phase 2b: wo_complete_info forms (six in-scope bundles), roster
 *     from field_those_on_crew. Behavior C — initial render reflects
 *     current form state, plus an explicit "Refresh reconciliation"
 *     button that re-renders the wrapper without submitting.
 *
 *   - Phase 2c: wo_tasks_list:lawn_mowing form, roster from
 *     field_mowing_who_on_site. Behavior B — initial render only, no
 *     AJAX rebuild, no Refresh button. Field-tablet usage; AJAX
 *     round-trips are unreliable. Plus a hard-validation handler that
 *     requires field_mowing_who_on_site to be populated before any
 *     save.
 *
 * The validate handler re-categorizes at submit time in both paths so
 * roster edits between initial render and submit are caught.
 */
function wo_sign_off_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object instanceof EntityFormInterface) {
    return;
  }
  $entity = $form_object->getEntity();
  if (!$entity instanceof EntityInterface) {
    return;
  }
  $entity_type = $entity->getEntityTypeId();
  if ($entity_type !== 'wo_complete_info' && $entity_type !== 'wo_tasks_list') {
    return;
  }
  /** @var \Drupal\wo_sign_off\Service\WoCrewRosterService $svc */
  $svc = \Drupal::service('wo_sign_off.crew_roster');
  if (!$svc->isInScope($entity_type, $entity->bundle())) {
    return;
  }

  // Position the reconciliation block. Default placement is just
  // after the roster field. For wo_complete_info forms we anchor
  // instead to the field that follows the roster in the read order
  // (field_how_many_trucks_taken on every in-scope bundle) and place
  // the Refresh button + wrapper immediately above it. Anchoring to
  // a downstream field is more robust than offsetting from roster:
  // if any future form-alter shuffles roster's weight, the
  // reconciliation block stays glued to its anchor.
  $roster_weight = _wo_sign_off_roster_field_weight($entity_type, $entity->bundle());
  $anchor_weight = _wo_sign_off_form_component_weight($entity_type, $entity->bundle(), 'field_how_many_trucks_taken');
  if ($anchor_weight !== NULL && $anchor_weight > $roster_weight) {
    // Place wrapper immediately above the anchor field. Refresh
    // button is nested inside the wrapper, so its position is
    // determined by the wrapper's weight + button's intra-wrapper
    // weight (set to -100 below to render first).
    $wrapper_weight = $anchor_weight - 0.1;
  }
  else {
    // No anchor available (or roster sits below it) — fall back to
    // right-after-roster placement.
    $wrapper_weight = $roster_weight + 0.2;
  }

  // Wrapper for AJAX rebuild target (used by wo_complete_info path
  // only; wo_tasks_list path doesn't trigger AJAX rebuilds but the
  // wrapper is harmless).
  //
  // #group => 'content' tells field_layout to route this element
  // into the layout's `content` region. field_layout's buildForm
  // (FieldLayoutBuilder.php) sets the same #group on every field
  // it places into a region, then Drupal core's processGroup /
  // preRenderGroup render handlers collect all elements with the
  // matching #group into the region's container. Without #group,
  // the wrapper renders OUTSIDE the layout (after all in-region
  // fields, regardless of #weight).
  $wrapper_id = 'signoff-reconciliation-wrapper';
  $form['signoff_reconciliation'] = [
    '#type' => 'container',
    '#attributes' => ['id' => $wrapper_id],
    '#weight' => $wrapper_weight,
    '#tree' => TRUE,
    '#group' => 'content',
  ];

  // Refresh button — only complex bundles (sprinkler, landscape) need
  // it, since those are the only ones that render per-row inputs.
  // Simple bundles silent-create on save, so refresh adds no value.
  //
  // The button is nested INSIDE the wrapper container rather than as
  // a top-level form element. Top-level placement with `#group =>
  // 'content'` works for containers (the wrapper does this) but does
  // NOT route #type=button elements into the field_layout content
  // region — they end up at the bottom of the form regardless of
  // weight. As a child of the wrapper, the button inherits the
  // wrapper's already-correct position.
  if ($svc->isComplexBundle($entity_type, $entity->bundle())) {
    $form['signoff_reconciliation']['refresh'] = [
      '#type' => 'button',
      '#value' => t('Refresh reconciliation list'),
      '#weight' => -100,
      '#limit_validation_errors' => [],
      '#ajax' => [
        'callback' => '_wo_sign_off_reconciliation_ajax_rebuild',
        'wrapper' => $wrapper_id,
        'effect' => 'fade',
      ],
    ];
  }

  _wo_sign_off_build_reconciliation_fieldset($form, $form_state, $entity);

  // Append validate + submit handlers. For the lawn_mowing path the
  // hard-validation on field_mowing_who_on_site goes FIRST so an
  // empty roster blocks before any reconciliation work.
  if ($entity_type === 'wo_tasks_list' && $entity->bundle() === 'lawn_mowing') {
    array_unshift($form['#validate'], '_wo_sign_off_assert_mowing_roster_populated');
  }
  $form['#validate'][] = '_wo_sign_off_reconciliation_validate';
  if (isset($form['actions']['submit']['#submit'])) {
    array_unshift($form['actions']['submit']['#submit'], '_wo_sign_off_reconciliation_submit');
  }
  else {
    array_unshift($form['#submit'], '_wo_sign_off_reconciliation_submit');
  }
}

/**
 * Hard-validation handler for wo_tasks_list:lawn_mowing forms (Phase 2c).
 *
 * field_mowing_who_on_site must be populated before submit. An empty
 * roster makes the wo_lawn_mowing billing math collapse to zero
 * (men_on_site = 0 → totalTime = 0) — a long-standing bug we close
 * here as part of Phase 2c.
 *
 * Inserted at the head of $form['#validate'] so it runs BEFORE the
 * reconciliation validate handler. If this fires, no further
 * reconciliation work happens.
 */
function _wo_sign_off_assert_mowing_roster_populated(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object instanceof EntityFormInterface) {
    return;
  }
  $entity = $form_object->getEntity();
  if ($entity->getEntityTypeId() !== 'wo_tasks_list' || $entity->bundle() !== 'lawn_mowing') {
    return;
  }
  $values = $form_state->getValues();
  $items = $values['field_mowing_who_on_site'] ?? [];
  $populated = FALSE;
  foreach ($items as $item) {
    if (is_array($item) && !empty($item['target_id'])) {
      $populated = TRUE;
      break;
    }
    if (is_numeric($item) && (int) $item > 0) {
      $populated = TRUE;
      break;
    }
  }
  if (!$populated) {
    $form_state->setErrorByName(
      'field_mowing_who_on_site',
      t('Please indicate who was on the crew before completing this mow.')
    );
  }
}

/**
 * Implements hook_ENTITY_TYPE_presave() for wo_tasks_list (Phase 2c).
 *
 * Defense-in-depth guard for the lawn_mowing bundle, mirroring the
 * Phase 2b guard at the top of wo_sign_off_entity_presave but for the
 * mowing path. Catches programmatic / REST / VBO writes that bypass
 * the form-layer reconciliation.
 *
 * Triggers only when field_completed is being set falsy (the
 * wo_lawn_mowing cascade trigger condition), bundle is lawn_mowing,
 * and _signoff_reconciliation_in_progress is not set.
 *
 * Throws \Drupal\Core\Entity\EntityStorageException when:
 *   - field_mowing_who_on_site is empty (hard validation)
 *   - any roster member lacks a complete wo_time_clock entry
 */
function wo_sign_off_wo_tasks_list_presave(EntityInterface $entity): void {
  if ($entity->bundle() !== 'lawn_mowing') {
    return;
  }
  // Only fires when field_completed is being set falsy (cascade trigger).
  if (!$entity->hasField('field_completed')
      || $entity->get('field_completed')->isEmpty()
      || $entity->get('field_completed')->value) {
    return;
  }
  // Skip if reconciliation handler is mid-flight.
  if (!empty($entity->_signoff_reconciliation_in_progress)) {
    return;
  }

  // Hard validation: roster must be populated.
  if (!$entity->hasField('field_mowing_who_on_site') || $entity->get('field_mowing_who_on_site')->isEmpty()) {
    throw new EntityStorageException(
      'wo_tasks_list:lawn_mowing cannot be completed: field_mowing_who_on_site is empty. '
      . 'Crew roster is required before completion.'
    );
  }

  // Defense-in-depth: assert all roster members have complete entries.
  _wo_sign_off_assert_roster_complete($entity);
}

/**
 * Roster field weight on a given form display.
 *
 * Returns the form display weight of the roster field for this
 * entity_type/bundle. Used by the form alter to position the
 * reconciliation block immediately after the roster field in the
 * form's read order.
 *
 * Falls back to a small default if the form display can't be loaded
 * or doesn't contain the roster field — defensive but should never
 * fire under normal conditions.
 *
 * @return float
 */
function _wo_sign_off_roster_field_weight(string $entity_type, string $bundle): float {
  $weight = _wo_sign_off_form_component_weight($entity_type, $bundle, _wo_sign_off_roster_field_for($entity_type));
  return $weight ?? 0.0;
}

/**
 * Read a single component's #weight from the default form display.
 * Returns NULL when the field/display is missing — caller decides
 * the fallback rather than getting a baked-in 0.0.
 */
function _wo_sign_off_form_component_weight(string $entity_type, string $bundle, string $field): ?float {
  if ($field === '') {
    return NULL;
  }
  try {
    $display = \Drupal::entityTypeManager()
      ->getStorage('entity_form_display')
      ->load("$entity_type.$bundle.default");
    if ($display) {
      $component = $display->getComponent($field);
      if (isset($component['weight'])) {
        return (float) $component['weight'];
      }
    }
  }
  catch (\Throwable $e) {
    // Fall through.
  }
  return NULL;
}

/**
 * Roster field name for a sign-off entity type.
 *
 * Internal helper paralleling WoCrewRosterService::rosterFieldFor() —
 * the service's version is private; this one is exposed for module
 * code that needs the field name without going through the service.
 *
 * @return string
 */
function _wo_sign_off_roster_field_for(string $entity_type): string {
  return match ($entity_type) {
    'wo_complete_info' => 'field_those_on_crew',
    'wo_tasks_list' => 'field_mowing_who_on_site',
    default => '',
  };
}

/**
 * Audit field name for a sign-off entity type and direction.
 *
 * @param string $entity_type
 *   'wo_complete_info' or 'wo_tasks_list'.
 * @param string $direction
 *   'closed' or 'created'.
 *
 * @return string
 *   Field machine name, or empty string if out of scope.
 */
function _wo_sign_off_audit_field_for(string $entity_type, string $direction): string {
  if ($direction !== 'closed' && $direction !== 'created') {
    return '';
  }
  $suffix = $entity_type === 'wo_complete_info' ? 'complete'
    : ($entity_type === 'wo_tasks_list' ? 'tasks' : '');
  if ($suffix === '') {
    return '';
  }
  return "field_{$direction}_signoff_{$suffix}";
}

/**
 * AJAX callback: re-render the reconciliation wrapper based on current
 * form state. The form rebuild has already re-run the form alter, so
 * the updated $form contains the freshly-categorized fieldset.
 */
function _wo_sign_off_reconciliation_ajax_rebuild(array $form, FormStateInterface $form_state): array {
  return $form['signoff_reconciliation'];
}

/**
 * Build the reconciliation fieldset content based on current form state.
 *
 * Reads the roster from form state (so AJAX rebuild reflects user edits
 * to field_those_on_crew without requiring a save). Categorizes each
 * roster member as clean / orphan / missing. Renders one row per
 * orphan or missing — clean members get no row.
 *
 * If the roster is empty OR all members are clean, the fieldset
 * contents collapse to a brief informational message rather than a
 * full reconciliation UI.
 */
function _wo_sign_off_build_reconciliation_fieldset(array &$form, FormStateInterface $form_state, EntityInterface $entity): void {
  /** @var \Drupal\wo_sign_off\Service\WoCrewRosterService $svc */
  $svc = \Drupal::service('wo_sign_off.crew_roster');

  // Roster source priority: form state values (AJAX-aware), then the
  // entity's current field values (covers initial render of both new
  // and existing entities, where form state hasn't been populated yet).
  $entity_type = $entity->getEntityTypeId();
  $roster_field = _wo_sign_off_roster_field_for($entity_type);
  $values = $form_state->getValues();
  $roster = $svc->normalizeRosterFromFormState($values, $entity_type, $entity->bundle());
  if (empty($roster) && $entity->hasField($roster_field) && !$entity->get($roster_field)->isEmpty()) {
    foreach ($entity->get($roster_field) as $item) {
      if (!empty($item->target_id)) {
        $roster[] = (int) $item->target_id;
      }
    }
    $roster = array_values(array_unique($roster));
  }

  // WO id resolution mirrors the roster: form state first (covers the
  // Add form + AJAX/rebuild, where field_work_order lives in form
  // state and is NOT yet on a new entity), then the entity. Without
  // the form-state read, a brand-new wo_complete_info on the Add form
  // always resolved $wo_id = 0 and the reconciliation collapsed to
  // the empty-state message — the per-row time fields never rendered
  // even with crew checked. Matches what the validate/submit handlers
  // already do.
  $wo_id = (int) ($values['field_work_order'][0]['target_id'] ?? 0);
  if ($wo_id <= 0 && $entity->hasField('field_work_order') && !$entity->get('field_work_order')->isEmpty()) {
    $wo_id = (int) $entity->get('field_work_order')->target_id;
  }

  // Empty roster — nothing to reconcile.
  // For wo_complete_info: cardinality on field_those_on_crew is multi-
  // value but not required, so empty is allowed; we just don't render
  // anything actionable. For wo_tasks_list:lawn_mowing: empty roster
  // is blocked separately by the hard-validation handler — we simply
  // render nothing here too. Empty-state messaging differs slightly to
  // reflect the absence of the Refresh button on the mowing path.
  if (empty($roster) || $wo_id <= 0) {
    $msg = $entity_type === 'wo_complete_info'
      ? t('No crew members assigned yet — reconciliation will appear once you add crew above and click "Refresh reconciliation list".')
      : t('No crew members assigned yet — reconciliation will appear once the crew roster above is populated.');
    $form['signoff_reconciliation']['empty_state'] = [
      '#markup' => '<p><em>' . $msg . '</em></p>',
    ];
    return;
  }

  $categorized = _wo_sign_off_categorize_roster($wo_id, $roster);
  $orphans = array_filter($categorized, fn($r) => $r['status'] === 'orphan');
  $missing = array_filter($categorized, fn($r) => $r['status'] === 'missing');

  if (empty($orphans) && empty($missing)) {
    $form['signoff_reconciliation']['ok_state'] = [
      '#markup' => '<p><em>' . t('All @n crew members have complete time entries on this work order.', ['@n' => count($roster)]) . '</em></p>',
    ];
    return;
  }

  $user_storage = \Drupal::entityTypeManager()->getStorage('user');
  $name = function (int $uid) use ($user_storage): string {
    $u = $user_storage->load($uid);
    return $u ? $u->getDisplayName() : 'User ID ' . $uid;
  };

  // ORPHAN rows — UX splits by form type:
  //
  //   wo_tasks_list (mowing tasks-list path): the foreman fills the
  //     tasks form right after finishing the job — Save IS the
  //     clock-out event. No second form; the orphan close uses
  //     end_time = now silently. Render a short summary so the
  //     foreman knows what will happen.
  //
  //   wo_complete_info (sign-off form for spray, fertilizing,
  //     cleanup, sprinkler, landscape): per-entry datetime widget
  //     so the foreman can correct delayed-signoff scenarios (the
  //     WO 49723 / 49497 pattern).
  if (!empty($orphans)) {
    if ($entity_type === 'wo_tasks_list') {
      $orphan_names = array_map($name, array_keys($orphans));
      $form['signoff_reconciliation']['orphan_preview'] = [
        '#markup' => '<p><em>' . t('Open clock-ins will be closed when you save: @names.', ['@names' => implode(', ', $orphan_names)]) . '</em></p>',
      ];
    }
    else {
      $form['signoff_reconciliation']['orphans_title'] = [
        '#markup' => '<h3>' . t('Confirm end times for forgotten clock-outs') . '</h3>',
      ];
      $form['signoff_reconciliation']['orphans_help'] = [
        '#markup' => '<p>' . t('These clock-ins are still open. Confirm or adjust each end time before saving. Prefilled values are estimates — please verify.') . '</p>',
      ];
      $form['signoff_reconciliation']['orphans'] = [
        '#type' => 'container',
        '#tree' => TRUE,
      ];
      foreach ($orphans as $uid => $info) {
        foreach ($info['orphan_entities'] as $orphan) {
          $tc_id = (int) $orphan->id();
          $start_iso = $orphan->get('field_start_time')->value ?? NULL;
          if (empty($start_iso)) {
            continue;
          }
          $start_dt = new DrupalDateTime($start_iso, 'UTC');
          $start_dt->setTimezone(new \DateTimeZone(date_default_timezone_get()));
          $prefill_dt = _wo_sign_off_compute_orphan_end_prefill($wo_id, $start_dt);

          $form['signoff_reconciliation']['orphans'][$tc_id] = [
            '#type' => 'fieldset',
            '#title' => t('@name — started @start (entry #@id)', [
              '@name' => $name((int) $uid),
              '@start' => $start_dt->format('m/d/Y g:i A'),
              '@id' => $tc_id,
            ]),
            '#tree' => TRUE,
            'end_time' => [
              '#type' => 'datetime',
              '#title' => t('End time'),
              '#description' => t('When did this teammate actually finish? Required.'),
              '#default_value' => $prefill_dt,
              '#required' => TRUE,
            ],
            'notes' => [
              '#type' => 'textfield',
              '#title' => t('Note (optional)'),
              '#size' => 60,
            ],
          ];
        }
      }
    }
  }

  if (empty($missing)) {
    return;
  }

  // Missing handling diverges by bundle. Simple bundles (single-block
  // work — lawn, spray, fertilizing, cleanup) silent-create with WO-
  // derived defaults. Complex bundles (sprinkler, landscape — varied
  // per-person windows) require explicit per-row times because no
  // single default fits the team.
  $is_complex = $svc->isComplexBundle($entity_type, $entity->bundle());
  if (!$is_complex) {
    $missing_names = array_map($name, array_keys($missing));
    $form['signoff_reconciliation']['missing_preview'] = [
      '#markup' => '<p><em>' . t('New clock-in entries will be created when you save: @names. Times are estimated; edit the time clock entries afterward if any need adjustment.', ['@names' => implode(', ', $missing_names)]) . '</em></p>',
    ];
    return;
  }

  // COMPLEX path — render per-person rows. Defaults are deliberately
  // empty so the form-filler enters real times rather than rubber-
  // stamping a default that won't match this teammate's actual window.
  $form['signoff_reconciliation']['title'] = [
    '#markup' => '<h3>' . t('Time Entries to Create') . '</h3>',
  ];
  $form['signoff_reconciliation']['help'] = [
    '#markup' => '<p>' . t('The following crew members have no clock-in record on this work order. Enter their actual start and end times. (Multi-cycle work — sprinkler / landscape — has varied per-person windows; defaults would not be accurate.)') . '</p>',
  ];
  $form['signoff_reconciliation']['rows'] = [
    '#type' => 'container',
  ];
  foreach ($missing as $uid => $row_info) {
    $form['signoff_reconciliation']['rows'][$uid] = [
      '#type' => 'fieldset',
      '#title' => t('@name — no entry; will be created', ['@name' => $name($uid)]),
      '#tree' => TRUE,
      'start_time' => [
        '#type' => 'datetime',
        '#title' => t('Start time'),
        '#description' => t('When did this teammate begin work on this WO?'),
        '#default_value' => NULL,
      ],
      'end_time' => [
        '#type' => 'datetime',
        '#title' => t('End time'),
        '#description' => t('When did this teammate finish work on this WO?'),
        '#default_value' => NULL,
      ],
      'notes' => [
        '#type' => 'textfield',
        '#title' => t('Note (optional)'),
        '#size' => 60,
      ],
    ];
  }
}

/**
 * Categorize each roster member's wo_time_clock entries on this WO.
 *
 * @return array<int, array{status: string, orphan_entities?: array<int, \Drupal\Core\Entity\EntityInterface>}>
 *   Keyed by uid. Status is one of 'clean', 'orphan', 'missing'.
 *   When orphan, includes ALL open wo_time_clock entities for the uid
 *   on this WO (multi-cycle teammates may have more than one open
 *   punch — all need closing at sign-off).
 */
function _wo_sign_off_categorize_roster(int $wo_id, array $roster): array {
  $tc_storage = \Drupal::entityTypeManager()->getStorage('wo_time_clock');
  $result = [];
  foreach ($roster as $uid) {
    $uid = (int) $uid;
    if ($uid <= 0) {
      continue;
    }
    // Open entries take priority. Sprinkler/landscape WOs commonly
    // have multiple in/out cycles per teammate (morning + afternoon,
    // lunch breaks, parts runs). A teammate may have several closed
    // entries plus one open entry (forgot the final clock-out) — they
    // are still "orphan", and ALL open entries get closed at save
    // (not just the most recent).
    $open_ids = $tc_storage->getQuery()
      ->accessCheck(FALSE)
      ->condition('field_work_order', $wo_id)
      ->condition('field_teammate', $uid)
      ->notExists('field_end_time')
      ->sort('field_start_time', 'ASC')
      ->execute();
    if (!empty($open_ids)) {
      $result[$uid] = [
        'status' => 'orphan',
        'orphan_entities' => $tc_storage->loadMultiple($open_ids),
      ];
      continue;
    }
    // No open entries — if any closed entries exist, the teammate's
    // time is fully captured.
    $closed_count = (int) $tc_storage->getQuery()
      ->accessCheck(FALSE)
      ->condition('field_work_order', $wo_id)
      ->condition('field_teammate', $uid)
      ->exists('field_end_time')
      ->count()
      ->execute();
    if ($closed_count > 0) {
      $result[$uid] = ['status' => 'clean'];
      continue;
    }
    // No entries at all → missing.
    $result[$uid] = ['status' => 'missing'];
  }
  return $result;
}

/**
 * Compute the default start_time (UTC ISO string) for silent-create
 * missing entries. Uses the earliest existing wo_time_clock start_time
 * on the WO so newly created entries align with the rest of the
 * crew's day. Falls back to the WO's `created` timestamp when no
 * other clock-ins exist. Final fallback is $now_utc, so the entry is
 * never zero-length end < start.
 */
function _wo_sign_off_compute_missing_start_default(int $wo_id, string $now_utc): string {
  $tc_storage = \Drupal::entityTypeManager()->getStorage('wo_time_clock');
  $earliest_ids = $tc_storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('field_work_order', $wo_id)
    ->exists('field_start_time')
    ->sort('field_start_time', 'ASC')
    ->range(0, 1)
    ->execute();
  if (!empty($earliest_ids)) {
    $tc = $tc_storage->load(reset($earliest_ids));
    $val = $tc->get('field_start_time')->value;
    if (!empty($val)) {
      return $val;
    }
  }
  $wo = \Drupal::entityTypeManager()->getStorage('work_order')->load($wo_id);
  if ($wo && $wo->hasField('created') && !$wo->get('created')->isEmpty()) {
    return DrupalDateTime::createFromTimestamp((int) $wo->get('created')->value)
      ->setTimezone(new \DateTimeZone('UTC'))
      ->format('Y-m-d\TH:i:s');
  }
  return $now_utc;
}

/**
 * Compute the default end_time (UTC ISO string) for silent-create
 * missing entries on simple bundles. Uses the latest existing
 * wo_time_clock end_time on the WO so newly created entries align
 * with when the crew actually left the site — matches the implicit
 * "simple bundle = whole crew worked the same shift" assumption.
 *
 * Falls back to $now_utc only when nobody has clocked out yet (the
 * degenerate case where the signer is creating every crew member's
 * entry from scratch). In that case there is no on-WO reference for
 * what "end" should mean, and the legacy behavior is preserved.
 *
 * Pre-fix behavior was always $now_utc, which produced multi-day
 * shift durations any time sign-off happened later than the crew's
 * actual leave time (see WO 49497 — Greg Kouri's 26.36 hr entry
 * created at sign-off the day after the work occurred).
 */
function _wo_sign_off_compute_missing_end_default(int $wo_id, string $now_utc): string {
  $tc_storage = \Drupal::entityTypeManager()->getStorage('wo_time_clock');
  $latest_ids = $tc_storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('field_work_order', $wo_id)
    ->exists('field_end_time')
    ->sort('field_end_time', 'DESC')
    ->range(0, 1)
    ->execute();
  if (!empty($latest_ids)) {
    $tc = $tc_storage->load(reset($latest_ids));
    $val = $tc->get('field_end_time')->value;
    if (!empty($val)) {
      return $val;
    }
  }
  return $now_utc;
}

/**
 * Compute the prefilled end_time (DrupalDateTime, site timezone) for
 * an orphan close-out row in the sign-off form. The foreman can edit
 * this before submitting; the prefill exists to make the common case
 * (whole crew left together) one acknowledging click.
 *
 * Priority:
 *   1. Latest existing closed end_time on this WO, if it is strictly
 *      after the orphan's own start_time. Matches "crew left together"
 *      for sprinkler/landscape multi-cycle work where someone else
 *      already clocked out.
 *   2. orphan_start + 1 hour. Small enough to force the foreman to
 *      look at it rather than rubber-stamp.
 */
function _wo_sign_off_compute_orphan_end_prefill(int $wo_id, DrupalDateTime $orphan_start_dt): DrupalDateTime {
  $tc_storage = \Drupal::entityTypeManager()->getStorage('wo_time_clock');
  $latest_ids = $tc_storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('field_work_order', $wo_id)
    ->exists('field_end_time')
    ->sort('field_end_time', 'DESC')
    ->range(0, 1)
    ->execute();
  if (!empty($latest_ids)) {
    $tc = $tc_storage->load(reset($latest_ids));
    $val = $tc->get('field_end_time')->value;
    if (!empty($val)) {
      $latest_dt = new DrupalDateTime($val, 'UTC');
      $latest_dt->setTimezone(new \DateTimeZone(date_default_timezone_get()));
      if ($latest_dt->getTimestamp() > $orphan_start_dt->getTimestamp()) {
        return $latest_dt;
      }
    }
  }
  $prefill = clone $orphan_start_dt;
  $prefill->modify('+1 hour');
  return $prefill;
}

/**
 * Form validate handler for the reconciliation fieldset.
 *
 * Two sets of inline rows to validate:
 *
 *   - ORPHAN rows (all bundles). Per-entry end_time fields the foreman
 *     fills in before submission. Validates end > start and end not in
 *     the future.
 *
 *   - MISSING rows (complex bundles only — sprinkler, landscape).
 *     Per-person start/end times the foreman fills in. Simple-bundle
 *     missing rows silent-create with defaults; nothing to validate.
 *
 * If the roster changed since render and complex-missing rows are
 * absent, rebuilds so the user can fill them in (this is the only
 * path that may require a second save — only fires when the user
 * added crew without first clicking the Refresh button).
 */
function _wo_sign_off_reconciliation_validate(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object instanceof EntityFormInterface) {
    return;
  }
  $entity = $form_object->getEntity();
  $entity_type = $entity->getEntityTypeId();
  if ($entity_type !== 'wo_complete_info' && $entity_type !== 'wo_tasks_list') {
    return;
  }
  /** @var \Drupal\wo_sign_off\Service\WoCrewRosterService $svc */
  $svc = \Drupal::service('wo_sign_off.crew_roster');
  if (!$svc->isInScope($entity_type, $entity->bundle())) {
    return;
  }

  $values = $form_state->getValues();
  $roster = $svc->normalizeRosterFromFormState($values, $entity_type, $entity->bundle());
  $wo_id = (int) ($values['field_work_order'][0]['target_id'] ?? $entity->get('field_work_order')->target_id ?? 0);
  if (empty($roster) || $wo_id <= 0) {
    return;
  }

  $categorized = _wo_sign_off_categorize_roster($wo_id, $roster);
  $orphans = array_filter($categorized, fn($r) => $r['status'] === 'orphan');
  $missing = array_filter($categorized, fn($r) => $r['status'] === 'missing');

  $now = \Drupal::time()->getRequestTime();
  $grace = (defined('WO_TOTAL_TIME_FUTURE_GRACE_MINUTES') ? WO_TOTAL_TIME_FUTURE_GRACE_MINUTES : 5) * 60;

  // Validate ORPHAN rows — only on wo_complete_info (Sign-Off form).
  // wo_tasks_list (Task List form) closes orphans silently at save
  // time with end = now, so there are no rows to validate.
  if (!empty($orphans) && $entity_type !== 'wo_tasks_list') {
    $needs_orphan_rebuild = FALSE;
    foreach ($orphans as $uid => $info) {
      foreach ($info['orphan_entities'] as $orphan) {
        $tc_id = (int) $orphan->id();
        if (!isset($values['signoff_reconciliation']['orphans'][$tc_id])) {
          $needs_orphan_rebuild = TRUE;
          break 2;
        }
      }
    }
    if ($needs_orphan_rebuild) {
      \Drupal::messenger()->addWarning(t('Crew roster updated. Confirm end times for the forgotten clock-outs that just appeared below, then save again.'));
      $form_state->setRebuild(TRUE);
      return;
    }

    foreach ($orphans as $uid => $info) {
      foreach ($info['orphan_entities'] as $orphan) {
        $tc_id = (int) $orphan->id();
        $row = $values['signoff_reconciliation']['orphans'][$tc_id] ?? [];
        $end_time = $row['end_time'] ?? NULL;
        $start_iso = $orphan->get('field_start_time')->value ?? NULL;
        $start_ts = $start_iso ? strtotime($start_iso . ' UTC') : 0;

        if (!$end_time instanceof DrupalDateTime) {
          $form_state->setErrorByName(
            "signoff_reconciliation][orphans][$tc_id][end_time",
            t('End time is required.')
          );
          continue;
        }
        if ($end_time->getTimestamp() > $now + $grace) {
          $form_state->setErrorByName(
            "signoff_reconciliation][orphans][$tc_id][end_time",
            t('End time (@e) is in the future.', ['@e' => $end_time->format('m/d/Y g:i A')])
          );
        }
        if ($start_ts && $end_time->getTimestamp() <= $start_ts) {
          $form_state->setErrorByName(
            "signoff_reconciliation][orphans][$tc_id][end_time",
            t('End time (@e) must be after the start time (@s).', [
              '@e' => $end_time->format('m/d/Y g:i A'),
              '@s' => date('m/d/Y g:i A', $start_ts),
            ])
          );
        }
      }
    }
  }

  if (!$svc->isComplexBundle($entity_type, $entity->bundle())) {
    return;
  }
  if (empty($missing)) {
    return;
  }

  // Roster changed since render — rebuild so missing rows appear with
  // empty inputs the user can fill in. (Refresh button avoids this
  // path for users who click it after editing the roster.)
  $needs_rebuild = FALSE;
  foreach ($missing as $uid => $info) {
    if (!isset($values['signoff_reconciliation']['rows'][$uid])) {
      $needs_rebuild = TRUE;
      break;
    }
  }
  if ($needs_rebuild) {
    \Drupal::messenger()->addWarning(t('Crew roster updated. Enter start and end times for the new entries below, then save again.'));
    $form_state->setRebuild(TRUE);
    return;
  }

  foreach ($missing as $uid => $info) {
    $row = $values['signoff_reconciliation']['rows'][$uid];
    $start_time = $row['start_time'] ?? NULL;
    $end_time = $row['end_time'] ?? NULL;
    if (!$start_time instanceof DrupalDateTime) {
      $form_state->setErrorByName(
        "signoff_reconciliation][rows][$uid][start_time",
        t('Start time is required.')
      );
    }
    if (!$end_time instanceof DrupalDateTime) {
      $form_state->setErrorByName(
        "signoff_reconciliation][rows][$uid][end_time",
        t('End time is required.')
      );
    }
    if (!($start_time instanceof DrupalDateTime) || !($end_time instanceof DrupalDateTime)) {
      continue;
    }
    if ($start_time->getTimestamp() > $now + $grace) {
      $form_state->setErrorByName(
        "signoff_reconciliation][rows][$uid][start_time",
        t('Start time (@s) is in the future.', ['@s' => $start_time->format('m/d/Y g:i A')])
      );
    }
    if ($end_time->getTimestamp() > $now + $grace) {
      $form_state->setErrorByName(
        "signoff_reconciliation][rows][$uid][end_time",
        t('End time (@e) is in the future.', ['@e' => $end_time->format('m/d/Y g:i A')])
      );
    }
    if ($end_time->getTimestamp() < $start_time->getTimestamp()) {
      $form_state->setErrorByName(
        "signoff_reconciliation][rows][$uid][end_time",
        t('End time (@e) is before start time (@s). Please verify the date and AM/PM.', [
          '@e' => $end_time->format('m/d/Y g:i A'),
          '@s' => $start_time->format('m/d/Y g:i A'),
        ])
      );
    }
  }
}

/**
 * Form submit handler — runs BEFORE the entity save fires. Performs all
 * reconciliation actions (close orphans, create missing, delete mistakes),
 * then sets the _signoff_reconciliation_in_progress flag on the parent
 * entity so the defense-in-depth presave guard skips this save.
 */
function _wo_sign_off_reconciliation_submit(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object instanceof EntityFormInterface) {
    return;
  }
  $entity = $form_object->getEntity();
  $entity_type = $entity->getEntityTypeId();
  if ($entity_type !== 'wo_complete_info' && $entity_type !== 'wo_tasks_list') {
    return;
  }
  /** @var \Drupal\wo_sign_off\Service\WoCrewRosterService $svc */
  $svc = \Drupal::service('wo_sign_off.crew_roster');
  if (!$svc->isInScope($entity_type, $entity->bundle())) {
    return;
  }

  $values = $form_state->getValues();
  $roster = $svc->normalizeRosterFromFormState($values, $entity_type, $entity->bundle());
  $wo_id = (int) ($values['field_work_order'][0]['target_id'] ?? $entity->get('field_work_order')->target_id ?? 0);
  if (empty($roster) || $wo_id <= 0) {
    // No reconciliation work to do; let entity save proceed normally.
    return;
  }

  $categorized = _wo_sign_off_categorize_roster($wo_id, $roster);
  $orphans = array_filter($categorized, fn($r) => $r['status'] === 'orphan');
  $missing = array_filter($categorized, fn($r) => $r['status'] === 'missing');
  if (empty($orphans) && empty($missing)) {
    return;
  }

  // Determine signer for audit. Prefer field_signed_off_by on the
  // sign-off entity (both wo_complete_info and wo_tasks_list:lawn_mowing
  // have this field); fall back to current user.
  $signer_uid = (int) ($values['field_signed_off_by'][0]['target_id'] ?? 0);
  if ($signer_uid <= 0) {
    $signer_uid = (int) \Drupal::currentUser()->id();
  }
  $signer_user = \Drupal::entityTypeManager()->getStorage('user')->load($signer_uid);
  $signer_name = $signer_user ? $signer_user->getDisplayName() : 'Unknown';
  $now_dt = new DrupalDateTime();
  $now_label = $now_dt->format('m/d/Y g:i A');
  $now_utc = $now_dt->setTimezone(new \DateTimeZone('UTC'))->format('Y-m-d\TH:i:s');

  $tc_storage = \Drupal::entityTypeManager()->getStorage('wo_time_clock');
  $user_storage = \Drupal::entityTypeManager()->getStorage('user');

  // For EXISTING entities, $entity->id() is already populated — set
  // the audit field inline. For NEW wo_complete_info entities, the ID
  // isn't assigned until the entity save that follows; we stash the
  // touched wo_time_clock IDs onto the parent and the wo_complete_info
  // hook_entity_insert (Phase 2b-fix) does a second pass.
  // wo_tasks_list:lawn_mowing entities are always existing during
  // sign-off (created earlier by the WOLawnMowingTaskController workflow
  // start) — no stash needed for that path.
  $parent_id = $entity->isNew() ? NULL : (int) $entity->id();
  $audit_closed_field = _wo_sign_off_audit_field_for($entity_type, 'closed');
  $audit_created_field = _wo_sign_off_audit_field_for($entity_type, 'created');
  $reconciled_closed_ids = [];
  $reconciled_created_ids = [];
  $closed_names = [];
  $created_names = [];

  // ORPHANS — close open clock-ins.
  //
  // wo_tasks_list (Task List form): silent close with end_time = now.
  // The foreman is clocking out by saving this form; no second
  // confirmation step is wanted.
  //
  // wo_complete_info (Sign-Off form): foreman-entered end_time from
  // the per-row datetime widget. Validation guarantees a real
  // DrupalDateTime is present.
  foreach ($orphans as $uid => $info) {
    $u = $user_storage->load($uid);
    $u_name = $u ? $u->getDisplayName() : 'User ID ' . $uid;
    $closed_count = 0;
    foreach ($info['orphan_entities'] as $orphan) {
      $tc_id = (int) $orphan->id();
      if ($entity_type === 'wo_tasks_list') {
        $end_utc = $now_utc;
        $audit_note = "[Closed by {$signer_name} at sign-off, {$now_label}]";
      }
      else {
        $row = $values['signoff_reconciliation']['orphans'][$tc_id] ?? [];
        $end_dt = $row['end_time'] ?? NULL;
        if (!$end_dt instanceof DrupalDateTime) {
          // Defensive: validation should have caught this. Fall back
          // to $now_utc rather than crash, but log loudly.
          \Drupal::logger('wo_sign_off')->warning(
            'Reconciliation: orphan row for entry @id on WO @wo had no end_time at save — falling back to now.',
            ['@id' => $tc_id, '@wo' => $wo_id]
          );
          $end_utc = $now_utc;
        }
        else {
          $end_utc = $end_dt->setTimezone(new \DateTimeZone('UTC'))->format('Y-m-d\TH:i:s');
        }
        $row_note = trim((string) ($row['notes'] ?? ''));
        $audit_prefix = "[Closed by {$signer_name} at sign-off, {$now_label}; end time entered by foreman]";
        $audit_note = trim($audit_prefix . ' ' . $row_note);
      }
      $orphan->set('field_end_time', $end_utc);
      $orphan->set('field_notes', $audit_note);
      if ($parent_id !== NULL) {
        $orphan->set($audit_closed_field, $parent_id);
      }
      $orphan->_signoff_reconciliation = TRUE;
      try {
        $orphan->save();
        $reconciled_closed_ids[] = (int) $orphan->id();
        $closed_count++;
      }
      catch (\Exception $e) {
        \Drupal::logger('wo_sign_off')->error(
          'Reconciliation: failed to close orphan @id: @msg',
          ['@id' => $orphan->id(), '@msg' => $e->getMessage()]
        );
      }
    }
    if ($closed_count > 0) {
      $closed_names[] = $closed_count > 1
        ? "{$u_name} ({$closed_count} entries)"
        : $u_name;
    }
  }

  // MISSING — split by bundle. Simple bundles silent-create with WO-
  // derived defaults; complex bundles use per-row times entered by
  // the user (validated above).
  if (!empty($missing)) {
    $is_complex = $svc->isComplexBundle($entity_type, $entity->bundle());
    $start_default_utc = $is_complex
      ? NULL
      : _wo_sign_off_compute_missing_start_default($wo_id, $now_utc);
    $end_default_utc = $is_complex
      ? NULL
      : _wo_sign_off_compute_missing_end_default($wo_id, $now_utc);

    foreach ($missing as $uid => $info) {
      if ($is_complex) {
        $row = $values['signoff_reconciliation']['rows'][$uid] ?? [];
        $start_dt = $row['start_time'] ?? NULL;
        $end_dt = $row['end_time'] ?? NULL;
        if (!$start_dt instanceof DrupalDateTime || !$end_dt instanceof DrupalDateTime) {
          \Drupal::logger('wo_sign_off')->warning(
            'Reconciliation: missing-row for uid @uid on WO @wo skipped — incomplete time values (validate handler should have blocked).',
            ['@uid' => $uid, '@wo' => $wo_id]
          );
          continue;
        }
        $start_utc = $start_dt->setTimezone(new \DateTimeZone('UTC'))->format('Y-m-d\TH:i:s');
        $end_utc = $end_dt->setTimezone(new \DateTimeZone('UTC'))->format('Y-m-d\TH:i:s');
        $row_note = trim((string) ($row['notes'] ?? ''));
        $audit_prefix = "[Created by {$signer_name} at sign-off, {$now_label}]";
        $audit_note = trim($audit_prefix . ' ' . $row_note);
      }
      else {
        $start_utc = $start_default_utc;
        $end_utc = $end_default_utc;
        $audit_note = "[Created by {$signer_name} at sign-off, {$now_label}]";
      }

      $new = $tc_storage->create([
        'type' => 'entry',
        'field_work_order' => $wo_id,
        'field_teammate' => $uid,
        'uid' => $uid,
        'field_start_time' => $start_utc,
        'field_end_time' => $end_utc,
        'field_notes' => $audit_note,
      ]);
      if ($parent_id !== NULL) {
        $new->set($audit_created_field, $parent_id);
      }
      $new->_signoff_reconciliation = TRUE;
      try {
        $new->save();
        $reconciled_created_ids[] = (int) $new->id();
        $u = $user_storage->load($uid);
        $created_names[] = $u ? $u->getDisplayName() : 'User ID ' . $uid;
      }
      catch (\Exception $e) {
        \Drupal::logger('wo_sign_off')->error(
          'Reconciliation: failed to create entry for uid @uid on WO @wo: @msg',
          ['@uid' => $uid, '@wo' => $wo_id, '@msg' => $e->getMessage()]
        );
      }
    }
  }

  // User feedback — confirm what was just done.
  $messenger = \Drupal::messenger();
  if (!empty($closed_names)) {
    $messenger->addStatus(t('Closed open clock-ins for: @names (end time: @t).', [
      '@names' => implode(', ', $closed_names),
      '@t' => $now_label,
    ]));
  }
  if (!empty($created_names)) {
    $messenger->addStatus(t('Created new clock-in entries for: @names.', [
      '@names' => implode(', ', $created_names),
    ]));
  }

  // Mark the parent so the presave guard doesn't re-evaluate the
  // (now-resolved) roster.
  $entity->_signoff_reconciliation_in_progress = TRUE;

  // Phase 2b-fix: stash IDs for new entities so wo_sign_off_entity_insert
  // can populate the audit reference fields once the parent has an ID.
  // Existing entities had their audit fields set inline above
  // (parent_id was non-NULL). wo_tasks_list:lawn_mowing entities are
  // always existing during sign-off, so this branch is effectively
  // wo_complete_info-only.
  if ($entity->isNew() && $entity_type === 'wo_complete_info') {
    if (!empty($reconciled_closed_ids)) {
      $entity->_reconciled_closed_ids = $reconciled_closed_ids;
    }
    if (!empty($reconciled_created_ids)) {
      $entity->_reconciled_created_ids = $reconciled_created_ids;
    }
  }
}

/**
 * Implements hook_entity_insert().
 *
 * Phase 2b-fix: completes the audit reference field population for
 * wo_time_clock entries that were closed or created by sign-off
 * reconciliation on a NEW wo_complete_info entity.
 *
 * The pre-save submit handler couldn't set field_closed_signoff_complete
 * or field_created_signoff_complete because $entity->id() was NULL.
 * This insert hook fires after the entity has an ID assigned, walks
 * the stashed wo_time_clock IDs, and back-fills the audit reference
 * field with the parent ID.
 *
 * For UPDATE on existing wo_complete_info entities, the pre-save
 * handler already set the audit fields inline — no second pass needed.
 */
function wo_sign_off_entity_insert(EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'wo_complete_info') {
    return;
  }
  /** @var \Drupal\wo_sign_off\Service\WoCrewRosterService $svc */
  $svc = \Drupal::service('wo_sign_off.crew_roster');
  if (!$svc->isInScope('wo_complete_info', $entity->bundle())) {
    return;
  }

  $closed_ids = $entity->_reconciled_closed_ids ?? [];
  $created_ids = $entity->_reconciled_created_ids ?? [];
  if (empty($closed_ids) && empty($created_ids)) {
    return;
  }

  $tc_storage = \Drupal::entityTypeManager()->getStorage('wo_time_clock');
  $parent_id = (int) $entity->id();

  foreach ($closed_ids as $tc_id) {
    $tc = $tc_storage->load($tc_id);
    if (!$tc) {
      \Drupal::logger('wo_sign_off')->warning(
        'Phase 2b-fix: wo_time_clock @id missing during audit-field backfill (closed pass).',
        ['@id' => $tc_id]
      );
      continue;
    }
    $tc->set('field_closed_signoff_complete', $parent_id);
    $tc->_signoff_reconciliation = TRUE;
    try {
      $tc->save();
    }
    catch (\Exception $e) {
      \Drupal::logger('wo_sign_off')->error(
        'Phase 2b-fix: failed to back-fill field_closed_signoff_complete on @id: @msg',
        ['@id' => $tc_id, '@msg' => $e->getMessage()]
      );
    }
  }

  foreach ($created_ids as $tc_id) {
    $tc = $tc_storage->load($tc_id);
    if (!$tc) {
      \Drupal::logger('wo_sign_off')->warning(
        'Phase 2b-fix: wo_time_clock @id missing during audit-field backfill (created pass).',
        ['@id' => $tc_id]
      );
      continue;
    }
    $tc->set('field_created_signoff_complete', $parent_id);
    $tc->_signoff_reconciliation = TRUE;
    try {
      $tc->save();
    }
    catch (\Exception $e) {
      \Drupal::logger('wo_sign_off')->error(
        'Phase 2b-fix: failed to back-fill field_created_signoff_complete on @id: @msg',
        ['@id' => $tc_id, '@msg' => $e->getMessage()]
      );
    }
  }
}

/**
 * Defense-in-depth: refuse to save a sign-off wo_complete_info if any
 * roster member lacks a complete wo_time_clock entry.
 *
 * Throws \Drupal\Core\Entity\EntityStorageException, aborting the save.
 *
 * Skipped via _signoff_reconciliation_in_progress on the entity, set
 * by the form submit handler after legitimate reconciliation completes.
 */
function _wo_sign_off_assert_roster_complete(EntityInterface $entity): void {
  /** @var \Drupal\wo_sign_off\Service\WoCrewRosterService $svc */
  $svc = \Drupal::service('wo_sign_off.crew_roster');
  $entity_type = $entity->getEntityTypeId();
  if ($entity_type !== 'wo_complete_info' && $entity_type !== 'wo_tasks_list') {
    return;
  }
  if (!$svc->isInScope($entity_type, $entity->bundle())) {
    return;
  }

  $wo_id = ($entity->hasField('field_work_order') && !$entity->get('field_work_order')->isEmpty())
    ? (int) $entity->get('field_work_order')->target_id
    : 0;
  if ($wo_id <= 0) {
    return;
  }

  $roster_field = _wo_sign_off_roster_field_for($entity_type);
  $roster = [];
  if ($entity->hasField($roster_field) && !$entity->get($roster_field)->isEmpty()) {
    foreach ($entity->get($roster_field) as $item) {
      if (!empty($item->target_id)) {
        $roster[] = (int) $item->target_id;
      }
    }
    $roster = array_values(array_unique($roster));
  }
  if (empty($roster)) {
    return;
  }

  $categorized = _wo_sign_off_categorize_roster($wo_id, $roster);
  $offenders = [];
  $user_storage = \Drupal::entityTypeManager()->getStorage('user');
  foreach ($categorized as $uid => $info) {
    if ($info['status'] !== 'clean') {
      $u = $user_storage->load($uid);
      $offenders[] = ($u ? $u->getDisplayName() : "uid=$uid")
        . ' (' . $info['status'] . ')';
    }
  }
  if (!empty($offenders)) {
    throw new EntityStorageException(sprintf(
      'Sign-off cannot be saved: the following crew member(s) need time entry reconciliation — %s. Use the form interface to reconcile time entries before signing off.',
      implode(', ', $offenders)
    ));
  }
}
