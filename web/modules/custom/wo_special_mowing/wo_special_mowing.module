<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\config_pages\ConfigPagesLoaderInterface;
use Drupal\eck\EckEntityInterface;
use Drupal\views\Views;

/**
 * Implements hook_entity_presave().
 *
 * Special-mowing billing model: Time + Materials + Trip + Dump +
 * Rental + Billing Adjustment. Trip fee is already truck-multiplied
 * by wo_sign_off (zipcode_trip_fee × field_trucks).
 */
function wo_special_mowing_entity_presave(EntityInterface $entity) {
    $grand_total = 0;
    $labor_subtotal = 0;

    if ($entity->getEntityTypeId() !== 'work_order' || $entity->bundle() !== 'special_mowing') {
        return;
    }

    $statusTermId = $entity->get('field_status')->target_id ?? 0;
    if ($statusTermId != 1097) {
        return;
    }

    $workOrderId = $entity->id();
    $config_pages_loader = \Drupal::service('config_pages.loader');
    $business_settings = $config_pages_loader->load('business_setting');

    if ($business_settings) {
        $hourlyRate = $business_settings->get('field_maintenance_crew_labor')->value;
        $hourlyBillingIncrement = $business_settings->get('field_hour_billing_increment')->value;
        $hourlyMinimum = $business_settings->get('field_cleanup_labor_minimum')->value;

        // Compute timeSpent locally — self-contained, doesn't depend on
        // wo_shared's hook firing first. Both produce the same value.
        $timeSpent = get_hours_for_special_mowing($workOrderId);
        $totalTime = $timeSpent;
        $entity->set('field_total_time', $totalTime);

        if ($totalTime > $hourlyMinimum) {
            $totalMinutes = $totalTime * 60;
            $hourlyBillingIncrementMinutes = $hourlyBillingIncrement * 60;
            $totalTimeIncrements = ceil($totalMinutes / $hourlyBillingIncrementMinutes);
            $hourlyRateIncrement = $hourlyRate * $hourlyBillingIncrement;
            $labor_subtotal = $hourlyRateIncrement * $totalTimeIncrements;
        }
        else {
            $labor_subtotal = $hourlyRate * $hourlyMinimum;
        }
        $entity->set('field_labor_total', $labor_subtotal);
    }

    if ($labor_subtotal > 0) {
        $grand_total += $labor_subtotal;
    }

    // Material costs (with markup, snapshotted at sign-off time).
    $material_subtotal = get_total_special_mowing_material_list_price($workOrderId);
    if ($material_subtotal > 0) {
        $entity->set('field_material_chemical_total', $material_subtotal);
        $grand_total += $material_subtotal;
    }

    // Trip fee — already computed as zipcode_trip_fee × trucks by wo_sign_off.
    $totalTrip = $entity->get('field_trip_fee')->value;
    if ($totalTrip > 0) {
        $grand_total += $totalTrip;
    }

    // Dump fees — sum of wo_material_dumping.field_dump_total for this WO.
    $dumpTotal = get_special_mowing_total_dump_fees($workOrderId);
    if ($dumpTotal > 0) {
        $entity->set('field_dump_fee_total', $dumpTotal);
        $grand_total += $dumpTotal;
    }

    // Rental fees — supports both receipt-cost AND hourly-rented equipment.
    $rental_fee_total = get_special_mowing_total_rental_fees($workOrderId);
    if ($rental_fee_total > 0) {
        $entity->set('field_rental_total', $rental_fee_total);
        $grand_total += $rental_fee_total;
    }

    // Office billing adjustment.
    $billingAdjustment = $entity->get('field_billing_adjustment')->value;
    $grand_total += $billingAdjustment;

    if ($grand_total > 0) {
        $entity->set('field_wo_total', $grand_total);
    }
}

/**
 * Calculates the total Materials for a given Work Order.
 */
function get_total_special_mowing_material_list_price($workOrderId) {
    $database = \Drupal::database();
    $query = $database->select('wo_material_list_item__field_subtotal_w_markup', 'subtotal');
    $query->join('wo_material_list_item', 'items', 'subtotal.entity_id = items.id');
    $query->join('wo_material_list_item__field_list_id', 'list_id', 'items.id = list_id.entity_id');
    $query->join('wo_material_list__field_work_order', 'work_order', 'list_id.field_list_id_target_id = work_order.entity_id');
    $query->condition('work_order.field_work_order_target_id', $workOrderId);
    $query->addExpression('SUM(subtotal.field_subtotal_w_markup_value)', 'total_subtotal_w_markup');
    $result = $query->execute()->fetchField();
    return $result ? $result : 0;
}

/**
 * Sum of dump fees on this WO. Mirrors wo_fall_cleanup pattern.
 */
function get_special_mowing_total_dump_fees($workOrderId) {
    $database = \Drupal::database();
    $query = $database->select('wo_material_dumping__field_dump_total', 'dump_fees');
    $query->join('wo_material_dumping__field_work_order', 'work_order', 'dump_fees.entity_id = work_order.entity_id');
    $query->condition('work_order.field_work_order_target_id', $workOrderId);
    $query->addExpression('SUM(dump_fees.field_dump_total_value)', 'total_dump_fee');
    $result = $query->execute()->fetchField();
    return $result ? $result : 0;
}

/**
 * Sum of rental fees on this WO. Mirrors wo_sprinkler_repair pattern —
 * COALESCE bills receipt cost when present, otherwise hourly_rate × hours.
 */
function get_special_mowing_total_rental_fees($workOrderId) {
    $database = \Drupal::database();
    $query = $database->select('wo_rental_equipment__field_rented_for', 'wrf');
    $query->condition('wrf.field_rented_for_target_id', $workOrderId);
    $query->condition('wrf.deleted', 0);
    $query->leftJoin('wo_rental_equipment__field_hourly_rate', 'hr', 'hr.entity_id = wrf.entity_id AND hr.deleted = 0');
    $query->leftJoin('wo_rental_equipment__field_hours', 'h', 'h.entity_id = wrf.entity_id AND h.deleted = 0');
    $query->leftJoin('wo_rental_equipment__field_receipt_total_cost', 'rtc', 'rtc.entity_id = wrf.entity_id AND rtc.deleted = 0');
    $query->addExpression(
        'SUM(COALESCE(rtc.field_receipt_total_cost_value, hr.field_hourly_rate_value * h.field_hours_value, 0))',
        'total_rental_fee'
    );
    $result = $query->execute()->fetchField();
    return $result ? (float) $result : 0.0;
}

/**
 * Retrieves the hours clocked in for special_mowing from related
 * wo_time_clock entities.
 */
function get_hours_for_special_mowing($workOrderId) {
    if (!is_numeric($workOrderId) || $workOrderId < 1 || !\Drupal::entityTypeManager()->getStorage('work_order')->load($workOrderId)) {
        return 0;
    }
    $hoursSpent = 0;
    $woTimeClockEntities = \Drupal::entityTypeManager()->getStorage('wo_time_clock')->loadByProperties([
        'field_work_order' => $workOrderId,
    ]);
    foreach ($woTimeClockEntities as $entity) {
        if ($entity->bundle() === 'entry') {
            $hours = $entity->get('field_total_time')->value;
            $hoursSpent += $hours;
        }
    }
    return $hoursSpent;
}
