<?php

use Drupal\flag\FlaggingInterface;
use Drupal\Core\Datetime\DrupalDateTime;

/**
 * Implements hook_flagging_insert().
 */
function wo_timer_flag_update_flagging_insert(FlaggingInterface $flagging) {
    // Check if the flag is 'work_order_timer' and the entity is of type 'work_order'.
    if ($flagging->getFlagId() === 'work_order_timer' && $flagging->getFlaggable()->getEntityTypeId() === 'work_order') {
      // Load the current user
      $current_user = \Drupal::currentUser();

      // Load the flagged work_order entity
      $work_order = $flagging->getFlaggable();


      // Read the WO's CURRENT persisted status (the flaggable is freshly
      // loaded by the flag system at clock-in time — not a stale form value).
      $current_status = (int) $work_order->get('field_status')->target_id;

      // Governance immutability rule: a clock-in must NOT silently revert a
      // closed/terminal Work Order back to In Progress. Crew clock back in to
      // add a forgotten time/material entry after sign-off — that entry must
      // still save (it does, below, outside this block), but the status flip
      // is suppressed. Terminal set: 1097 Complete, 1283 Warrantied,
      // 1281 Invoiced, 1504 Paid, 1098 Canceled. All other statuses keep
      // today's behavior (Open/Scheduled/Assigned/blocker states promote to
      // In Progress; In Progress is already a no-op). Skipping here is
      // side-effect-free: no wo_status_updates record is created, so the
      // wo_status_updates propagation never runs and the WO is never saved.
      $terminal_statuses = [1097, 1283, 1281, 1504, 1098];

      // Check if the current status is not 'In Progress' (1092) and not closed.
      if ($current_status != 1092 && !in_array($current_status, $terminal_statuses, TRUE)) {
            // Update the 'field_status' of the work_order entity to 'In Progress'
            //$work_order->set('field_status', 1092); // Term ID for 'In Progress'
            //$work_order->save();

            // Create a new 'wo_status_updates' entity
            $wo_status_updates = \Drupal::entityTypeManager()
            ->getStorage('wo_status_updates')
            ->create([
                'type' => 'update', // The bundle name for 'wo_status_updates'
                'field_status_of_wo' => $work_order->id(),
                'field_status' => 1092, // The taxonomy term ID for 'In Progress'
                'field_status_change_note' => ['value' => 'Teammate Clocked In'],
                'uid' => $current_user->id(),
            ]);

            // Save the new 'wo_status_updates' entity
            $wo_status_updates->save();
        }

      // Create a new 'wo_time_clock' entity
      $wo_time_clock = \Drupal::entityTypeManager()
        ->getStorage('wo_time_clock')
        ->create([
          'type' => 'entry',
          'field_work_order' => $flagging->getFlaggable()->id(),
          'field_notes' => 'Start time entered through system',
          'field_start_time' => DrupalDateTime::createFromTimestamp(time(), new \DateTimeZone('UTC'))->format('Y-m-d\TH:i:s'),
          // Explicitly NULL — overrides the field's default_date: 'now' config.
          // Active clock-ins must have NULL end_time so AnomalyDetectionService
          // and Phase 2 reconciliation can detect them via notExists('field_end_time').
          'field_end_time' => NULL,
          'uid' => $current_user->id(),
          'field_teammate' => $current_user->id(),
        ]);
  
      // Save the new 'wo_time_clock' entity and get its ID
      $wo_time_clock->save();
      $wo_time_clock_id = $wo_time_clock->id();
  
      // Update the 'field_wo_timer_entered' field in the 'work_order_timer' flag
      $flagging->set('field_wo_timer_entered', $wo_time_clock_id);
      $flagging->save();
    }
  }

/**
 * Implements hook_flagging_delete().
 */
function wo_timer_flag_update_flagging_delete(FlaggingInterface $flagging) {
    // Check if the unflagged entity is a 'work_order' and the flag is 'work_order_timer'.
    if ($flagging->getFlagId() === 'work_order_timer' && $flagging->getFlaggable()->getEntityTypeId() === 'work_order') {
      // Retrieve the associated 'wo_time_clock' entity.
      $wo_time_clock_id = $flagging->field_wo_timer_entered->target_id;
      $wo_time_clock = \Drupal::entityTypeManager()
        ->getStorage('wo_time_clock')
        ->load($wo_time_clock_id);
  
      if ($wo_time_clock) {
        // Skip if the entry has already been closed (e.g., by Phase 2c
        // sign-off reconciliation that ran before the cascade fired,
        // or by manual office cleanup that pre-closed the entry).
        // The flag deletion itself still completes; we just don't
        // clobber an already-populated end_time or its audit trail.
        if ($wo_time_clock->get('field_end_time')->isEmpty()) {
          $wo_time_clock->set('field_end_time', DrupalDateTime::createFromTimestamp(time(), new \DateTimeZone('UTC'))->format('Y-m-d\TH:i:s'));

          // field_notes is multi-value (cardinality -1). Append a new
          // item so the two system notes render as two separate
          // entries in the form widget rather than being concatenated
          // into one varchar(255) line where the "\n" is invisible.
          $wo_time_clock->get('field_notes')->appendItem('End Time entered by system');

          // Save the updated entity. The single-entry cap guard
          // (_wo_total_time_validate_time_clock_entry) rejects an
          // end=now close that would exceed the bundle's cap. The
          // smart Clock-Out button routes interactive over-cap
          // clock-outs to the edit form before they ever reach here,
          // so this should only throw on a *programmatic* unflag
          // (wo_lawn_mowing / wo_snow_removal task completion) of an
          // over-cap entry. Don't let that fatal the flag delete —
          // log it and leave the entry open for correction; the
          // smart button / AnomalyDetection will surface it.
          try {
            $wo_time_clock->save();
          }
          catch (\Drupal\Core\Entity\EntityStorageException $e) {
            \Drupal::logger('wo_timer_flag_update')->warning(
              'Clock-out for wo_time_clock @id (WO @wo) rejected by the single-entry cap guard on a programmatic unflag. '
              . 'Entry left OPEN for correction. Message: @msg',
              [
                '@id' => $wo_time_clock->id(),
                '@wo' => $flagging->getFlaggable() ? $flagging->getFlaggable()->id() : 'unknown',
                '@msg' => $e->getMessage(),
              ]
            );
          }
        }
      }
      else {
        // Phase 2d: silent-no-op visibility. The flag's
        // field_wo_timer_entered points at a wo_time_clock that
        // doesn't load — either deleted, never created, or pointing
        // at a stale ID. Without this log, the user's clock-out tap
        // appears to succeed (the flag is removed) but no end_time
        // gets written and no record of the failure exists.
        $flaggable = $flagging->getFlaggable();
        \Drupal::logger('wo_timer_flag_update')->warning(
          'Clock-out flag delete fired but field_wo_timer_entered references no valid wo_time_clock entity. '
          . 'target_id: @target_id, user: @uid, flag_id: @flag_id, work_order_id: @wo_id. '
          . 'Clock-out was silently skipped — user may believe their tap succeeded but no end_time was written.',
          [
            '@target_id' => $wo_time_clock_id ?? 'NULL',
            '@uid' => \Drupal::currentUser()->id(),
            '@flag_id' => $flagging->id(),
            '@wo_id' => $flaggable ? $flaggable->id() : 'unknown',
          ]
        );
      }
    }
  }

/**
 * Implements hook_preprocess_flag().
 */
function wo_timer_flag_update_preprocess_flag(&$variables) {
  $flag = $variables['flag'] ?? NULL;
  // Check if the flag is the "work_order_timer" flag.
  if ($flag && $flag->id() === 'work_order_timer') {
    // Get the flag service and current user.
    $flag_service = \Drupal::service('flag');
    $current_user = \Drupal::currentUser();
    $entity = $variables['flaggable'] ?? NULL;

    // Determine flag state.
    $is_flagged = FALSE;
    if (isset($variables['attributes']['href'])) {
      $href = $variables['attributes']['href'];
      // If the URL contains "/unflag/", the entity is flagged.
      if (strpos($href, '/flag/unflag/work_order_timer/') !== FALSE) {
        $is_flagged = TRUE;
      }
    } elseif ($entity && $entity->getEntityTypeId() === 'work_order') {
      // Use the flag service to check if the entity is flagged by the current user.
      $is_flagged = $flag_service->getFlagging($flag, $entity, $current_user) !== NULL;
    }

    // Set the CSS class based on flag state.
    $flag_state_class = $is_flagged ? 'flag-state-flagged' : 'flag-state-unflagged';

    // Set the link text for accessibility.
    $link_text = $is_flagged ? 'Clock Out' : 'Clock In';

    // Ensure link_text is set with visually-hidden span and icon span.
    $variables['link_text'] = [
      '#type' => 'inline_template',
      '#template' => '<span class="visually-hidden">{{ link_text }}</span><span class="flag-timer-icon {{ flag_state_class }}" aria-hidden="true"></span>',
      '#context' => [
        'link_text' => $link_text,
        'flag_state_class' => $flag_state_class,
      ],
    ];

    // Set the title attribute and provide fallback for template.
    $variables['title'] = $link_text;
    $variables['link_text_raw'] = $link_text;

    // Add custom CSS classes without overwriting existing ones.
    if (!isset($variables['attributes']['class'])) {
      $variables['attributes']['class'] = [];
    }
    $variables['attributes']['class'] = array_unique(array_merge(
      $variables['attributes']['class'],
      [
        'flag',
        'flag-work-order-timer',
        'js-flag-work-order-timer-' . ($entity ? $entity->id() : 'unknown'),
        $is_flagged ? 'action-unflag' : 'action-flag',
        'flag-timer-icon',
        $flag_state_class,
      ]
    ));

    // Attach the custom CSS library.
    $variables['#attached']['library'][] = 'wo_timer_flag_update/flag-timer';

    // Smart Clock-Out: if the open entry has already been running
    // longer than the bundle's single-entry cap, the one-tap unflag
    // would stamp end=now and be rejected by the cap guard. Instead,
    // point the Clock-Out link at the entry's edit form so the
    // teammate confirms the real end time (or checks the override).
    // Saving there closes the entry; wo_timer_flag_update_wo_time_clock_update
    // then removes the timer flag (flag-off-on-close invariant).
    // Only the over-cap case diverts — normal clock-outs (≈96% of
    // entries, well under the cap) keep the one-tap behavior.
    if ($is_flagged && $entity && $entity->getEntityTypeId() === 'work_order') {
      $flagging = $flag_service->getFlagging($flag, $entity, $current_user);
      if ($flagging
          && $flagging->hasField('field_wo_timer_entered')
          && !$flagging->get('field_wo_timer_entered')->isEmpty()) {
        $tc_id = $flagging->get('field_wo_timer_entered')->target_id;
        $tc = \Drupal::entityTypeManager()->getStorage('wo_time_clock')->load($tc_id);
        if ($tc
            && $tc->hasField('field_start_time')
            && !$tc->get('field_start_time')->isEmpty()
            && $tc->get('field_end_time')->isEmpty()) {
          $start_ts = strtotime((string) $tc->get('field_start_time')->value . 'Z');
          if ($start_ts) {
            $elapsed_hours = (\Drupal::time()->getRequestTime() - $start_ts) / 3600;
            $cap = function_exists('_wo_total_time_get_max_entry_hours')
              ? _wo_total_time_get_max_entry_hours($entity->bundle())
              : 4.0;
            if ($elapsed_hours > $cap) {
              $dest = \Drupal::request()->getRequestUri();
              $url = \Drupal\Core\Url::fromRoute(
                'entity.wo_time_clock.edit_form',
                ['wo_time_clock' => $tc_id],
                ['query' => ['destination' => $dest]]
              );
              $variables['attributes']['href'] = $url->toString();
              $review_text = 'Clock Out — confirm time';
              $variables['title'] = $review_text;
              $variables['link_text_raw'] = $review_text;
              $variables['link_text'] = [
                '#type' => 'inline_template',
                '#template' => '<span class="visually-hidden">{{ t }}</span><span class="flag-timer-icon flag-state-flagged flag-timer-review" aria-hidden="true"></span>',
                '#context' => ['t' => $review_text],
              ];
              $variables['attributes']['class'][] = 'flag-timer-review';
            }
          }
        }
      }
    }

  }
}

/**
 * Implements hook_ENTITY_TYPE_update() for wo_time_clock entities.
 *
 * Flag-off-on-close invariant: when an entry's field_end_time
 * transitions from empty to set (by ANY path — the edit form the
 * smart Clock-Out button routes to, sign-off reconciliation, manual
 * correction), remove any work_order_timer flagging that points at
 * this entry. This makes "entry closed ⇒ clocked out" true
 * regardless of how the close happened.
 *
 * No loop / no double-stamp: unflag() fires
 * wo_timer_flag_update_flagging_delete(), whose existing guard skips
 * when field_end_time is already populated (which it now is).
 */
function wo_timer_flag_update_wo_time_clock_update(\Drupal\Core\Entity\EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'wo_time_clock' || $entity->bundle() !== 'entry') {
    return;
  }
  $original = $entity->original ?? NULL;
  $was_open = $original ? $original->get('field_end_time')->isEmpty() : TRUE;
  $now_closed = !$entity->get('field_end_time')->isEmpty();
  if (!$was_open || !$now_closed) {
    return;
  }

  $flaggings = \Drupal::entityTypeManager()->getStorage('flagging')->loadByProperties([
    'flag_id' => 'work_order_timer',
    'field_wo_timer_entered' => $entity->id(),
  ]);
  if (empty($flaggings)) {
    return;
  }
  $flag_service = \Drupal::service('flag');
  foreach ($flaggings as $flagging) {
    $flag = $flagging->getFlag();
    $flaggable = $flagging->getFlaggable();
    if ($flag && $flaggable) {
      $flag_service->unflag($flag, $flaggable, $flagging->getOwner());
    }
  }
}

/**
 * Implements hook_module_implements_alter().
 */
function wo_timer_flag_update_module_implements_alter(&$implementations, $hook) {
  if ($hook === 'preprocess_flag' && isset($implementations['wo_timer_flag_update'])) {
    // Move wo_timer_flag_update to the end to run last.
    $group = $implementations['wo_timer_flag_update'];
    unset($implementations['wo_timer_flag_update']);
    $implementations['wo_timer_flag_update'] = $group;
  }
}