<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\EntityStorageException;
use Drupal\Core\Form\FormStateInterface;
use Drupal\datetime\Plugin\Field\FieldType\DateTimeItemInterface;

/**
 * Future-time grace window in minutes. start_time / end_time values up to
 * this many minutes ahead of "now" are accepted (clock skew tolerance).
 */
const WO_TOTAL_TIME_FUTURE_GRACE_MINUTES = 5;

/**
 * Default long-shift threshold in hours, used as fallback when
 * business_setting.field_long_shift_hours is unavailable. Live value
 * should always come from that field — see
 * _wo_total_time_get_long_shift_hours().
 */
const WO_TOTAL_TIME_DEFAULT_LONG_SHIFT_HOURS = 16.0;

/**
 * Default single-entry caps in hours, used as fallback when the
 * business_setting fields are unavailable/empty. Live values should
 * come from business_setting.field_max_entry_hours /
 * field_max_entry_hours_long — see _wo_total_time_get_max_entry_hours().
 *
 * A single wo_time_clock entry (one clock-in to clock-out) exceeding
 * the applicable cap is rejected at presave unless
 * field_time_limit_override is checked (or an admin/sign-off bypass
 * applies). No legitimate single continuous session on one WO runs
 * this long — a real long day is multiple WOs and/or breaks (which
 * are separate clock-in/out cycles = separate entries).
 */
const WO_TOTAL_TIME_DEFAULT_MAX_ENTRY_HOURS = 4.0;
const WO_TOTAL_TIME_DEFAULT_MAX_ENTRY_HOURS_LONG = 14.0;

/**
 * work_order bundles where genuinely long single sessions occur, so
 * they use the elevated cap (field_max_entry_hours_long) instead of
 * the standard one. Hardcoded by design — same pattern as the
 * $excludedBundles / COMPLEX_BUNDLES lists elsewhere.
 */
const WO_TOTAL_TIME_LONG_JOB_BUNDLES = [
  'landscaping',
  'sprinkler_repair',
  'sprinkler_installation',
];

/**
 * Implements hook_entity_presave().
 *
 * Two responsibilities, in order:
 *
 *   1. Phase 1 data integrity guards. Five hard checks that throw
 *      EntityStorageException when violated. Catches manual edits,
 *      REST writes, imports, and any future programmatic save path.
 *      The cancellation of the save propagates to the caller — Drupal
 *      lets the exception bubble out of presave naturally.
 *
 *   2. Existing computation logic (preserved unchanged):
 *      - field_total_time roll-up from start/end
 *      - manual-entry ownership reassignment based on field_teammate
 *
 * Phase 2 will modify (2) to skip ownership reassignment when the
 * _signoff_reconciliation context flag is set on the entity. Do not
 * change that logic in Phase 1.
 */
function wo_total_time_entity_presave(EntityInterface $entity) {
  if ($entity->getEntityTypeId() === 'wo_time_clock') {
    // Phase 1 — data integrity guards. May throw.
    _wo_total_time_validate_time_clock_entry($entity);

    // Existing logic for calculating total time.
    if ($entity->hasField('field_start_time') && $entity->hasField('field_end_time')) {
      $startTime = $entity->get('field_start_time')->date;
      $endTime = $entity->get('field_end_time')->date;

      if ($startTime && $endTime) {
        $timeDifference = $endTime->getTimestamp() - $startTime->getTimestamp();
        $hours = round($timeDifference / 3600, 2);
        if ($entity->hasField('field_total_time')) {
          $entity->set('field_total_time', $hours);
        }
      }
      elseif ($entity->hasField('field_total_time')) {
        $entity->set('field_total_time', NULL);
      }
    }

    // Debug: Capture request and entity details.
    $request = \Drupal::request();
    $route = $request->get('_route') ?: 'No route';
    $method = $request->getMethod();
    $current_user = \Drupal::currentUser()->id();
    $teammate_id = $entity->hasField('field_teammate') && !$entity->get('field_teammate')->isEmpty() ? $entity->get('field_teammate')->target_id : 'None';
    $original_uid = $entity->getOwnerId();

    // Simplified manual entry check: Any POST request for now.
    // TODO Phase 2: skip this block when $entity->_signoff_reconciliation
    // is set, to allow sign-off-time reconciliation to write entries
    // owned by the actual teammate without reassignment side effects.
    $is_manual_entry = $request->getMethod() === 'POST';

    if ($is_manual_entry && $entity->hasField('field_teammate') && !$entity->get('field_teammate')->isEmpty()) {
      $teammate_id = $entity->get('field_teammate')->target_id;
      if ($teammate_id && $teammate_id != $entity->getOwnerId()) {
        $entity->setOwnerId($teammate_id);
        \Drupal::logger('wo_total_time')->notice('UID updated from @old to @new for manual entry', [
          '@old' => $original_uid,
          '@new' => $teammate_id,
        ]);
      }
      else {
        \Drupal::logger('wo_total_time')->notice('No UID change needed: Teammate=@teammate, OriginalUID=@uid', [
          '@teammate' => $teammate_id,
          '@uid' => $original_uid,
        ]);
      }
    }

    // Phase 1 extension: reverse auto-sync. When field_teammate is
    // empty AND uid is populated and non-anonymous, sync field_teammate
    // FROM uid. Common case: a teammate manually enters their own time
    // via the standalone form and doesn't notice the field_teammate
    // field. Without this sync the entry stays attributed to "no one"
    // via field_teammate, which breaks downstream consumers
    // (Phase 2 reconciliation, variance dashboard per-teammate
    // queries) that key on field_teammate rather than uid.
    //
    // Runs on all save paths, not just POST. Programmatic writes that
    // fail to set field_teammate are also bug paths worth correcting.
    //
    // Does NOT fire when field_teammate is already populated (preserves
    // legitimate office-staff-on-behalf attribution where uid !=
    // field_teammate). Does NOT fire when uid is anonymous (uid 0) —
    // leaves edge-case entries alone.
    if ($entity->hasField('field_teammate') && $entity->get('field_teammate')->isEmpty()) {
      $owner_uid = (int) $entity->getOwnerId();
      if ($owner_uid > 0) {
        $entity->set('field_teammate', $owner_uid);
      }
    }
  }
}

/**
 * Implements hook_entity_update().
 */
function wo_total_time_entity_update(EntityInterface $entity) {
  _wo_total_time_trigger_wo_recalc($entity);
}

/**
 * Implements hook_entity_insert().
 */
function wo_total_time_entity_insert(EntityInterface $entity) {
  _wo_total_time_trigger_wo_recalc($entity);
}

/**
 * Implements hook_ENTITY_TYPE_presave() for work_order entities.
 *
 * Recalculates field_total_time = sum(wo_time_clock.field_total_time)
 * for the WO's closed clock entries. Gates on Complete status (1097)
 * only:
 *   - Pre-completion WOs are skipped — clock data is mid-flight and a
 *     partial total would mislead anyone reading the WO.
 *   - Invoiced (1281), Paid (1504), Canceled (1098), and Warrantied
 *     (1283) are all skipped implicitly because they're not Complete —
 *     once a WO leaves the Complete state, the captured-at-billing-time
 *     value is preserved.
 *
 * For lawn_mowing WOs, wo_lawn_mowing also recalculates field_total_time
 * on save (along with field_labor_total and other bundle-specific
 * derived fields). Both produce the same value here — sum of clock
 * entries, no multiplier — so the redundancy is idempotent.
 *
 * Combined with the existing wo_time_clock insert/update hooks that
 * trigger a parent WO save, this completes the chain: editing a clock
 * entry on a Complete WO will now flow through to a refreshed total.
 */
function wo_total_time_work_order_presave(EntityInterface $entity) {
  if ($entity->isNew()) {
    return;
  }
  if (!$entity->hasField('field_total_time')) {
    return;
  }
  $status = (int) ($entity->get('field_status')->target_id ?? 0);
  if ($status !== 1097) {
    return;
  }

  $tcIds = \Drupal::entityQuery('wo_time_clock')
    ->accessCheck(FALSE)
    ->condition('field_work_order', $entity->id())
    ->condition('field_end_time', NULL, 'IS NOT NULL')
    ->execute();

  $sum = 0.0;
  if ($tcIds) {
    foreach (\Drupal::entityTypeManager()->getStorage('wo_time_clock')->loadMultiple($tcIds) as $tc) {
      $sum += (float) ($tc->get('field_total_time')->value ?? 0);
    }
  }

  $entity->set('field_total_time', round($sum, 2));
}

/**
 * Implements hook_form_alter().
 *
 * Phase 1 Layer B — friendly inline form-layer validation that mirrors
 * presave guards 1–3 and adds a soft confirmation flow for unusually
 * long shifts (> field_long_shift_hours from business_setting).
 *
 * Detection by element presence rather than form_id pattern so this
 * works for the standalone wo_time_clock add/edit form, the inline
 * entity form embed, and any future composed forms.
 */
function wo_total_time_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (!_wo_total_time_form_targets_time_clock($form, $form_state)) {
    return;
  }

  // Consolidation: the persistent field_time_limit_override checkbox
  // (Guard 6 / per-bundle 4-or-14hr cap, records an audit note) covers
  // the same user intent as this form-only AM/PM safety confirm. When
  // it is present on the form, suppress the duplicate checkbox so the
  // user sees only one "yes this is intentional" control. The validator
  // accepts either as confirmation of the long-shift case.
  if (!isset($form['field_time_limit_override'])) {
    // Fallback only — every wo_time_clock entry carries
    // field_time_limit_override, so this branch is reached only if a
    // future form display omits the field. Weight 50 puts the checkbox
    // just above the actions container (default #weight 100), so the
    // confirm and the Save button are visually adjacent rather than
    // the checkbox sitting orphaned below the buttons.
    $form['long_shift_confirmed'] = [
      '#type' => 'checkbox',
      '#title' => t('Yes, this long shift is correct'),
      '#description' => t("Only check this box if you are intentionally entering a shift over @h hours. Otherwise the entry will be rejected as a likely AM/PM error.", [
        '@h' => rtrim(rtrim(number_format(_wo_total_time_get_long_shift_hours(), 1), '0'), '.'),
      ]),
      '#default_value' => 0,
      '#weight' => 50,
    ];
  }

  $form['#validate'][] = '_wo_total_time_form_validate';

  // "Copy times from first teammate" UX (2026-06-03).
  //
  // When the crew lead enters multiple teammates' time entries on the
  // same WO, the start/end times are usually identical across teammates.
  // Show a one-click "Copy times" affordance at the top of the ADD
  // form when (a) the form is for a new entry, (b) field_work_order
  // is pre-filled (typical: the "Enter Manually" button on the WO page
  // passes ?edit[field_work_order][widget][0][target_id]=N), and
  // (c) at least one wo_time_clock entry already exists for that WO.
  //
  // JS-only fill — no AJAX round-trip. Times are pre-formatted in the
  // site's timezone before embedding so the JS just sets input.value
  // directly on the datetime_default widget's date + time inputs.
  // field_teammate is NOT copied (different per row).
  _wo_total_time_form_add_copy_from_first($form, $form_state);
}

/**
 * Inject the "Copy times from first teammate" affordance on the ADD
 * form when there's an existing entry to copy from.
 */
function _wo_total_time_form_add_copy_from_first(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object || !method_exists($form_object, 'getEntity')) {
    return;
  }
  $entity = $form_object->getEntity();
  if (!$entity instanceof EntityInterface || !$entity->isNew()) {
    // Edit forms don't need this — the entity already has its own times.
    return;
  }

  $wo_id = _wo_total_time_get_wo_id_from_form($form, $form_state);
  if ($wo_id <= 0) {
    // No WO context yet (free-form add from the wo_time_clock content
    // list with no pre-fill). The copy UI requires knowing which WO
    // to look up; bail quietly.
    return;
  }

  $first = _wo_total_time_get_first_entry_for_wo($wo_id);
  if (!$first) {
    return;
  }

  $start_raw = (string) ($first->get('field_start_time')->value ?? '');
  $end_raw = (string) ($first->get('field_end_time')->value ?? '');
  if ($start_raw === '' || $end_raw === '') {
    return;
  }

  // Datetime fields store UTC ISO strings; the widget displays in the
  // site's default timezone. Pre-format here so the JS doesn't have
  // to do TZ math.
  $tz = new \DateTimeZone(date_default_timezone_get());
  try {
    $start_dt = new \DateTime($start_raw . 'Z');
    $start_dt->setTimezone($tz);
    $end_dt = new \DateTime($end_raw . 'Z');
    $end_dt->setTimezone($tz);
  }
  catch (\Throwable $e) {
    return;
  }

  $teammate_name = '(unknown teammate)';
  if (!$first->get('field_teammate')->isEmpty()) {
    $teammate_entity = $first->get('field_teammate')->entity;
    if ($teammate_entity) {
      $teammate_name = (string) $teammate_entity->getDisplayName();
    }
  }

  $start_display = $start_dt->format('m/d/Y g:i A');
  $end_display = $end_dt->format('m/d/Y g:i A');

  $form['bos_wtc_copy_from_first'] = [
    '#type' => 'container',
    '#weight' => -100,
    '#attributes' => ['class' => ['bos-wtc-copy-from-first']],
    'summary' => [
      '#type' => 'item',
      '#markup' => t(
        '<p><strong>First entry on this WO:</strong> @name worked <strong>@start</strong> – <strong>@end</strong>.</p>',
        ['@name' => $teammate_name, '@start' => $start_display, '@end' => $end_display]
      ),
    ],
    'button' => [
      '#type' => 'button',
      '#value' => t('Copy these times'),
      '#attributes' => [
        // type=button keeps the browser from treating Enter on this
        // button as a form submit (the button is JS-only).
        'type' => 'button',
        'class' => ['bos-wtc-copy-btn', 'button'],
        'data-scope' => 'form',
        'data-start-date' => $start_dt->format('Y-m-d'),
        'data-start-time' => $start_dt->format('H:i:s'),
        'data-end-date' => $end_dt->format('Y-m-d'),
        'data-end-time' => $end_dt->format('H:i:s'),
      ],
    ],
    'note' => [
      '#type' => 'item',
      '#markup' => '<p><em>' . t('Pick the teammate this entry belongs to below, then save. You can adjust the times after copying if this person worked a different shift.') . '</em></p>',
    ],
  ];
  $form['#attached']['library'][] = 'wo_total_time/copy_from_first';
}

/**
 * Resolve the work_order id from the wo_time_clock add form.
 *
 * Priority:
 *   1. $form_state values (after submit / rebuild)
 *   2. The widget's default value (initial render — populated from the
 *      ?edit[field_work_order][widget][0][target_id]=N URL query param
 *      that the "Enter Manually" button on the WO page sets)
 */
function _wo_total_time_get_wo_id_from_form(array $form, FormStateInterface $form_state): int {
  $values = $form_state->getValues();
  if (!empty($values['field_work_order'][0]['target_id'])) {
    return (int) $values['field_work_order'][0]['target_id'];
  }
  if (isset($form['field_work_order']['widget'][0]['target_id']['#default_value'])) {
    $default = $form['field_work_order']['widget'][0]['target_id']['#default_value'];
    if (is_object($default) && method_exists($default, 'id')) {
      return (int) $default->id();
    }
    if (is_array($default) && !empty($default['target_id'])) {
      return (int) $default['target_id'];
    }
    if (is_numeric($default)) {
      return (int) $default;
    }
  }
  return 0;
}

/**
 * Load the earliest (by entity id, i.e., "first created") wo_time_clock
 * entry for a given work order that has both start and end times set.
 * Returns NULL when no usable entry exists yet.
 */
function _wo_total_time_get_first_entry_for_wo(int $wo_id): ?EntityInterface {
  if ($wo_id <= 0) {
    return NULL;
  }
  try {
    $ids = \Drupal::entityTypeManager()->getStorage('wo_time_clock')->getQuery()
      ->accessCheck(FALSE)
      ->condition('field_work_order', $wo_id)
      ->exists('field_start_time')
      ->exists('field_end_time')
      ->sort('id', 'ASC')
      ->range(0, 1)
      ->execute();
  }
  catch (\Throwable $e) {
    return NULL;
  }
  if (!$ids) {
    return NULL;
  }
  return \Drupal::entityTypeManager()->getStorage('wo_time_clock')->load((int) reset($ids));
}

/**
 * Form validate handler for wo_time_clock add/edit forms.
 *
 * Mirrors presave guards 1–3 (end-before-start, future start, future
 * end) so the user gets inline errors before submit completes — better
 * UX than a hard exception. Then enforces the soft >long-shift-hours
 * confirmation requirement.
 *
 * The presave-layer guards are still active and will catch anything
 * the form misses (defense in depth).
 */
function _wo_total_time_form_validate(array &$form, FormStateInterface $form_state): void {
  $start = _wo_total_time_form_value_to_timestamp($form_state, 'field_start_time');
  $end = _wo_total_time_form_value_to_timestamp($form_state, 'field_end_time');
  $now = \Drupal::time()->getRequestTime();
  $grace = WO_TOTAL_TIME_FUTURE_GRACE_MINUTES * 60;

  if ($start !== NULL && $end !== NULL && $end < $start) {
    $form_state->setErrorByName(
      'field_end_time',
      t('End time (@e) is before start time (@s). Please verify the date and AM/PM.', [
        '@e' => date('m/d/Y g:i A', $end),
        '@s' => date('m/d/Y g:i A', $start),
      ])
    );
  }
  if ($start !== NULL && $start > $now + $grace) {
    $form_state->setErrorByName(
      'field_start_time',
      t('Start time (@s) is in the future. Time entries cannot be dated forward.', [
        '@s' => date('m/d/Y g:i A', $start),
      ])
    );
  }
  if ($end !== NULL && $end > $now + $grace) {
    $form_state->setErrorByName(
      'field_end_time',
      t('End time (@e) is in the future.', [
        '@e' => date('m/d/Y g:i A', $end),
      ])
    );
  }

  // Soft >long-shift-hours confirmation. Only triggered when start and
  // end are both set and produce a positive duration — the other guards
  // already covered the bad-data cases.
  //
  // Confirmation can come from either checkbox: the persistent
  // field_time_limit_override (Guard 6 / per-bundle cap, also records
  // an audit note) when present, or the form-only long_shift_confirmed
  // fallback. One tick of either satisfies this validator.
  if ($start !== NULL && $end !== NULL && $end >= $start) {
    $hours = ($end - $start) / 3600;
    $threshold = _wo_total_time_get_long_shift_hours();
    if ($hours > $threshold) {
      $tlo = $form_state->getValue(['field_time_limit_override', 0, 'value']);
      $confirmed = !empty($form_state->getValue('long_shift_confirmed'))
        || !empty($tlo);
      if (!$confirmed) {
        $has_persistent = isset($form['field_time_limit_override']);
        $error_target = $has_persistent ? 'field_time_limit_override' : 'long_shift_confirmed';
        $box_label    = $has_persistent
          ? t('This long entry is correct (override time limit)')
          : t('Yes, this long shift is correct');
        $form_state->setErrorByName(
          $error_target,
          t('This entry is @h hours, which is over the @t-hour threshold and likely an AM/PM error. If this entry is correct (e.g., a real long shift), check the "@box" box and re-submit.', [
            '@h' => number_format($hours, 1),
            '@t' => rtrim(rtrim(number_format($threshold, 1), '0'), '.'),
            '@box' => $box_label,
          ])
        );
      }
    }
  }
}

/**
 * Phase 1 — five hard data integrity guards on wo_time_clock entries.
 *
 * Throws \Drupal\Core\Entity\EntityStorageException when any guard
 * fails. The exception aborts the save and bubbles to the caller.
 *
 * Guards (in order):
 *
 *   1. END BEFORE START — end_time < start_time (both required for the
 *      check; either being empty skips it).
 *   2. START IN THE FUTURE — start_time > now + grace window.
 *   3. END IN THE FUTURE — end_time > now + grace window.
 *   4. PARENT WO LOCKED — WO status is Invoiced (1281) or Paid (1504),
 *      AND current user lacks 'administer eck entities' (so site_admin
 *      and administrator roles can still bypass), AND this is an
 *      UPDATE not an INSERT. Insert is allowed because legitimate
 *      reasons exist to add new entries on a closed WO via admin tools.
 *      Skipped when $entity->_signoff_reconciliation is set — Phase 2
 *      uses this flag for sign-off-time reconciliation that legitimately
 *      writes entries on closing WOs.
 *   5. CANCELED WO — WO status is 1098 AND current user lacks
 *      'administer eck entities'. Applies to both insert and update —
 *      no new entries should land on a canceled WO.
 *
 * Long-shift (>16 hour) checking is NOT a presave guard — it lives in
 * the form-layer validate handler with a soft confirmation flow, so
 * legitimate long shifts are entry-able without admin intervention.
 */
function _wo_total_time_validate_time_clock_entry(EntityInterface $entity): void {
  $start = ($entity->hasField('field_start_time') && !$entity->get('field_start_time')->isEmpty())
    ? (int) strtotime((string) $entity->get('field_start_time')->value . 'Z')
    : NULL;
  $end = ($entity->hasField('field_end_time') && !$entity->get('field_end_time')->isEmpty())
    ? (int) strtotime((string) $entity->get('field_end_time')->value . 'Z')
    : NULL;
  $now = \Drupal::time()->getRequestTime();
  $grace = WO_TOTAL_TIME_FUTURE_GRACE_MINUTES * 60;

  // Guard 1 — end before start.
  if ($start !== NULL && $end !== NULL && $end < $start) {
    throw new EntityStorageException(sprintf(
      'Time entry rejected: end time (%s) is before start time (%s). Please verify the date and AM/PM.',
      date('m/d/Y g:i A', $end),
      date('m/d/Y g:i A', $start)
    ));
  }

  // Guard 2 — start in the future (with 5-minute grace).
  if ($start !== NULL && $start > $now + $grace) {
    throw new EntityStorageException(sprintf(
      'Time entry rejected: start time (%s) is in the future. Time entries cannot be dated forward.',
      date('m/d/Y g:i A', $start)
    ));
  }

  // Guard 3 — end in the future (with 5-minute grace).
  if ($end !== NULL && $end > $now + $grace) {
    throw new EntityStorageException(sprintf(
      'Time entry rejected: end time (%s) is in the future.',
      date('m/d/Y g:i A', $end)
    ));
  }

  // Guards 4 and 5 — parent WO status checks.
  $wo_id = ($entity->hasField('field_work_order') && !$entity->get('field_work_order')->isEmpty())
    ? (int) $entity->get('field_work_order')->target_id
    : 0;
  if ($wo_id <= 0) {
    return;
  }
  $wo = \Drupal::entityTypeManager()->getStorage('work_order')->load($wo_id);
  if (!$wo || !$wo->hasField('field_status') || $wo->get('field_status')->isEmpty()) {
    return;
  }
  $status_tid = (int) $wo->get('field_status')->target_id;

  // Phase 2 hook: sign-off-time reconciliation legitimately writes
  // entries on closing WOs. The reconciliation code sets this flag on
  // the entity before save to bypass the lock guard. Phase 1 reads
  // the flag but never sets it.
  $is_signoff = !empty($entity->_signoff_reconciliation);

  $is_admin = _wo_total_time_user_can_bypass_lock();

  // Guard 4 — Invoiced / Paid lock. Update only.
  if (!$is_admin && !$is_signoff && !$entity->isNew()) {
    if ($status_tid === 1281 || $status_tid === 1504) {
      throw new EntityStorageException(
        'Time entry cannot be modified: parent Work Order is Invoiced or Paid. Contact a site administrator if a correction is required.'
      );
    }
  }

  // Guard 5 — Canceled WO. Insert AND update.
  if (!$is_admin && $status_tid === 1098) {
    throw new EntityStorageException(
      'Time entry cannot be created or modified: parent Work Order is Canceled.'
    );
  }

  // Guard 6 — single-entry duration cap. A single clock-in to
  // clock-out longer than the bundle's cap is rejected unless the
  // teammate explicitly checks field_time_limit_override (or an admin
  // bypass applies). Deliberately does NOT honor $is_signoff: the
  // Task List silent-close path sets that flag and is exactly the
  // path that produced the WO 49723 / Tanner-style runaway entries —
  // it must be subject to the cap so the close routes to correction
  // instead of silently stamping an 18-hour shift.
  if ($start !== NULL && $end !== NULL) {
    $duration_hours = ($end - $start) / 3600;
    $cap = _wo_total_time_get_max_entry_hours($wo->bundle());
    $override = $entity->hasField('field_time_limit_override')
      && !$entity->get('field_time_limit_override')->isEmpty()
      && (bool) $entity->get('field_time_limit_override')->value;

    if ($duration_hours > $cap && !$override && !$is_admin) {
      throw new EntityStorageException(sprintf(
        'Time entry rejected: this single clock entry is %s hours, over the %s-hour limit for %s work. '
        . 'A real long day is multiple work orders and/or breaks (separate clock-ins). '
        . 'If this entry truly is correct, check "This long entry is correct" on the entry to confirm.',
        number_format($duration_hours, 2),
        number_format($cap, 2),
        $wo->bundle()
      ));
    }

    // Override accepted (or admin) and over cap — stamp an audit note
    // so the deliberate override is traceable. Idempotent: skip if an
    // override note is already present (re-saves shouldn't stack notes).
    if ($duration_hours > $cap && ($override || $is_admin) && $entity->hasField('field_notes')) {
      $already = FALSE;
      foreach ($entity->get('field_notes')->getValue() as $item) {
        if (isset($item['value']) && stripos($item['value'], '[Time limit override') === 0) {
          $already = TRUE;
          break;
        }
      }
      if (!$already) {
        $uid = (int) \Drupal::currentUser()->id();
        $uname = \Drupal::currentUser()->getDisplayName();
        $note = sprintf(
          '[Time limit override: %sh entry exceeds %sh cap for %s — confirmed by %s (uid %d) on %s]',
          number_format($duration_hours, 2),
          number_format($cap, 2),
          $wo->bundle(),
          $uname,
          $uid,
          date('m/d/Y g:i A', \Drupal::time()->getRequestTime())
        );
        $entity->get('field_notes')->appendItem($note);
      }
    }
  }
}

/**
 * Trigger WO billing recalculation when a time clock entry changes.
 *
 * Skips WOs in protected statuses (Invoiced, Paid, Canceled) to
 * prevent accidental billing changes on finalized work orders.
 */
function _wo_total_time_trigger_wo_recalc(EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'wo_time_clock') {
    return;
  }

  $wo_id = $entity->get('field_work_order')->target_id ?? NULL;
  if (!$wo_id) {
    return;
  }

  // Static guard to prevent infinite loops.
  static $processing = [];
  if (isset($processing[$wo_id])) {
    return;
  }
  $processing[$wo_id] = TRUE;

  $wo = \Drupal::entityTypeManager()
    ->getStorage('work_order')
    ->load($wo_id);

  if (!$wo) {
    unset($processing[$wo_id]);
    return;
  }

  // Do NOT recalculate if WO is already Invoiced, Paid, or Canceled.
  $status_tid = (int) ($wo->get('field_status')->target_id ?? 0);
  if (in_array($status_tid, _wo_total_time_get_protected_status_tids(), TRUE)) {
    unset($processing[$wo_id]);
    return;
  }

  $wo->save();
  unset($processing[$wo_id]);
}

/**
 * Single source of truth for WO status TIDs that are "locked" against
 * billing changes: Invoiced (1281), Paid (1504), Canceled (1098).
 *
 * @return int[]
 */
function _wo_total_time_get_protected_status_tids(): array {
  return [1281, 1504, 1098];
}

/**
 * Reads the long-shift threshold from business_setting.
 *
 * Falls back to WO_TOTAL_TIME_DEFAULT_LONG_SHIFT_HOURS (16.0) if the
 * field is missing or empty.
 *
 * @return float
 */
function _wo_total_time_get_long_shift_hours(): float {
  /** @var \Drupal\config_pages\ConfigPagesLoaderServiceInterface $loader */
  $loader = \Drupal::service('config_pages.loader');
  $cfg = $loader->load('business_setting');
  if (!$cfg || !$cfg->hasField('field_long_shift_hours') || $cfg->get('field_long_shift_hours')->isEmpty()) {
    return WO_TOTAL_TIME_DEFAULT_LONG_SHIFT_HOURS;
  }
  $value = $cfg->get('field_long_shift_hours')->value;
  return is_numeric($value) ? (float) $value : WO_TOTAL_TIME_DEFAULT_LONG_SHIFT_HOURS;
}

/**
 * Resolve the single-entry hour cap for a given work_order bundle.
 *
 * Long-job bundles (landscaping, sprinkler_repair,
 * sprinkler_installation) use field_max_entry_hours_long; everything
 * else uses field_max_entry_hours. Each falls back to its code-default
 * constant when the business_setting field is missing/empty/non-numeric.
 *
 * @param string $wo_bundle
 *   The parent work_order bundle machine name.
 *
 * @return float
 *   The cap in hours.
 */
function _wo_total_time_get_max_entry_hours(string $wo_bundle): float {
  $is_long = in_array($wo_bundle, WO_TOTAL_TIME_LONG_JOB_BUNDLES, TRUE);
  $field = $is_long ? 'field_max_entry_hours_long' : 'field_max_entry_hours';
  $default = $is_long
    ? WO_TOTAL_TIME_DEFAULT_MAX_ENTRY_HOURS_LONG
    : WO_TOTAL_TIME_DEFAULT_MAX_ENTRY_HOURS;

  /** @var \Drupal\config_pages\ConfigPagesLoaderServiceInterface $loader */
  $loader = \Drupal::service('config_pages.loader');
  $cfg = $loader->load('business_setting');
  if (!$cfg || !$cfg->hasField($field) || $cfg->get($field)->isEmpty()) {
    return $default;
  }
  $value = $cfg->get($field)->value;
  return is_numeric($value) ? (float) $value : $default;
}

/**
 * Whether the current user can bypass the wo_time_clock lock guards
 * (parent WO Invoiced/Paid/Canceled). Returns TRUE for site_admin and
 * administrator roles; FALSE for everyone else.
 *
 * Uses 'administer eck entities' as the proxy permission since that's
 * the granted-to-site_admin permission that semantically covers
 * "elevated ECK admin access". administrator gets it via is_admin: true.
 *
 * @return bool
 */
function _wo_total_time_user_can_bypass_lock(): bool {
  return \Drupal::currentUser()->hasPermission('administer eck entities');
}

/**
 * Whether the form being altered targets a wo_time_clock entity AND
 * exposes the start/end time fields as editable form elements.
 *
 * The element check excludes confirmation forms (delete, etc.) where
 * the long-shift checkbox and validate handler have nothing to act
 * on. Without it, the checkbox renders on the delete confirm dialog,
 * which is just visual noise (UI bug surfaced 2026-05-03).
 */
function _wo_total_time_form_targets_time_clock(array $form, FormStateInterface $form_state): bool {
  $form_object = $form_state->getFormObject();
  if (!$form_object || !method_exists($form_object, 'getEntity')) {
    return FALSE;
  }
  $entity = $form_object->getEntity();
  if (!$entity instanceof EntityInterface || $entity->getEntityTypeId() !== 'wo_time_clock') {
    return FALSE;
  }
  return isset($form['field_start_time']) && isset($form['field_end_time']);
}

/**
 * Resolve a datetime form value to a UTC timestamp.
 *
 * Drupal datetime widgets submit either a DrupalDateTime instance or
 * an array with 'date'/'time' keys. Returns NULL when the value isn't
 * present or can't be parsed.
 *
 * @return int|null
 */
function _wo_total_time_form_value_to_timestamp(FormStateInterface $form_state, string $field_name): ?int {
  $value = $form_state->getValue([$field_name, 0, 'value']);
  if ($value instanceof \Drupal\Core\Datetime\DrupalDateTime) {
    return $value->getTimestamp();
  }
  if (is_string($value) && $value !== '') {
    $ts = strtotime($value);
    return $ts !== FALSE ? $ts : NULL;
  }
  return NULL;
}

/**
 * Implements hook_preprocess_views_view_field().
 *
 * Office billing safety net on the admin_billing view
 * (/admin/office/work-orders/billing). Detection-only — never blocks
 * invoicing or changes a value, just makes a figure impossible to
 * skim past:
 *
 *  - Hours (field_total_time): RED ⚠ badge when it exceeds the
 *    long-shift threshold (business_setting.field_long_shift_hours,
 *    default 16 — the line AnomalyDetectionService uses). Pairs with
 *    the single-entry cap; catches anything that still slips through.
 *  - Sq. Ft. (field_current_turf_sq_footage): YELLOW box when it is
 *    0 / blank — no sq ft was entered, which the office should chase
 *    down (ask the crew / enter it) before invoicing.
 */
function wo_total_time_preprocess_views_view_field(array &$variables): void {
  $view = $variables['view'] ?? NULL;
  $field = $variables['field'] ?? NULL;
  if (!$view || !$field || $view->id() !== 'admin_billing') {
    return;
  }
  $row = $variables['row'] ?? NULL;
  $entity = ($row && isset($row->_entity)) ? $row->_entity : NULL;
  if (!$entity) {
    return;
  }

  if ($field->field === 'field_total_time') {
    if (!$entity->hasField('field_total_time') || $entity->get('field_total_time')->isEmpty()) {
      return;
    }
    $hours = (float) $entity->get('field_total_time')->value;
    $threshold = _wo_total_time_get_long_shift_hours();
    if ($hours <= $threshold) {
      return;
    }
    $original = $variables['output'] ?? '';
    $variables['output'] = \Drupal\Core\Render\Markup::create(
      '<span style="display:inline-block;background:#c0392b;color:#fff;font-weight:bold;'
      . 'padding:3px 6px;border-radius:3px;" '
      . 'title="Labor hours exceed the ' . (int) $threshold . '-hour review threshold — verify before invoicing">'
      . '&#9888; ' . $original . '</span>'
    );
    return;
  }

  if ($field->field === 'field_current_turf_sq_footage') {
    // Only flag bundles that actually carry this field — i.e. the
    // turf-service WOs where a sq ft is genuinely expected
    // (fertilizing, aerating, dethatching, grub_prevention,
    // lawn_mowing, pre_emergent, special_mowing, estimate). Repair,
    // sprinkler, snow, landscaping etc. don't have the field at all,
    // so a blank Sq. Ft. there is normal — not a missing-data flag.
    // Gating on hasField() is self-maintaining if the field's bundle
    // assignment changes later.
    if (!$entity->hasField('field_current_turf_sq_footage')) {
      return;
    }
    // Field exists on this bundle → empty OR 0 means "not entered".
    $sqft = !$entity->get('field_current_turf_sq_footage')->isEmpty()
      ? (float) $entity->get('field_current_turf_sq_footage')->value
      : 0.0;
    if ($sqft > 0) {
      return;
    }
    $original = $variables['output'] ?? '';
    $variables['output'] = \Drupal\Core\Render\Markup::create(
      '<span style="display:inline-block;background:#f1c40f;color:#000;font-weight:bold;'
      . 'padding:3px 6px;border-radius:3px;border:1px solid #b8920b;" '
      . 'title="No square footage on file — confirm with the crew and enter it before invoicing">'
      . ($original !== '' ? $original : '0') . '</span>'
    );
    return;
  }
}
