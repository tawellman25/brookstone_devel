<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\config_pages\ConfigPagesLoaderInterface;
use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Queue\QueueFactory;
use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_entity_presave().
 */
function wo_weed_spraying_entity_presave(EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'work_order' || $entity->bundle() !== 'weed_spraying') {
    return;
  }

  // Guard: block a duplicate only when a GENUINELY-ACTIVE open weed spray WO
  // already exists for this property+year. Abandoned open WOs (stale-empty /
  // resurrected) are ignored here — they used to trap creation — and are healed
  // by the create controller, the crew add-form alter, or the daily cron sweep.
  // (Read-only check: this runs inside presave, so it must not modify entities.)
  if ($entity->isNew() && !$entity->get('field_property')->isEmpty()) {
    $property_id = (int) $entity->get('field_property')->target_id;
    $active = _wo_weed_spraying_find_active_open_wo($property_id, FALSE);
    if ($active) {
      $msg = "A weed spray work order (#{$active->id()}) is already open for this property. Redirecting you to it.";
      \Drupal::messenger()->addWarning($msg);
      throw new \Drupal\Core\Entity\EntityStorageException($msg);
    }
  }

  // Billing calculation only runs on Complete (1097).
  if (($entity->get('field_status')->target_id ?? 0) != 1097) {
    return;
  }

  $workOrderId = $entity->id();
  if (!is_numeric($workOrderId) || $workOrderId < 1) {
    return;
  }

  $grand_total = 0;
  $chemical_subtotal = 0;
  $labor_subtotal = 0;
  $totalTrip = 0;

  $config_pages_loader = \Drupal::service('config_pages.loader');
  $business_settings = $config_pages_loader->load('business_setting');

  if ($business_settings) {
    $minSprayFee = $business_settings->get('field_minimum_spray_fee')->value ?? 0;
    $minAllottedTime = $business_settings->get('field_spray_minimum_allotted_tim')->value ?? 0;
    $minGallon = $business_settings->get('field_spray_minimum_gallon')->value ?? 0;
    $additionalGallonRate = $business_settings->get('field_additional_per_gallon_fee')->value ?? 0;
    $hourlyRate = $business_settings->get('field_spray_crew_labor')->value ?? 0;
    $hourlyBillingIncrement = $business_settings->get('field_hour_billing_increment')->value ?? 0;
    $sprayMinTrip = $business_settings->get('field_spray_trip_minimum')->value ?? 0;

    $gallonsUsed = get_largest_gallons_used_for_weed_spraying($workOrderId);
    $timeSpent = get_hours_for_weed_spraying($workOrderId);

    // 0-gallon visit = inspection / no-spray check. Bill $0, but DO continue to
    // the property write-back below (Last Checked + no-spray note).
    if ($gallonsUsed == 0) {
      $entity->set('field_wo_total', 0);
    }
    else {
      if ($gallonsUsed > $minGallon) {
        $chemical_subtotal = ($gallonsUsed - $minGallon) * $additionalGallonRate;
      }
      $entity->set('field_material_chemical_total', $chemical_subtotal);

      if ($timeSpent > $minAllottedTime) {
        $extraHours = $timeSpent - $minAllottedTime;
        $additionalIncrements = ceil($extraHours / $hourlyBillingIncrement);
        $labor_subtotal = ($hourlyRate * $hourlyBillingIncrement) * $additionalIncrements;
      }
      $entity->set('field_labor_total', $labor_subtotal);

      if ($sprayMinTrip > 0) {
        $totalTrip = $sprayMinTrip;
        $entity->set('field_trip_fee', $sprayMinTrip);
      } else {
        $totalTrip = $entity->get('field_trip_fee')->value ?? 0;
      }

      if ($minSprayFee > 0) {
        $entity->set('field_task_rate', $minSprayFee);
        $grand_total += $minSprayFee;
      }

      if ($chemical_subtotal > 0) {
        $grand_total += $chemical_subtotal;
      }

      if ($labor_subtotal > 0) {
        $grand_total += $labor_subtotal;
      }

      if ($totalTrip > 0) {
        $grand_total += $totalTrip;
      }

      $billingAdjustment = $entity->get('field_billing_adjustment')->value ?? 0;
      $grand_total += $billingAdjustment;

      if ($grand_total > 0) {
        $entity->set('field_wo_total', $grand_total);
      }
    }
  }

  // Record the visit on the property's weed-spraying info (Last Checked,
  // no-spray note, Last Applied). Shared with the queue worker so the write-back
  // is identical whether it runs synchronously here or via the retry queue.
  _wo_weed_spraying_write_property_info($entity);
}

/**
 * Implements hook_entity_insert().
 */
function wo_weed_spraying_entity_insert(EntityInterface $entity) {
  if ($entity->getEntityTypeId() === 'work_order' && $entity->bundle() === 'weed_spraying' && ($entity->get('field_status')->target_id ?? 0) == 1097) {
    $queue = \Drupal::service('queue')->get('wo_weed_spraying_queue');
    $queue->createItem([
      'work_order_id' => $entity->id(),
      'operation' => 'insert',
      'attempts' => 0,
    ]);
  }
}

/**
 * Implements hook_entity_update().
 */
function wo_weed_spraying_entity_update(EntityInterface $entity) {
  if ($entity->getEntityTypeId() === 'work_order' && $entity->bundle() === 'weed_spraying' && ($entity->get('field_status')->target_id ?? 0) == 1097) {
    $queue = \Drupal::service('queue')->get('wo_weed_spraying_queue');
    $queue->createItem([
      'work_order_id' => $entity->id(),
      'operation' => 'update',
      'attempts' => 0,
    ]);
  }
}

/**
 * Implements hook_queue_info().
 */
function wo_weed_spraying_queue_info() {
  return [
    'wo_weed_spraying_queue' => [
      'title' => t('Weed Spraying Work Order Queue'),
      'description' => t('Queue for processing Weed Spraying work order updates.'),
    ],
  ];
}

/**
 * Process the Weed Spraying queue.
 */
function wo_weed_spraying_process_queue($queue_name, $item) {
  if ($queue_name !== 'wo_weed_spraying_queue') {
    return;
  }

  $workOrderId = $item->data['work_order_id'];
  $operation = $item->data['operation'];
  $attempts = $item->data['attempts'] ?? 0;
  $max_attempts = 3;

  if (!is_numeric($workOrderId) || $workOrderId < 1) {
    return;
  }

  $workOrder = \Drupal::entityTypeManager()->getStorage('work_order')->load($workOrderId);
  if (!$workOrder || $workOrder->bundle() !== 'weed_spraying' || ($workOrder->get('field_status')->target_id ?? 0) != 1097) {
    return;
  }

  $result = _wo_weed_spraying_handle_work_order($workOrder, $operation);
  if (!$result && $attempts < $max_attempts) {
    $queue = \Drupal::service('queue')->get('wo_weed_spraying_queue');
    $queue->createItem([
      'work_order_id' => $workOrderId,
      'operation' => $operation,
      'attempts' => $attempts + 1,
    ]);
    sleep(1);
  }
}

/**
 * Helper function to process work orders.
 */
function _wo_weed_spraying_handle_work_order(EntityInterface $entity, $operation) {
  $workOrderId = $entity->id();
  if (!is_numeric($workOrderId) || $workOrderId < 1 || ($entity->get('field_status')->target_id ?? 0) != 1097) {
    return true;
  }
  return _wo_weed_spraying_write_property_info($entity);
}

/**
 * Writes the weed-spraying visit back to property_spraying_info.
 *
 * Shared by the presave (synchronous) and the retry queue. Always records the
 * visit on field_last_checked. If the sign-off was flagged "No Spray" (or zero
 * gallons), writes a no-spray note to field_last_check_note and leaves Last
 * Applied (date/amount/by) on the last real spray. On a real application,
 * updates Last Applied and clears the note.
 *
 * @return bool
 *   TRUE always (the visit date falls back to now, so there is nothing to retry).
 */
function _wo_weed_spraying_write_property_info(EntityInterface $entity) {
  $workOrderId = $entity->id();
  if (!is_numeric($workOrderId) || $workOrderId < 1) {
    return TRUE;
  }

  $gallonsUsed = get_largest_gallons_used_for_weed_spraying($workOrderId);
  $signOffDateFormatted = NULL;
  $signOffBy = NULL;
  $noSpray = FALSE;

  // Most recent spray-crew sign-off for this WO.
  $result = \Drupal::entityQuery('wo_complete_info')
    ->accessCheck(FALSE)
    ->condition('field_work_order', $workOrderId)
    ->condition('type', 'spray_crew')
    ->sort('field_date_completed', 'DESC')
    ->range(0, 1)
    ->execute();
  if (!empty($result)) {
    $woSignOffInfo = \Drupal::entityTypeManager()->getStorage('wo_complete_info')->load(reset($result));
    if ($woSignOffInfo) {
      $signOffBy = $woSignOffInfo->get('field_signed_off_by')->target_id;
      $noSpray = (bool) ($woSignOffInfo->get('field_no_spray')->value ?? FALSE);
      $ts = $woSignOffInfo->get('field_date_completed')->value;
      if ($ts) {
        $d = DrupalDateTime::createFromTimestamp($ts);
        $d->setTimezone(new \DateTimeZone('UTC'));
        $signOffDateFormatted = $d->format('Y-m-d\TH:i:s');
      }
    }
  }

  // Always have a visit date (fall back to now / current user).
  if (!$signOffDateFormatted) {
    $now = new DrupalDateTime('now', new \DateTimeZone('UTC'));
    $signOffDateFormatted = $now->format('Y-m-d\TH:i:s');
    if (!$signOffBy) {
      $signOffBy = \Drupal::currentUser()->id();
    }
  }

  $propertyId = $entity->get('field_property')->target_id ?? NULL;
  if (!$propertyId) {
    return TRUE;
  }

  $existing = \Drupal::entityTypeManager()->getStorage('property_spraying_info')->loadByProperties([
    'field_property' => $propertyId,
    'type' => 'weed_spraying',
  ]);
  $info = empty($existing)
    ? \Drupal::entityTypeManager()->getStorage('property_spraying_info')->create([
        'type' => 'weed_spraying',
        'field_property' => $propertyId,
      ])
    : reset($existing);

  // Always record the visit.
  $info->set('field_last_checked', $signOffDateFormatted);

  if ($noSpray || $gallonsUsed <= 0) {
    // Checked, nothing applied: note it; leave Last Applied on the last real spray.
    $dateLabel = '';
    try {
      $dt = new \DateTime($signOffDateFormatted, new \DateTimeZone('UTC'));
      $dt->setTimezone(new \DateTimeZone(date_default_timezone_get()));
      $dateLabel = $dt->format('m/d/Y');
    }
    catch (\Exception $e) {
      // Leave blank on a malformed value.
    }
    $byName = '';
    if ($signOffBy && ($u = \Drupal\user\Entity\User::load($signOffBy))) {
      $byName = $u->getDisplayName();
    }
    $info->set('field_last_check_note', 'Checked ' . $dateLabel . ($byName ? ' by ' . $byName : '') . ' - no spraying performed.');
  }
  else {
    // Real application: update Last Applied + clear the no-spray note.
    $info->set('field_last_amount_applied', $gallonsUsed);
    $info->set('field_last_applied_date', $signOffDateFormatted);
    if ($signOffBy) {
      $info->set('field_last_applied_by', $signOffBy);
    }
    $info->set('field_last_check_note', '');
  }

  $info->save();
  return TRUE;
}

/**
 * Retrieves the largest gallons value used for weed_spraying.
 */
function get_largest_gallons_used_for_weed_spraying($workOrderId) {
  if (!is_numeric($workOrderId) || $workOrderId < 1) {
    return 0;
  }

  $query = \Drupal::entityQuery('wo_chemicals_used')
    ->accessCheck(FALSE)
    ->condition('field_work_order', $workOrderId)
    ->condition('type', 'weed_spraying');
  $ids = $query->execute();

  if (empty($ids)) {
    return 0;
  }

  $entities = \Drupal::entityTypeManager()->getStorage('wo_chemicals_used')->loadMultiple($ids);
  $largestGallonsUsed = 0;

  foreach ($entities as $entity) {
    $gallons = $entity->get('field_total_gallons_applied')->value ?? 0;
    if ($gallons > $largestGallonsUsed) {
      $largestGallonsUsed = $gallons;
    }
  }

  return $largestGallonsUsed;
}

/**
 * Retrieves the hours clocked in for Weed Spraying.
 */
function get_hours_for_weed_spraying($workOrderId) {
  if (!is_numeric($workOrderId) || $workOrderId < 1) {
    return 0;
  }

  $query = \Drupal::entityQuery('wo_time_clock')
    ->accessCheck(FALSE)
    ->condition('field_work_order', $workOrderId)
    ->condition('type', 'entry');
  $ids = $query->execute();

  if (empty($ids)) {
    return 0;
  }

  $entities = \Drupal::entityTypeManager()->getStorage('wo_time_clock')->loadMultiple($ids);
  $hoursSpent = 0;

  foreach ($entities as $entity) {
    $hoursSpent += $entity->get('field_total_time')->value ?? 0;
  }

  return $hoursSpent;
}

/**
 * Implements hook_form_alter().
 *
 * Intercepts the wo_chemicals_used:weed_spraying add form to split
 * multiple chemical selections into separate entity saves.
 */
function wo_weed_spraying_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  // Only intercept the weed_spraying chemicals form.
  if ($form_id !== 'wo_chemicals_used_weed_spraying_form') {
    return;
  }

  // Only on add (new entity), not edit.
  $entity = $form_state->getFormObject()->getEntity();
  if (!$entity->isNew()) {
    return;
  }

  // Replace the default submit handler with our own.
  $form['actions']['submit']['#submit'] = ['_wo_weed_spraying_chemicals_multi_submit'];
}

/**
 * Custom submit handler: splits multi-chemical selections into separate entities.
 */
function _wo_weed_spraying_chemicals_multi_submit($form, FormStateInterface $form_state) {
  // Get all selected chemical IDs — field_chemical is now multi-value.
  $chemical_values = $form_state->getValue('field_chemical');

  // Extract target IDs — filter out empty/unselected checkboxes (value = 0).
  $selected_chemicals = [];
  foreach ($chemical_values as $item) {
    $tid = $item['target_id'] ?? 0;
    if ($tid) {
      $selected_chemicals[] = $tid;
    }
  }

  if (empty($selected_chemicals)) {
    \Drupal::messenger()->addError('Please select at least one chemical.');
    return;
  }

  // Get all other field values from the form state.
  $work_order = $form_state->getValue('field_work_order');
  $gallons = $form_state->getValue('field_total_gallons_applied');
  $amount_type = $form_state->getValue('field_chemical_amount_type');
  $per_gallons = $form_state->getValue('field_per_how_many_gallons');
  $total_added = $form_state->getValue('field_total_added_to_sprayer');
  $spreader = $form_state->getValue('field_spreader_sticker_adjuvalen');
  $chemical_cost = $form_state->getValue('field_chemical_cost');
  $spreader_cost = $form_state->getValue('field_spreader_cost');
  $subtotal = $form_state->getValue('field_subtotal');

  $created = 0;
  $storage = \Drupal::entityTypeManager()->getStorage('wo_chemicals_used');

  foreach ($selected_chemicals as $chemical_id) {
    $entity = $storage->create([
      'type' => 'weed_spraying',
      'field_chemical' => ['target_id' => $chemical_id],
      'field_work_order' => $work_order,
      'field_total_gallons_applied' => $gallons,
      'field_chemical_amount_type' => $amount_type,
      'field_per_how_many_gallons' => $per_gallons,
      'field_total_added_to_sprayer' => $total_added,
      'field_spreader_sticker_adjuvalen' => $spreader,
      'field_chemical_cost' => $chemical_cost,
      'field_spreader_cost' => $spreader_cost,
      'field_subtotal' => $subtotal,
      'uid' => \Drupal::currentUser()->id(),
    ]);
    $entity->save();
    $created++;
  }

  // Success message.
  \Drupal::messenger()->addStatus(
    \Drupal::translation()->formatPlural(
      $created,
      '1 chemical record created.',
      '@count chemical records created.'
    )
  );

  // Redirect back to the work order.
  $wo_id = $work_order[0]['target_id'] ?? NULL;
  if ($wo_id) {
    $wo = \Drupal::entityTypeManager()->getStorage('work_order')->load($wo_id);
    if ($wo) {
      $form_state->setRedirectUrl($wo->toUrl());
      return;
    }
  }

  // Fallback redirect to add form.
  $form_state->setRedirect('entity.wo_chemicals_used.add_form',
    ['wo_chemicals_used_type' => 'weed_spraying']);
}

/**
 * Implements hook_form_FORM_ID_alter() for wo_complete_info.
 */
function wo_weed_spraying_form_wo_complete_info_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  $form['#submit'][] = 'wo_weed_spraying_wo_complete_info_submit';
}

/**
 * Custom submit handler to trigger work order save.
 */
function wo_weed_spraying_wo_complete_info_submit($form, FormStateInterface $form_state) {
  $entity = $form_state->getFormObject()->getEntity();
  if ($entity->getEntityTypeId() === 'wo_complete_info' && $entity->bundle() === 'spray_crew') {
    $work_order = $entity->get('field_work_order')->entity;
    if ($work_order && $work_order->bundle() === 'weed_spraying' && ($work_order->get('field_status')->target_id ?? 0) == 1097) {
      $queue = \Drupal::service('queue')->get('wo_weed_spraying_queue');
      $queue->createItem([
        'work_order_id' => $work_order->id(),
        'operation' => 'update',
        'attempts' => 0,
      ]);
    }
  }
}

/**
 * Implements hook_entity_view().
 *
 * Shows a "Customer Prefers Mystic" alert on weed spraying work orders
 * when the property's spraying info has field_prefers_mystic = TRUE.
 */
function wo_weed_spraying_entity_view(array &$build, EntityInterface $entity, $display, $view_mode) {
  if ($entity->getEntityTypeId() !== 'work_order' || $entity->bundle() !== 'weed_spraying') {
    return;
  }

  if (!$entity->hasField('field_property') || $entity->get('field_property')->isEmpty()) {
    return;
  }

  $property_id = (int) $entity->get('field_property')->target_id;
  if ($property_id <= 0) {
    return;
  }

  $spraying_infos = \Drupal::entityTypeManager()
    ->getStorage('property_spraying_info')
    ->loadByProperties([
      'field_property' => $property_id,
      'type' => 'weed_spraying',
    ]);

  if (empty($spraying_infos)) {
    return;
  }

  $spraying_info = reset($spraying_infos);
  if (!$spraying_info->hasField('field_prefers_mystic')
      || $spraying_info->get('field_prefers_mystic')->isEmpty()
      || !(int) $spraying_info->get('field_prefers_mystic')->value) {
    return;
  }

  $build['mystic_alert'] = [
    '#type' => 'inline_template',
    '#template' => '<div role="alert" style="background:#dc3545;color:#fff;padding:10px 16px;border-radius:4px;font-weight:700;font-size:0.95rem;margin-bottom:1rem;">Customer prefers &quot;Mystic&quot; chemical for weed spraying.</div>',
    '#weight' => -100,
  ];
}

/**
 * Implements hook_form_FORM_ID_alter() for work_order_weed_spraying_form.
 *
 * For crew roles: checks if an open weed spray WO already exists for
 * the property and redirects to it instead of showing the add form.
 */
function wo_weed_spraying_form_work_order_weed_spraying_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  // Allow admin/office/supervisor roles through.
  $bypass_roles = ['administrator', 'site_admin', 'administration', 'supervisor'];
  $current_roles = \Drupal::currentUser()->getRoles();
  foreach ($bypass_roles as $role) {
    if (in_array($role, $current_roles)) {
      return;
    }
  }

  // Get property ID from query string or form state.
  $property_id = \Drupal::request()->query->get('field_property');
  if (!$property_id) {
    return;
  }

  // Crew add-form: route to the genuinely-active open WO if one exists. Abandoned
  // open WOs (stale-empty / resurrected) are healed here so they no longer trap
  // the crew, and the add form is allowed to proceed.
  $active = _wo_weed_spraying_find_active_open_wo((int) $property_id, TRUE);
  if ($active) {
    \Drupal::messenger()->addWarning(
      t('A weed spray work order (#@id) is already open for this property. Redirecting you to it.', ['@id' => $active->id()])
    );
    $response = new \Symfony\Component\HttpFoundation\RedirectResponse(
      $active->toUrl('canonical')->toString()
    );
    $response->send();
    exit;
  }
}

/**
 * Status TIDs and the "done" set used across weed-spray housekeeping.
 */
function _wo_weed_spraying_done_statuses(): array {
  // Complete, Canceled, Invoiced, Warrantied.
  return [1097, 1098, 1281, 1283];
}

/**
 * Classifies an open (non-done) weed_spraying WO for housekeeping.
 *
 * @return string
 *   'active'      — genuinely in use (recent, has work, or already invoiced);
 *                   leave alone.
 *   'resurrected' — reached Complete (1097) before, then was reopened (the
 *                   clock-in resurrection bug). Billing/history are involved, so
 *                   it is FLAGGED for office review, never auto-modified.
 *   'stale_empty' — older than 45 days with zero time entries and zero
 *                   chemicals; abandoned and safe to auto-cancel.
 */
function _wo_weed_spraying_classify_open_wo(EntityInterface $wo): string {
  $etm = \Drupal::entityTypeManager();
  $id = $wo->id();

  // Never touch a WO that has already been billed.
  if ((int) ($wo->get('field_invoiced')->value ?? 0) === 1) {
    return 'active';
  }

  $had_complete = (int) $etm->getStorage('wo_status_updates')->getQuery()
    ->accessCheck(FALSE)
    ->condition('field_status_of_wo', $id)
    ->condition('field_status', 1097)
    ->count()->execute();
  if ($had_complete > 0) {
    return 'resurrected';
  }

  $age_days = (\Drupal::time()->getRequestTime() - (int) $wo->get('created')->value) / 86400;
  if ($age_days > 45) {
    $time = (int) $etm->getStorage('wo_time_clock')->getQuery()->accessCheck(FALSE)->condition('field_work_order', $id)->count()->execute();
    $chem = (int) $etm->getStorage('wo_chemicals_used')->getQuery()->accessCheck(FALSE)->condition('field_work_order', $id)->count()->execute();
    if ($time === 0 && $chem === 0) {
      return 'stale_empty';
    }
  }

  return 'active';
}

/**
 * Drives a weed_spraying WO to a status via a wo_status_updates audit record.
 *
 * Mirrors how MarkWorkOrderInvoicedAction transitions status: the status-update
 * entity's presave propagates field_status onto the WO, leaving an audit trail.
 */
function _wo_weed_spraying_set_status(EntityInterface $wo, int $status_tid, string $note): bool {
  try {
    \Drupal::entityTypeManager()->getStorage('wo_status_updates')->create([
      'type' => 'update',
      'field_status_of_wo' => $wo->id(),
      'field_status' => $status_tid,
      'field_status_change_note' => $note,
      'uid' => \Drupal::currentUser()->id() ?: 1,
    ])->save();
    return TRUE;
  }
  catch (\Exception $e) {
    \Drupal::logger('wo_weed_spraying')->error('Housekeeping status change failed for WO @id -> @s: @m', [
      '@id' => $wo->id(), '@s' => $status_tid, '@m' => $e->getMessage(),
    ]);
    return FALSE;
  }
}

/**
 * Auto-cancels one stale-empty open WO via a status-update audit record.
 *
 * Only ever called for the 'stale_empty' class (old, zero time, zero chemicals,
 * not invoiced) — the case where cancellation is unambiguously safe.
 */
function _wo_weed_spraying_cancel_stale(EntityInterface $wo): bool {
  $created = date('m/d/Y', (int) $wo->get('created')->value);
  $age = (int) ((\Drupal::time()->getRequestTime() - (int) $wo->get('created')->value) / 86400);
  if (_wo_weed_spraying_set_status($wo, 1098, "Auto-canceled by spray housekeeping: created {$created}, no time or chemicals recorded after {$age} days. The number is kept as a canceled record; a fresh spray WO can now be created for this property.")) {
    \Drupal::logger('wo_weed_spraying')->notice('Spray housekeeping canceled abandoned WO @id (created @c, no work).', ['@id' => $wo->id(), '@c' => $created]);
    return TRUE;
  }
  return FALSE;
}

/**
 * Finds the genuinely-active open weed_spraying WO for a property this year.
 *
 * Abandoned open WOs (stale-empty / resurrected) are NOT considered active —
 * they are exactly what used to trap techs, since the create route, the crew
 * add-form, and the presave guard all treated any open WO as a blocker. When
 * $heal is TRUE the abandoned ones are healed in place so they stop blocking;
 * when FALSE (e.g. inside a presave) the function only inspects.
 *
 * @return \Drupal\Core\Entity\EntityInterface|null
 *   The active open WO, or NULL.
 */
function _wo_weed_spraying_find_active_open_wo(int $property_id, bool $heal = FALSE): ?EntityInterface {
  if ($property_id < 1) {
    return NULL;
  }
  $storage = \Drupal::entityTypeManager()->getStorage('work_order');
  $year = date('Y');
  $ids = $storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('type', 'weed_spraying')
    ->condition('field_property', $property_id)
    ->condition('field_status', _wo_weed_spraying_done_statuses(), 'NOT IN')
    ->condition('created', [strtotime("{$year}-01-01 00:00:00"), strtotime("{$year}-12-31 23:59:59")], 'BETWEEN')
    ->sort('created', 'DESC')
    ->execute();
  $active = NULL;
  foreach ($storage->loadMultiple($ids) as $wo) {
    $class = _wo_weed_spraying_classify_open_wo($wo);
    if ($class === 'active') {
      if ($active === NULL) {
        $active = $wo;
      }
      continue;
    }
    // Auto-cancel only the safe case (stale-empty). Resurrected WOs are left
    // untouched here — they are non-active so they no longer block creation,
    // and the daily sweep flags them for office review (billing-sensitive).
    if ($heal && $class === 'stale_empty') {
      _wo_weed_spraying_cancel_stale($wo);
    }
  }
  return $active;
}

/**
 * Sweeps all open weed_spraying WOs, healing abandoned ones.
 *
 * Shared by hook_cron and the one-time cleanup script.
 */
function _wo_weed_spraying_sweep_abandoned(bool $dry_run = FALSE): array {
  $storage = \Drupal::entityTypeManager()->getStorage('work_order');
  // Scope to the current year — the trap (and the create flow) only concerns
  // this season's WOs; older WOs in legacy statuses are out of scope.
  $year = date('Y');
  $ids = $storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('type', 'weed_spraying')
    ->condition('field_status', _wo_weed_spraying_done_statuses(), 'NOT IN')
    ->condition('created', [strtotime("{$year}-01-01 00:00:00"), strtotime("{$year}-12-31 23:59:59")], 'BETWEEN')
    ->execute();
  $out = ['canceled' => [], 'flagged' => [], 'active' => 0];
  foreach ($storage->loadMultiple($ids) as $wo) {
    $class = _wo_weed_spraying_classify_open_wo($wo);
    if ($class === 'active') {
      $out['active']++;
      continue;
    }
    if ($class === 'resurrected') {
      // Billing/history-sensitive — flag for office review, never auto-modify.
      $out['flagged'][] = $wo->id();
      if (!$dry_run) {
        \Drupal::logger('wo_weed_spraying')->warning('Spray housekeeping: resurrected WO @id (reached Complete, then reopened) needs office review — finalize (Complete/Invoice) or Cancel by hand so billing and spray history stay correct.', ['@id' => $wo->id()]);
      }
      continue;
    }
    // stale_empty.
    if ($dry_run) {
      $out['canceled'][] = $wo->id();
      continue;
    }
    if (_wo_weed_spraying_cancel_stale($wo)) {
      $out['canceled'][] = $wo->id();
    }
  }
  return $out;
}

/**
 * Implements hook_cron().
 *
 * Once a day, sweep abandoned weed_spraying WOs so stale/resurrected ones don't
 * trap their property in the create flow (and so the route report stays honest).
 */
function wo_weed_spraying_cron() {
  $state = \Drupal::state();
  $now = \Drupal::time()->getRequestTime();
  if ($now - (int) $state->get('wo_weed_spraying.last_sweep', 0) < 82800) {
    return;
  }
  $state->set('wo_weed_spraying.last_sweep', $now);
  $res = _wo_weed_spraying_sweep_abandoned();
  if (!empty($res['canceled']) || !empty($res['flagged'])) {
    \Drupal::logger('wo_weed_spraying')->notice('Spray housekeeping sweep: canceled @c stale-empty, flagged @f resurrected for review.', [
      '@c' => count($res['canceled']),
      '@f' => count($res['flagged']),
    ]);
  }
}