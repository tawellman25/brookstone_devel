{% if content.field_variant.0['#markup'] == "style- 1" %}
    <section class="portfolio-details-1 portfolio-details dt-section">
            <div class="container">
                <div class="images">
                    <div class="portfolio-details-slider owl-carousel owl-theme">
                    {% for key,value in content.field_images['#items'] %}
                        <div class="item">
                            <img src="{{file_url(content.field_images['#items'][key].entity.uri.value)}}" alt="{{content.field_images['#items'][key].alt}}">
                        </div>
                    {% endfor %}
                    </div>
                </div>
                <div class="contents">
                    <div class="content">
                        <div class="title">
                            <h2>{{content.field_title_1.0}}</h2>
                        </div>
                        <div class="content-item">
                            {{content.field_description.0}}
                            <ul class="details">
                                <li><span>{{content.field_subtitle_1.0}}</span>{{content.field_subcontent_1.0}}</li>
                                <li><span>{{content.field_subtitle_2.0}}</span>{{content.field_category.0['#title']}}</li>
                                <li><span>{{content.field_subtitle_3.0}}</span>{{content.field_project_date.value| date('d F, o')}}</li>
                            </ul>
                        </div>
                    </div>
                    <div class="content">
                        <div class="title">
                            <h2>{{content.field_title_2.0}}</h2>
                        </div>
                        <ul class="social-icons">
                           {{ drupal_block('addtoany_block') }} 
                        </ul>
                    </div>
                </div>
            </div>
        </section>
{% elseif content.field_variant.0['#markup'] == "style- 2" %}
    <section class="portfolio-details-2 portfolio-details sidebar-page dt-section">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 col-md-12 col-12">
                    <div class="full-width">
                        <div class="images">
                            <div class="row s-10">
                            {% for key,value in content.field_images['#items'] %}
                                {% if key != 2%}
                                <div class="col-lg-6 col-md-6 col-12">
                                    <div class="item">
                                        <img src="{{file_url(content.field_images['#items'][key].entity.uri.value)}}" alt="{{content.field_images['#items'][key].alt}}">
                                    </div>
                                </div>        
                                {% else %}
                                <div class="col-lg-12 col-md-12 col-12">
                                    <div class="item">
                                        <img src="{{file_url(content.field_images['#items'][key].entity.uri.value)}}" alt="{{content.field_images['#items'][key].alt}}">
                                    </div>
                                </div>
                                {% endif %}
                            {% endfor %}
                            </div>
                        </div>
                        <h2>{{content.field_title_2.0}}</h2>
                        {{content.field_description.0}}
                        <ul class="social-icons">
                            {{ drupal_block('addtoany_block') }} 
                        </ul>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 col-12">
                    <div class="sidebar">
                        <div class="details-wrapper">
                            <h3>{{content.field_title_1.0}}</h3>
                            <ul class="details">
                                <li><span>{{content.field_subtitle_1.0}}</span>{{content.field_subcontent_1.0}}</li>
                                <li><span>{{content.field_subtitle_2.0}}</span>{{content.field_category.0['#title']}}</li>
                                <li><span>{{content.field_subtitle_3.0}}</span>{{content.field_project_date.value| date('d F, o')}}</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% elseif content.field_variant.0['#markup'] == "style- 3" %}
    <section class="portfolio-details-3 portfolio-details dt-section">
        <div class="container">
            <div class="row align-items-center s-0">
                <div class="col-lg-5 col-md-6 col-12">
                    <div class="image">
                        <img src="{{file_url(content.field_images['#items'].entity.uri.value)}}" alt="{{content.field_images['#items'].alt}}">
                    </div>
                </div>
                <div class="col-lg-7 col-md-12 col-12">
                    <div class="content">
                        <h2>{{content.field_title_1.0}}</h2>
                        {{content.field_description.0}}
                        <ul class="details">
                            <li><span>{{content.field_subtitle_1.0}}</span>{{content.field_subcontent_1.0}}</li>
                            <li><span>{{content.field_subtitle_2.0}}</span>{{content.field_category.0['#title']}}</li>
                            <li><span>{{content.field_subtitle_2.0}}</span>{{content.field_project_date.value| date('d F, o')}}</li>
                        </ul>
                        <ul class="social-icons">
                            {{ drupal_block('addtoany_block') }} 
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endif %}