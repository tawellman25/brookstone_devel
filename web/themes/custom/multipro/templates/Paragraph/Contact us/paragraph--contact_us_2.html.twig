<section class="map contact-2-map">
    <div class="item">
        <div class="map-style-1">
            <div id="map-container-google-2" class="z-depth-1-half map-container">
                {{content.field_location_on_map.0}}
            </div>
        </div>
    </div>
</section>
<section class="contact-style-2-form bg-blue dt-section">
    <div class="container">
        <div class="contact-details">
            <div class="row s-40">
                <div class="col-lg-6 col-md-6 col-12">
                    <div class="image">
                        <img src="{{file_url(content.field_image['#items'].entity.uri.value)}}" alt="{{content.field_image['#items'].alt}}">
                    </div>
                </div>
                <div class="col-lg-6 col-md-6 col-12">
                    <ul class="details">
                        <li><span>{{content.field_title1.0}}</span><a href="https://maps.google.com" title="{{content.field_address.0}}">{{content.field_address.0}}</a></li>
                        <li><span>{{content.field_title2.0}}</span><a href="tel:{{content.field_suffix.0}}" title="{{content.field_phone.0}}">{{content.field_phone.0}}</a></li>
                        <li><span>{{content.field_title3.0}}</span><a href="mailto:mail@domain.com" title="{{content.field_mail.0}}">{{content.field_mail.0}}</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="contact-form">
            <div class="row s-35">
                <div class="col-lg-4 col-md-12 col-12">
                    <h2>{{content.field_title.0}}</h2>
                </div>
                <div class="col-lg-8 col-md-12 col-12">
                    <div class="form-style-3">
                        {{content.field_contact_form.0}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>