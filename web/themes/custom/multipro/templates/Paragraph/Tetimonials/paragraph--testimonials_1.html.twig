<section class="testimonials-1">
    <div class="container">
        <div class="row s-0">
            <div class="col-lg-6 col-md-5 col-12">
                <div class="image">
                    <img src="{{file_url(content.field_image['#items'].entity.uri.value)}}" alt="{{file_url(content.field_image['#items'].alt)}}">
                    <div class="overlay">
                        <div class="counter-item">
                            <div class="value"><span data-purecounter-start="0" data-purecounter-end="{{content.field_counter.0}}" class="purecounter"></span><span>{{content.field_suffix.0}}</span></div>
                            <h6>{{content.field_title.0}}</h6>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 col-md-7 col-12">
                {{content.field_testimonials}}
            </div>
        </div>
    </div>
</section>